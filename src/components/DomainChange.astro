---
// src/components/DomainChange.astro
---

<div class="relative z-60 border-b border-stone-700/80 bg-stone-900">
  <div class="mx-auto max-w-(--breakpoint-2xl) px-4 sm:px-6 lg:px-8">
    <div
      class="flex flex-wrap items-center gap-x-3 gap-y-2 py-2.5 text-xs sm:text-sm"
    >
      <span
        class="inline-flex items-center border border-stone-700 bg-stone-800 px-2 py-1 font-mono text-[10px] font-black uppercase tracking-[0.2em] text-amber-300"
      >
        Domain Update
      </span>
      <p class="font-medium text-stone-300">
        Friends of Ute Valley Park is now at
        <a
          href="https://fuvp.org"
          class="font-bold text-amber-300 underline decoration-amber-300/50 underline-offset-4 transition-colors hover:decoration-amber-300"
          >fuvp.org</a
        >.
      </p>
    </div>
  </div>
</div>
