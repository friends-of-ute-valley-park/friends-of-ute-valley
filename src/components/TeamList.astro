---
import { Image } from "astro:assets";

const teamMembers = [
  {
    name: "Drew Town",
    title: "Chair",
    image: import("@/assets/images/members/drew-town.png"),
  },
  {
    name: "Christine Thomas",
    title: "Vice-Chair",
    image: import("@/assets/images/members/christine-thomas.jpg"),
  },
  {
    name: "Megan Town",
    title: "Treasurer",
    image: import("@/assets/images/members/megan-town.jpg"),
  },
  {
    name: "Katie Gray",
    title: "Secretary & Nature and Trail Specialist",
    image: import("@/assets/images/members/katie-gray.jpg"),
  },
  {
    name: "Phill Emmert",
    title: "Communications",
    image: import("@/assets/images/members/phill-emmert.jpg"),
  },
  {
    name: "Haley Kline Murphy",
    title: "Education and Stewardship Coordinator",
    image: import("@/assets/images/members/haley-kline-murphy.jpg"),
  },
  {
    name: "Pete Galeotti",
    title: "Outreach and Engagement Specialist",
    image: import("@/assets/images/members/pete-galeotti.jpg"),
  },
  {
    name: "Nadine Lambert",
    title: "Volunteer Coordinator",
    image: import("@/assets/images/members/nadine-lambert.jpg"),
  },
  {
    name: "Jake Nixon",
    title: "Historian",
    image: import("@/assets/images/members/jake-nixon.jpg"),
  },
];
---

<div class="team-list">
  <div class="inner l-container">
    <div class="header section-heading">
      <div class="eyebrow section-kicker">
        <span class="section-kicker__rule"></span>
        <span class="section-kicker__text">Our Team</span>
      </div>
      <h2 class="section-heading__title">
        Meet the <span>Team.</span>
      </h2>
      <p class="section-heading__copy">
        The dedicated leadership team overseeing the preservation, community
        outreach, and technical operations of the Ute Valley urban wildland.
      </p>
    </div>

    <div class="grid feature-grid feature-grid--two-sm feature-grid--three">
      {
        teamMembers.map((teamMember) => (
          <div class="card media-zoom-parent">
            <div class="media">
              <Image
                height="600"
                width="600"
                class="image media-cover media-zoom"
                src={teamMember.image}
                alt={teamMember.name}
              />
              <div class="matte media-matte" />
            </div>
            <div class="body">
              <h3 class="name card-title">
                {teamMember.name}
              </h3>
              <p class="meta-label">
                {teamMember.title}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .team-list {
    border-bottom: 1px solid var(--color-border);
    padding-block: 6rem;
  }

  .team-list .header {
    margin-bottom: 4rem;
  }

  .team-list .card {
    background: var(--color-surface);
    transition: background-color 200ms;
  }

  .team-list .card:hover {
    background: var(--color-page);
  }

  .team-list .media {
    position: relative;
    aspect-ratio: 1;
    width: 100%;
    overflow: hidden;
    filter: grayscale(1);
    transition: filter 700ms;
  }

  .team-list .card:hover .media {
    filter: grayscale(0);
  }

  .team-list .body {
    display: grid;
    gap: 0.5rem;
    border-top: 1px solid var(--color-border-muted);
    padding: 1.5rem;
  }

  .team-list .name {
    --card-title-size: 1.125rem;
  }

  .team-list .body p {
    --meta-label-tracking: var(--tracking-label);
    margin: 0;
    color: var(--color-brand-strong);
  }

</style>
