---
const stats = [
  { id: 1, name: "Individual volunteers", value: "130" },
  { id: 2, name: "Total volunteer hours", value: "538" },
  { id: 3, name: "Instagram followers", value: "1,900" },
  { id: 4, name: "Community survey responses", value: "105" },
];

import { Image } from "astro:assets";
import Volunteers from "@/assets/images/volunteer-6.jpg";
---

<div class="impact-stats">
  <div class="impact-stats__layout">
    <!-- Image with technical frame -->
    <div class="impact-stats__media">
      <Image
        src={Volunteers}
        alt="Volunteers in action"
        class="impact-stats__image"
      />
      <div class="impact-stats__matte"></div>
    </div>

    <!-- Stats Content -->
    <div class="impact-stats__content">
      <div class="impact-stats__stack">
        <div class="impact-stats__heading section-heading">
          <div class="impact-stats__eyebrow section-kicker">
            <span class="section-kicker__rule"></span>
            <span class="section-kicker__text">Year in Review: 2024</span>
          </div>
          <h2 class="section-heading__title">
            Our <br />
            <span>Impact.</span>
          </h2>
          <p class="section-heading__copy">
            Here's what our amazing volunteers accomplished together in 2024.
          </p>
        </div>

        <div class="impact-stats__grid feature-grid">
          {
            stats.map((stat) => (
              <div class="impact-stats__stat">
                <div>
                  {stat.value}
                </div>
                <div>
                  {stat.name}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .impact-stats {
    position: relative;
    overflow: hidden;
    border-block: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .impact-stats__layout {
    display: grid;
  }

  .impact-stats__media {
    position: relative;
    height: 24rem;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  :global(.impact-stats__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .impact-stats__matte {
    position: absolute;
    inset: 0;
    border: 1.5rem solid color-mix(in oklab, var(--color-surface) 10%, transparent);
    pointer-events: none;
  }

  .impact-stats__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 5vw, 4rem);
  }

  .impact-stats__stack {
    display: grid;
    gap: 3rem;
  }

  .impact-stats__heading {
    --section-heading-title-size: clamp(2.25rem, 5vw, 3rem);
    --section-heading-accent-style: normal;
    --section-heading-copy-width: 36rem;
    --section-kicker-rule-color: var(--color-accent-strong);
    --section-kicker-text-color: var(--color-accent-strong);
  }

  .impact-stats__stat div:last-child {
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .impact-stats__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    --feature-grid-border-color: var(--color-border-muted);
    --feature-grid-background: var(--color-border-muted);
  }

  .impact-stats__stat {
    display: grid;
    gap: 0.25rem;
    background: var(--color-surface);
    padding: 1.5rem;
    transition: background-color 200ms;
  }

  .impact-stats__stat:hover {
    background: var(--color-page);
  }

  .impact-stats__stat div:first-child {
    color: var(--color-text-strong);
    font-family: var(--font-label);
    font-size: clamp(1.875rem, 4vw, 2.25rem);
    font-weight: 900;
    letter-spacing: 0;
    font-variant-numeric: tabular-nums;
  }

  .impact-stats__stat div:last-child {
    color: var(--color-text-subtle);
  }

  @media (min-width: 64rem) {
    .impact-stats__layout {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .impact-stats__media {
      height: auto;
      border-right: 1px solid var(--color-border);
      border-bottom: 0;
    }
  }
</style>
