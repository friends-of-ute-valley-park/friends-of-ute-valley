---
import { isDateInList } from "../utils/date";

export interface Props {
  eventDates?: string[];
}

const { eventDates = [] } = Astro.props as Props;

type CalendarEventType = "public" | "company";

type CalendarEvent = {
  date: string;
  type: CalendarEventType;
  title: string;
  companyName?: string;
};

const seasonEvents: CalendarEvent[] = [
  { date: "2026-05-20", type: "public", title: "Public volunteer event" },
  { date: "2026-06-03", type: "public", title: "Public volunteer event" },
  { date: "2026-06-17", type: "public", title: "Public volunteer event" },
  { date: "2026-07-01", type: "public", title: "Public volunteer event" },
  { date: "2026-07-15", type: "public", title: "Public volunteer event" },
  { date: "2026-08-05", type: "public", title: "Public volunteer event" },
  { date: "2026-08-19", type: "public", title: "Public volunteer event" },
  { date: "2026-09-02", type: "public", title: "Public volunteer event" },
  {
    date: "2026-05-18",
    type: "company",
    title: "Company volunteer event",
    companyName: "Entegris",
  },
  {
    date: "2026-06-26",
    type: "company",
    title: "Company volunteer event",
    companyName: "Orthopedic Rehabilitation Associates",
  },
  {
    date: "2026-08-01",
    type: "company",
    title: "Company volunteer event",
    companyName: "Trail Sisters",
  },
];

const toLocalDate = (dateString: string) => {
  const [year, month, day] = dateString.split("-").map(Number);
  return new Date(year, month - 1, day);
};

const propEvents = eventDates.map((date) => ({
  date,
  type: "public" as const,
  title: "Public volunteer event",
}));
const calendarEvents = propEvents.length > 0 ? propEvents : seasonEvents;
const volunteerEventDates = calendarEvents.map((event) => toLocalDate(event.date));
const currentYear =
  calendarEvents.length > 0
    ? toLocalDate(calendarEvents[0].date).getFullYear()
    : new Date().getFullYear();
const allMonths = [
  { label: "April", monthIndex: 3 },
  { label: "May", monthIndex: 4 },
  { label: "June", monthIndex: 5 },
  { label: "July", monthIndex: 6 },
  { label: "August", monthIndex: 7 },
  { label: "September", monthIndex: 8 },
];

const eventMonthIndexes = volunteerEventDates.map((date) => date.getMonth());
const firstVisibleMonth =
  eventMonthIndexes.length > 0 ? Math.min(...eventMonthIndexes) : 3;
const lastVisibleMonth =
  eventMonthIndexes.length > 0 ? Math.max(...eventMonthIndexes) : 8;

const months = allMonths.filter(
  ({ monthIndex }) =>
    monthIndex >= firstVisibleMonth && monthIndex <= lastVisibleMonth,
);

const getDaysInMonth = (year: number, month: number) => {
  const dayCount = new Date(year, month + 1, 0).getDate();

  return Array.from(
    { length: dayCount },
    (_, dayIndex) => new Date(year, month, dayIndex + 1),
  );
};

const getCalendarEvent = (date: Date) =>
  calendarEvents.find((event) => isDateInList(date, [toLocalDate(event.date)]));

const getEventLabel = (event: CalendarEvent) =>
  event.companyName ? `${event.title}: ${event.companyName}` : event.title;
---

<div class="static-calendar">
  <div class="header">
    <div class="heading section-heading">
      <div class="eyebrow section-kicker">
        <span class="section-kicker__rule"></span>
        <span class="section-kicker__text">Volunteer Calendar</span>
      </div>
      <h2 class="section-heading__title">
        Posted <span>Workdays.</span>
      </h2>
    </div>
    <div class="intro">
      <p class="section-heading__copy">
        Highlighted dates show public volunteer sessions and company community
        workdays. Company workdays are not open to public registration.
      </p>
      <div class="legend">
        <div>
          <span class="legend-swatch public" aria-hidden="true"></span>
          <span>Public</span>
        </div>
        <div>
          <span class="legend-swatch company" aria-hidden="true"></span>
          <span>Company</span>
        </div>
      </div>
    </div>
  </div>

  <div class="months feature-grid feature-grid--two feature-grid--three-xl">
    {
      months.map(({ label, monthIndex }) => {
        const daysInMonth = getDaysInMonth(currentYear, monthIndex);
        const firstDayOfWeek = daysInMonth[0].getDay();

        return (
          <div class="month">
            <h3>
              {label}
            </h3>
            <div class="grid">
              {["S", "M", "T", "W", "T", "F", "S"].map((day) => (
                <div class="weekday">
                  {day}
                </div>
              ))}

              {Array.from({ length: firstDayOfWeek }).map(() => (
                <div class="day blank" />
              ))}

              {daysInMonth.map((day) => {
                const calendarEvent = getCalendarEvent(day);
                const isVolunteerDay = Boolean(calendarEvent);
                const isCompanyEvent = calendarEvent?.type === "company";
                const eventLabel = calendarEvent ? getEventLabel(calendarEvent) : undefined;

                return (
                  <div
                    class:list={[
                      "day",
                      !isVolunteerDay && "day empty",
                      isVolunteerDay && !isCompanyEvent && "day public",
                      isCompanyEvent && "day company",
                    ]}
                    title={isCompanyEvent ? eventLabel : undefined}
                    aria-label={eventLabel}
                  >
                    <span
                      class:list={[
                        "day-number",
                        isVolunteerDay && !isCompanyEvent
                          ? "day-number public"
                          : isCompanyEvent
                          ? "day-number company"
                          : "day-number empty",
                      ]}
                    >
                      {day.getDate()}
                    </span>
                    {
                      isVolunteerDay && !isCompanyEvent && (
                        <div class="event-outline public" />
                      )
                    }
                    {
                      isCompanyEvent && (
                        <div class="event-outline company" />
                      )
                    }
                  </div>
                );
              })}

              {Array.from({
                length: (7 - ((daysInMonth.length + firstDayOfWeek) % 7)) % 7,
              }).map(() => (
                <div class="day blank" />
              ))}
            </div>
          </div>
        );
      })
    }
  </div>
</div>

<style>
  .static-calendar {
    width: min(100% - (var(--space-page-x) * 2), var(--container-wide));
    margin-inline: auto;
    padding-block: 3rem;
  }

  .static-calendar .header {
    display: grid;
    align-items: end;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .static-calendar .legend span:last-child,
  .static-calendar .weekday {
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .static-calendar .intro {
    --section-heading-copy-width: 28rem;
    --section-heading-copy-margin: 0;
    --section-heading-copy-size: var(--text-body-small);
    max-width: 28rem;
  }

  .static-calendar .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .static-calendar .legend div {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .static-calendar .legend-swatch {
    width: 0.75rem;
    height: 0.75rem;
  }

  .static-calendar .legend-swatch.public {
    border: 1px solid var(--color-brand-strong);
    background: color-mix(in oklab, var(--color-brand) 15%, transparent);
  }

  .static-calendar .legend-swatch.company {
    border: 1px solid var(--color-accent-strong);
    background: color-mix(in oklab, var(--color-accent) 25%, transparent);
  }

  .static-calendar .legend span:last-child {
    color: var(--color-text-muted);
  }

  .static-calendar .month {
    background: var(--color-surface);
    padding: 2rem;
  }

  .static-calendar .month h3 {
    margin: 0 0 1.5rem;
    border-bottom: 1px solid var(--color-border-muted);
    padding-bottom: 0.5rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .static-calendar .grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--color-border-muted);
    background: var(--color-border-muted);
  }

  .static-calendar .weekday {
    background: var(--color-page);
    color: var(--color-text-subtle);
    padding-block: 0.5rem;
    text-align: center;
  }

  .static-calendar .day {
    position: relative;
    display: flex;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
  }

  .static-calendar .day.blank,
  .static-calendar .day.empty {
    background: var(--color-surface);
  }

  .static-calendar .day.public {
    background: color-mix(in oklab, var(--color-brand) 6%, transparent);
  }

  .static-calendar .day.company {
    background: color-mix(in oklab, var(--color-accent) 15%, transparent);
  }

  .static-calendar .day-number {
    font-family: var(--font-label);
    font-size: 0.75rem;
  }

  .static-calendar .day-number.empty {
    color: var(--color-text-muted);
  }

  .static-calendar .day-number.public,
  .static-calendar .day-number.company {
    font-weight: 900;
  }

  .static-calendar .day-number.public {
    color: var(--color-brand-strong);
  }

  .static-calendar .day-number.company {
    color: var(--color-accent-strong);
  }

  .static-calendar .event-outline {
    position: absolute;
    inset: 0.25rem;
    pointer-events: none;
  }

  .static-calendar .event-outline.public {
    border: 1px solid color-mix(in oklab, var(--color-brand-strong) 40%, transparent);
  }

  .static-calendar .event-outline.company {
    border: 1px solid color-mix(in oklab, var(--color-accent-strong) 60%, transparent);
  }

  @media (min-width: 48rem) {
    .static-calendar .header {
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.8fr);
    }
  }
</style>
