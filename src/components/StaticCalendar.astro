---
import {
  eachDayOfInterval,
  endOfMonth,
  format,
  getDay,
  startOfMonth,
} from "date-fns";
import { isDateInList } from "../utils/date";

export interface Props {
  eventDates?: string[];
}

const { eventDates = [] } = Astro.props as Props;

type CalendarEventType = "public" | "company";

type CalendarEvent = {
  date: string;
  type: CalendarEventType;
  title: string;
  companyName?: string;
};

const seasonEvents: CalendarEvent[] = [
  { date: "2026-05-20", type: "public", title: "Public volunteer event" },
  { date: "2026-06-03", type: "public", title: "Public volunteer event" },
  { date: "2026-06-17", type: "public", title: "Public volunteer event" },
  { date: "2026-07-01", type: "public", title: "Public volunteer event" },
  { date: "2026-07-15", type: "public", title: "Public volunteer event" },
  { date: "2026-08-05", type: "public", title: "Public volunteer event" },
  { date: "2026-08-19", type: "public", title: "Public volunteer event" },
  { date: "2026-09-02", type: "public", title: "Public volunteer event" },
  {
    date: "2026-05-18",
    type: "company",
    title: "Company volunteer event",
    companyName: "Entegris",
  },
  {
    date: "2026-06-26",
    type: "company",
    title: "Company volunteer event",
    companyName: "Orthopedic Rehabilitation Associates",
  },
  {
    date: "2026-08-01",
    type: "company",
    title: "Company volunteer event",
    companyName: "Trail Sisters",
  },
];

const toLocalDate = (dateString: string) => {
  const [year, month, day] = dateString.split("-").map(Number);
  return new Date(year, month - 1, day);
};

const propEvents = eventDates.map((date) => ({
  date,
  type: "public" as const,
  title: "Public volunteer event",
}));
const calendarEvents = propEvents.length > 0 ? propEvents : seasonEvents;
const volunteerEventDates = calendarEvents.map((event) => toLocalDate(event.date));
const currentYear =
  calendarEvents.length > 0
    ? toLocalDate(calendarEvents[0].date).getFullYear()
    : new Date().getFullYear();
const allMonths = [
  { label: "April", monthIndex: 3 },
  { label: "May", monthIndex: 4 },
  { label: "June", monthIndex: 5 },
  { label: "July", monthIndex: 6 },
  { label: "August", monthIndex: 7 },
  { label: "September", monthIndex: 8 },
];

const eventMonthIndexes = volunteerEventDates.map((date) => date.getMonth());
const firstVisibleMonth =
  eventMonthIndexes.length > 0 ? Math.min(...eventMonthIndexes) : 3;
const lastVisibleMonth =
  eventMonthIndexes.length > 0 ? Math.max(...eventMonthIndexes) : 8;

const months = allMonths.filter(
  ({ monthIndex }) =>
    monthIndex >= firstVisibleMonth && monthIndex <= lastVisibleMonth,
);

const getDaysInMonth = (year: number, month: number) => {
  const start = startOfMonth(new Date(year, month));
  const end = endOfMonth(start);
  return eachDayOfInterval({ start, end });
};

const getCalendarEvent = (date: Date) =>
  calendarEvents.find((event) => isDateInList(date, [toLocalDate(event.date)]));

const getEventLabel = (event: CalendarEvent) =>
  event.companyName ? `${event.title}: ${event.companyName}` : event.title;
---

<div
  class="calendar-container mx-auto max-w-(--breakpoint-2xl) px-4 py-12 sm:px-6 lg:px-8"
>
  <div
    class="mb-12 grid items-end gap-8 md:grid-cols-[minmax(0,1fr)_minmax(0,0.8fr)]"
  >
    <div class="space-y-4">
      <div class="flex items-center gap-4">
        <span class="inline-block h-px w-8 bg-primary-dark"></span>
        <span
          class="font-mono text-[10px] font-black uppercase tracking-[0.2em] text-stone-500"
          >Volunteer Calendar</span
        >
      </div>
      <h2
        class="text-4xl font-serif font-black uppercase leading-none tracking-tight text-stone-900 sm:text-6xl"
      >
        Posted <span class="italic text-primary-dark">Workdays.</span>
      </h2>
    </div>
    <div class="max-w-md">
      <p class="text-sm font-medium leading-relaxed text-stone-600">
        Highlighted dates show public volunteer sessions and company community
        workdays. Company workdays are not open to public registration.
      </p>
      <div class="mt-5 flex flex-wrap gap-4">
        <div class="flex items-center gap-2">
          <span
            class="h-3 w-3 border border-primary-dark bg-primary/15"
            aria-hidden="true"></span>
          <span class="font-mono text-[10px] font-black uppercase tracking-widest text-stone-600"
            >Public</span
          >
        </div>
        <div class="flex items-center gap-2">
          <span
            class="h-3 w-3 border border-accent-dark bg-accent/25"
            aria-hidden="true"></span>
          <span class="font-mono text-[10px] font-black uppercase tracking-widest text-stone-600"
            >Company</span
          >
        </div>
      </div>
    </div>
  </div>

  <div
    class="grid grid-cols-1 gap-px border border-stone-300 bg-stone-300 md:grid-cols-2 xl:grid-cols-3"
  >
    {
      months.map(({ label, monthIndex }) => {
        const daysInMonth = getDaysInMonth(currentYear, monthIndex);
        const firstDayOfWeek = getDay(daysInMonth[0]);

        return (
          <div class="bg-white p-8">
            <h3 class="mb-6 border-b border-stone-100 pb-2 font-serif text-xl font-black uppercase text-stone-900">
              {label}
            </h3>
            <div class="grid grid-cols-7 gap-px border border-stone-100 bg-stone-100">
              {["S", "M", "T", "W", "T", "F", "S"].map((day) => (
                <div class="bg-stone-50 py-2 text-center font-mono text-[10px] font-black uppercase text-stone-500">
                  {day}
                </div>
              ))}

              {Array.from({ length: firstDayOfWeek }).map(() => (
                <div class="h-10 bg-white" />
              ))}

              {daysInMonth.map((day) => {
                const calendarEvent = getCalendarEvent(day);
                const isVolunteerDay = Boolean(calendarEvent);
                const isCompanyEvent = calendarEvent?.type === "company";
                const eventLabel = calendarEvent ? getEventLabel(calendarEvent) : undefined;

                return (
                  <div
                    class:list={[
                      "relative flex h-10 items-center justify-center",
                      !isVolunteerDay && "bg-white",
                      isVolunteerDay && !isCompanyEvent && "bg-primary/6",
                      isCompanyEvent && "bg-accent/15",
                    ]}
                    title={isCompanyEvent ? eventLabel : undefined}
                    aria-label={eventLabel}
                  >
                    <span
                      class:list={[
                        "font-mono text-xs",
                        isVolunteerDay && !isCompanyEvent
                          ? "font-black text-primary-dark"
                          : isCompanyEvent
                          ? "font-black text-accent-dark"
                          : "text-stone-600",
                      ]}
                    >
                      {format(day, "d")}
                    </span>
                    {
                      isVolunteerDay && !isCompanyEvent && (
                        <div class="absolute inset-1 border border-primary-dark/40" />
                      )
                    }
                    {
                      isCompanyEvent && (
                        <div class="absolute inset-1 border border-accent-dark/60" />
                      )
                    }
                  </div>
                );
              })}

              {Array.from({
                length: (7 - ((daysInMonth.length + firstDayOfWeek) % 7)) % 7,
              }).map(() => (
                <div class="h-10 bg-white" />
              ))}
            </div>
          </div>
        );
      })
    }
  </div>
</div>
