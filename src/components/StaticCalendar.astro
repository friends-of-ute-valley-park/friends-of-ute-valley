---
import {
  eachDayOfInterval,
  endOfMonth,
  format,
  getDay,
  startOfMonth,
} from "date-fns";
import { isDateInList } from "../utils/date";

export interface Props {
  eventDates?: string[];
}

const { eventDates = [] } = Astro.props as Props;

type CalendarEventType = "public" | "company";

type CalendarEvent = {
  date: string;
  type: CalendarEventType;
  title: string;
  companyName?: string;
};

const seasonEvents: CalendarEvent[] = [
  { date: "2026-05-20", type: "public", title: "Public volunteer event" },
  { date: "2026-06-03", type: "public", title: "Public volunteer event" },
  { date: "2026-06-17", type: "public", title: "Public volunteer event" },
  { date: "2026-07-01", type: "public", title: "Public volunteer event" },
  { date: "2026-07-15", type: "public", title: "Public volunteer event" },
  { date: "2026-08-05", type: "public", title: "Public volunteer event" },
  { date: "2026-08-19", type: "public", title: "Public volunteer event" },
  { date: "2026-09-02", type: "public", title: "Public volunteer event" },
  {
    date: "2026-05-18",
    type: "company",
    title: "Company volunteer event",
    companyName: "Entegris",
  },
  {
    date: "2026-06-26",
    type: "company",
    title: "Company volunteer event",
    companyName: "Orthopedic Rehabilitation Associates",
  },
  {
    date: "2026-08-01",
    type: "company",
    title: "Company volunteer event",
    companyName: "Trail Sisters",
  },
];

const toLocalDate = (dateString: string) => {
  const [year, month, day] = dateString.split("-").map(Number);
  return new Date(year, month - 1, day);
};

const propEvents = eventDates.map((date) => ({
  date,
  type: "public" as const,
  title: "Public volunteer event",
}));
const calendarEvents = propEvents.length > 0 ? propEvents : seasonEvents;
const volunteerEventDates = calendarEvents.map((event) => toLocalDate(event.date));
const currentYear =
  calendarEvents.length > 0
    ? toLocalDate(calendarEvents[0].date).getFullYear()
    : new Date().getFullYear();
const allMonths = [
  { label: "April", monthIndex: 3 },
  { label: "May", monthIndex: 4 },
  { label: "June", monthIndex: 5 },
  { label: "July", monthIndex: 6 },
  { label: "August", monthIndex: 7 },
  { label: "September", monthIndex: 8 },
];

const eventMonthIndexes = volunteerEventDates.map((date) => date.getMonth());
const firstVisibleMonth =
  eventMonthIndexes.length > 0 ? Math.min(...eventMonthIndexes) : 3;
const lastVisibleMonth =
  eventMonthIndexes.length > 0 ? Math.max(...eventMonthIndexes) : 8;

const months = allMonths.filter(
  ({ monthIndex }) =>
    monthIndex >= firstVisibleMonth && monthIndex <= lastVisibleMonth,
);

const getDaysInMonth = (year: number, month: number) => {
  const start = startOfMonth(new Date(year, month));
  const end = endOfMonth(start);
  return eachDayOfInterval({ start, end });
};

const getCalendarEvent = (date: Date) =>
  calendarEvents.find((event) => isDateInList(date, [toLocalDate(event.date)]));

const getEventLabel = (event: CalendarEvent) =>
  event.companyName ? `${event.title}: ${event.companyName}` : event.title;
---

<div class="static-calendar">
  <div class="static-calendar__header">
    <div class="static-calendar__heading">
      <div class="static-calendar__eyebrow">
        <span></span>
        <span>Volunteer Calendar</span>
      </div>
      <h2>
        Posted <span>Workdays.</span>
      </h2>
    </div>
    <div class="static-calendar__intro">
      <p>
        Highlighted dates show public volunteer sessions and company community
        workdays. Company workdays are not open to public registration.
      </p>
      <div class="static-calendar__legend">
        <div>
          <span class="static-calendar__legend-swatch static-calendar__legend-swatch--public" aria-hidden="true"></span>
          <span>Public</span>
        </div>
        <div>
          <span class="static-calendar__legend-swatch static-calendar__legend-swatch--company" aria-hidden="true"></span>
          <span>Company</span>
        </div>
      </div>
    </div>
  </div>

  <div class="static-calendar__months">
    {
      months.map(({ label, monthIndex }) => {
        const daysInMonth = getDaysInMonth(currentYear, monthIndex);
        const firstDayOfWeek = getDay(daysInMonth[0]);

        return (
          <div class="static-calendar__month">
            <h3>
              {label}
            </h3>
            <div class="static-calendar__grid">
              {["S", "M", "T", "W", "T", "F", "S"].map((day) => (
                <div class="static-calendar__weekday">
                  {day}
                </div>
              ))}

              {Array.from({ length: firstDayOfWeek }).map(() => (
                <div class="static-calendar__day static-calendar__day--blank" />
              ))}

              {daysInMonth.map((day) => {
                const calendarEvent = getCalendarEvent(day);
                const isVolunteerDay = Boolean(calendarEvent);
                const isCompanyEvent = calendarEvent?.type === "company";
                const eventLabel = calendarEvent ? getEventLabel(calendarEvent) : undefined;

                return (
                  <div
                    class:list={[
                      "static-calendar__day",
                      !isVolunteerDay && "static-calendar__day--empty",
                      isVolunteerDay && !isCompanyEvent && "static-calendar__day--public",
                      isCompanyEvent && "static-calendar__day--company",
                    ]}
                    title={isCompanyEvent ? eventLabel : undefined}
                    aria-label={eventLabel}
                  >
                    <span
                      class:list={[
                        "static-calendar__day-number",
                        isVolunteerDay && !isCompanyEvent
                          ? "static-calendar__day-number--public"
                          : isCompanyEvent
                          ? "static-calendar__day-number--company"
                          : "static-calendar__day-number--empty",
                      ]}
                    >
                      {format(day, "d")}
                    </span>
                    {
                      isVolunteerDay && !isCompanyEvent && (
                        <div class="static-calendar__event-outline static-calendar__event-outline--public" />
                      )
                    }
                    {
                      isCompanyEvent && (
                        <div class="static-calendar__event-outline static-calendar__event-outline--company" />
                      )
                    }
                  </div>
                );
              })}

              {Array.from({
                length: (7 - ((daysInMonth.length + firstDayOfWeek) % 7)) % 7,
              }).map(() => (
                <div class="static-calendar__day static-calendar__day--blank" />
              ))}
            </div>
          </div>
        );
      })
    }
  </div>
</div>

<style>
  .static-calendar {
    width: min(100% - (var(--space-page-x) * 2), var(--container-wide));
    margin-inline: auto;
    padding-block: 3rem;
  }

  .static-calendar__header {
    display: grid;
    align-items: end;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .static-calendar__heading {
    display: grid;
    gap: 1rem;
  }

  .static-calendar__eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .static-calendar__eyebrow span:first-child {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--color-brand-strong);
  }

  .static-calendar__eyebrow span:last-child,
  .static-calendar__legend span:last-child,
  .static-calendar__weekday {
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .static-calendar__eyebrow span:last-child {
    color: var(--color-text-subtle);
  }

  .static-calendar__heading h2 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .static-calendar__heading h2 span {
    color: var(--color-brand-strong);
    font-style: italic;
  }

  .static-calendar__intro {
    max-width: 28rem;
  }

  .static-calendar__intro p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .static-calendar__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .static-calendar__legend div {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .static-calendar__legend-swatch {
    width: 0.75rem;
    height: 0.75rem;
  }

  .static-calendar__legend-swatch--public {
    border: 1px solid var(--color-brand-strong);
    background: color-mix(in oklab, var(--color-brand) 15%, transparent);
  }

  .static-calendar__legend-swatch--company {
    border: 1px solid var(--color-accent-strong);
    background: color-mix(in oklab, var(--color-accent) 25%, transparent);
  }

  .static-calendar__legend span:last-child {
    color: var(--color-text-muted);
  }

  .static-calendar__months {
    display: grid;
    gap: 1px;
    border: 1px solid var(--color-border);
    background: var(--color-border);
  }

  .static-calendar__month {
    background: var(--color-surface);
    padding: 2rem;
  }

  .static-calendar__month h3 {
    margin: 0 0 1.5rem;
    border-bottom: 1px solid var(--color-border-muted);
    padding-bottom: 0.5rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .static-calendar__grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--color-border-muted);
    background: var(--color-border-muted);
  }

  .static-calendar__weekday {
    background: var(--color-page);
    color: var(--color-text-subtle);
    padding-block: 0.5rem;
    text-align: center;
  }

  .static-calendar__day {
    position: relative;
    display: flex;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
  }

  .static-calendar__day--blank,
  .static-calendar__day--empty {
    background: var(--color-surface);
  }

  .static-calendar__day--public {
    background: color-mix(in oklab, var(--color-brand) 6%, transparent);
  }

  .static-calendar__day--company {
    background: color-mix(in oklab, var(--color-accent) 15%, transparent);
  }

  .static-calendar__day-number {
    font-family: var(--font-label);
    font-size: 0.75rem;
  }

  .static-calendar__day-number--empty {
    color: var(--color-text-muted);
  }

  .static-calendar__day-number--public,
  .static-calendar__day-number--company {
    font-weight: 900;
  }

  .static-calendar__day-number--public {
    color: var(--color-brand-strong);
  }

  .static-calendar__day-number--company {
    color: var(--color-accent-strong);
  }

  .static-calendar__event-outline {
    position: absolute;
    inset: 0.25rem;
    pointer-events: none;
  }

  .static-calendar__event-outline--public {
    border: 1px solid color-mix(in oklab, var(--color-brand-strong) 40%, transparent);
  }

  .static-calendar__event-outline--company {
    border: 1px solid color-mix(in oklab, var(--color-accent-strong) 60%, transparent);
  }

  @media (min-width: 48rem) {
    .static-calendar__header {
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.8fr);
    }

    .static-calendar__months {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 80rem) {
    .static-calendar__months {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
