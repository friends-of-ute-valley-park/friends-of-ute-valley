---
import { getCollection } from 'astro:content';
import InstagramIcon from '~icons/mdi/instagram';
import FacebookIcon from '~icons/mdi/facebook';
import GithubIcon from '~icons/mdi/github';
import { byPriorityAsc } from '@/utils/content';

interface Props {
  variant?: 'buttons' | 'inline';
}

const { variant = 'buttons' } = Astro.props as Props;
const isInline = variant === 'inline';
const Wrapper = isInline ? 'span' : 'div';

const iconComponents: Record<string, typeof FacebookIcon> = {
  facebook: FacebookIcon,
  instagram: InstagramIcon,
  github: GithubIcon,
};

const toneClasses: Record<string, string> = {
  facebook: 'social-links__link--brand',
  instagram: 'social-links__link--accent',
  github: 'social-links__link--neutral',
};

const socialLinks = (await getCollection('social-links'))
  .filter((entry) => !isInline || entry.data.showInline)
  .sort(byPriorityAsc);
---

<Wrapper class:list={['social-links', isInline ? 'social-links--inline' : 'social-links--buttons']}>
  {socialLinks.map((entry) => {
    const Icon = iconComponents[entry.data.icon];
    const tone = toneClasses[entry.data.icon] ?? '';
    return (
      <a
        href={entry.data.link}
        class:list={[
          'social-links__link',
          isInline ? 'social-links__link--inline' : 'social-links__link--button',
          !isInline && tone,
        ]}
        target={isInline ? undefined : '_blank'}
        rel={isInline ? undefined : 'noopener noreferrer nofollow'}
      >
        <span class="social-links__label">{entry.data.title}</span>
        <Icon class={isInline ? 'social-links__icon social-links__icon--inline' : 'social-links__icon'} aria-hidden="true" />
      </a>
    );
  })}
</Wrapper>

<style>
  .social-links {
    display: inline-flex;
    align-items: center;
  }

  .social-links--inline {
    gap: 0.5rem;
    margin-inline: 0.25rem;
    vertical-align: text-bottom;
  }

  .social-links--buttons {
    position: relative;
    gap: 1rem;
  }

  .social-links__link {
    color: inherit;
  }

  .social-links__link--inline {
    color: var(--color-brand-strong);
  }

  .social-links__link--inline:hover {
    color: var(--color-brand-hover);
  }

  .social-links__link--button {
    display: inline-flex;
    min-width: 2.5rem;
    min-height: 2.5rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-subtle);
    padding: 0.5rem;
    transition:
      border-color 200ms,
      color 200ms,
      transform 200ms;
  }

  .social-links__link--button:active {
    transform: scale(0.96);
  }

  .social-links__link--brand:hover {
    border-color: var(--color-brand);
    color: var(--color-brand);
  }

  .social-links__link--accent:hover {
    border-color: var(--color-accent-strong);
    color: var(--color-accent-strong);
  }

  .social-links__link--neutral:hover {
    border-color: var(--color-text-strong);
    color: var(--color-text-strong);
  }

  .social-links__label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  :global(.social-links__icon) {
    width: 1.25rem;
    height: 1.25rem;
  }

  :global(.social-links__icon--inline) {
    width: 1rem;
    height: 1rem;
  }
</style>
