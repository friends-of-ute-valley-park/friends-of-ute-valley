---
import { getCollection } from 'astro:content';
import InstagramIcon from '~icons/mdi/instagram';
import FacebookIcon from '~icons/mdi/facebook';
import GithubIcon from '~icons/mdi/github';
import { byPriorityAsc } from '@/utils/content';

interface Props {
  variant?: 'buttons' | 'inline';
}

const { variant = 'buttons' } = Astro.props as Props;
const isInline = variant === 'inline';
const Wrapper = isInline ? 'span' : 'div';

const iconComponents: Record<string, typeof FacebookIcon> = {
  facebook: FacebookIcon,
  instagram: InstagramIcon,
  github: GithubIcon,
};

const hoverStyles: Record<string, string> = {
  facebook: 'hover:text-primary hover:border-primary',
  instagram: 'hover:text-secondary hover:border-secondary',
  github: 'hover:text-stone-900 hover:border-stone-900',
};

const socialLinks = (await getCollection('social-links'))
  .filter((entry) => !isInline || entry.data.showInline)
  .sort(byPriorityAsc);
---

<Wrapper class:list={[isInline ? 'mx-1 inline-flex space-x-2' : 'relative flex space-x-4']}>
  {socialLinks.map((entry) => {
    const Icon = iconComponents[entry.data.icon];
    const hover = hoverStyles[entry.data.icon] ?? '';
    return (
      <a
        href={entry.data.link}
        class:list={[
          isInline
            ? 'text-primary-dark focus-within:ring-2 focus-within:ring-primary-light hover:text-primary-light focus:outline-hidden'
            : 'inline-flex min-h-10 min-w-10 items-center justify-center border border-stone-300 bg-white p-2 text-stone-500 transition-[border-color,color,transform] duration-200 active:scale-96',
          !isInline && hover,
        ]}
        target={isInline ? undefined : '_blank'}
        rel={isInline ? undefined : 'noopener noreferrer nofollow'}
      >
        <span class="sr-only">{entry.data.title}</span>
        <Icon class={isInline ? 'h-4 w-4' : 'h-5 w-5'} aria-hidden="true" />
      </a>
    );
  })}
</Wrapper>
