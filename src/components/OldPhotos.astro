---
import { Picture } from "astro:assets";

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/old-ute-valley-park-photos/old-ute-*.jpg",
  { eager: true },
);

const sorted = Object.entries(allImages)
  .map(([path, mod]) => {
    const match = path.match(/old-ute-(\d+)\.jpg$/);
    return { num: match ? parseInt(match[1]) : 0, image: mod.default };
  })
  .sort((a, b) => a.num - b.num);

const initialPhotos = sorted.slice(0, 6);
const morePhotos = sorted.slice(6);
---

<div class="historic-photos">
  <div class="eyebrow section-kicker">
    <span class="section-kicker__rule"></span>
    <span class="section-kicker__text">Park History</span>
  </div>

  <div class="grid feature-grid feature-grid--two-sm feature-grid--three">
    {
      initialPhotos.map(({ image, num }) => (
        <div class="item media-zoom-frame">
          <Picture
            src={image}
            alt={`Historic Ute Valley Park photo ${num}`}
            widths={[400, 600, 800]}
            formats={["avif", "webp"]}
            class="image media-cover media-zoom media-zoom--slow"
            loading="lazy"
          />
          <div class="matte media-matte" />
        </div>
      ))
    }
  </div>

  <div id="view-more-btn" class="more">
    <button
      class="button"
      data-toggle-photos
    >
      View More Photos
    </button>
  </div>

  <div id="more-photos" class="extra" hidden>
    <div class="grid feature-grid feature-grid--two-sm feature-grid--three">
      {
        morePhotos.map(({ image, num }) => (
          <div class="item media-zoom-frame">
            <Picture
              src={image}
              alt={`Historic Ute Valley Park photo ${num}`}
              widths={[400, 600, 800]}
              formats={["avif", "webp"]}
              class="image media-cover media-zoom media-zoom--slow"
              loading="lazy"
            />
            <div class="matte media-matte" />
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  const btn = document.querySelector("[data-toggle-photos]");
  const btnWrapper = document.getElementById("view-more-btn");
  const morePhotos = document.getElementById("more-photos");

  btn?.addEventListener("click", () => {
    morePhotos?.removeAttribute("hidden");
    btnWrapper?.remove();
  });
</script>

<style>
  .historic-photos {
    display: grid;
    gap: 3rem;
  }

  .historic-photos .eyebrow {
    margin-bottom: -1rem;
    --section-kicker-rule-color: var(--color-border);
  }

  .historic-photos .item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-surface);
  }

  .historic-photos .more {
    display: flex;
    justify-content: center;
    padding-top: 2rem;
  }

  .historic-photos .button {
    border: 2px solid var(--color-text-strong);
    background: transparent;
    color: var(--color-text-strong);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    transition:
      background-color 200ms,
      border-color 200ms,
      color 200ms,
      box-shadow 200ms,
      transform 200ms;
  }

  .historic-photos .button:hover {
    background: var(--color-text-strong);
    color: var(--color-text-inverse);
  }

  .historic-photos .button:active {
    transform: scale(0.96);
  }

  .historic-photos .extra {
    display: grid;
    gap: 3rem;
  }

  .historic-photos .extra[hidden] {
    display: none;
  }

</style>
