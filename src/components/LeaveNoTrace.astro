---
import { Picture } from "astro:assets";
import PlanAhead from "../assets/images/lnt/plan-ahead-and-prepare.jpg";
import TravelOnDurableSurfaces from "../assets/images/lnt/travel-on-durable-surfaces.jpg";
import DisposeOfWasteProperly from "../assets/images/lnt/dispose-of-waste-properly.jpg";
import LeaveWhatYouFind from "../assets/images/lnt/leave-what-you-find.jpg";
import RespectWildlife from "../assets/images/lnt/respect-wildlife.jpg";
import BeConsiderateOfOtherVisitors from "../assets/images/lnt/be-considerate-of-other-visitors.jpg";

const principles = [
  {
    id: "01",
    name: "Plan Ahead & Prepare",
    text: "A little preparation goes a long way! Check the forecast, plan your route, and review the <a class='text-link' href='/rules/'>park rules</a> before heading out.",
    image: PlanAhead,
    altText: "A lone tree in Ute Valley Park",
  },
  {
    id: "02",
    name: "Travel on Durable Surfaces",
    text: "<a class='text-link' href='/leavenotrace/travel-on-durable-surfaces/'>Stay on the trail</a> to protect the landscape around you. Stick to marked paths and respect Natural Preservation Area closures so plants and soil can thrive.",
    image: TravelOnDurableSurfaces,
    altText: "Ute Valley Park trail",
  },
  {
    id: "03",
    name: "Dispose of Waste Properly",
    text: "Follow a Pack-In, Pack-Out approach — carry out everything you carry in, including <a class='text-link' href='/leavenotrace/dogs/'>pet waste</a>. This keeps Ute Valley Park looking (and smelling) bea-UTE-iful!",
    image: DisposeOfWasteProperly,
    altText: "Rubbish in the dirt",
  },
  {
    id: "04",
    name: "Leave What You Find",
    text: "Take only photos, leave only footprints! <a class='text-link' href='/leavenotrace/leave-what-you-find/'>Snap all the pictures you like</a>, but please leave rocks, plants, and other natural treasures for the next visitor to enjoy.",
    image: LeaveWhatYouFind,
    altText: "Flowers",
  },
  {
    id: "05",
    name: "Respect Wildlife",
    text: "Observe all wildlife from a safe distance and never feed them. Keep dogs on leash to protect wildlife habitat — learn more about our <a class='text-link' href='/leavenotrace/respect-wildlife/'>leash guidelines</a>.",
    image: RespectWildlife,
    altText: "A deer in Ute Valley Park",
  },
  {
    id: "06",
    name: "Be Considerate of Other Visitors",
    text: "A friendly hello goes a long way! Yield to other trail users, keep noise levels down, and share the trail so everyone can have a great time in the park.",
    image: BeConsiderateOfOtherVisitors,
    altText: "Hikers walking on snow in the park",
  },
];

import lntLogo from "../assets/images/logos/leave-no-trace.png";
---

<section class="lnt-principles">
  <div class="inner">
    <div class="layout">
      <!-- Left Column: About Leave No Trace -->
      <div class="intro">
        <div class="intro-sticky">
          <div class="intro-copy section-heading">
            <h2 class="title section-heading__title">
              Leave <br /> No <br />
              <span>Trace.</span>
            </h2>

            <p class="summary section-heading__copy">
              Ute Valley Park is a treasured urban wildland. Please help keep
              the park safe and clean for all visitors by following the Seven
              Principles.
            </p>
          </div>

          <div class="partner">
            <div class="logo-card">
              <a
                href="https://www.lnt.org"
                target="_blank"
                rel="noopener noreferrer nofollow"
              >
                <Picture
                  src={lntLogo}
                  alt="Leave No Trace Official Logo"
                  width="200"
                  class="logo"
                />
              </a>
              <div class="certification">
                <span>Certified Partner</span>
              </div>
            </div>

            <a
              href="/rules/"
              class="button button--brand rules-link"
            >
              View Park Rules
            </a>
          </div>
        </div>
      </div>

      <!-- Principles Column -->
      <div class="list-wrap">
        <div class="list">
          {
            principles.map((principle) => (
              <div class="card media-zoom-parent media-zoom-parent--expand">
                <div class="card-head">
                  <div class="number-row">
                    <span>
                      {principle.id}
                    </span>
                    <div />
                  </div>
                  <h3>
                    {principle.name}
                  </h3>
                </div>

                <div class="media media-frame">
                  <Picture
                    class="image media-cover media-zoom"
                    src={principle.image}
                    alt={principle.altText}
                    width={600}
                  />
                </div>

                <p class="copy" set:html={principle.text} />

                <div class="principle-label">
                  <span>
                    Principle {principle.id}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .lnt-principles {
    overflow: hidden;
    border-top: 1px solid var(--color-border);
    background: var(--color-page);
  }

  .lnt-principles .inner {
    max-width: var(--container-wide);
    margin-inline: auto;
  }

  .lnt-principles .layout {
    display: grid;
  }

  .lnt-principles .intro {
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
    padding: clamp(2rem, 5vw, 4rem);
  }

  .lnt-principles .intro-sticky {
    display: grid;
    gap: 3rem;
  }

  .lnt-principles .intro-copy {
    --section-heading-gap: 1.5rem;
    --section-heading-title-size: clamp(3rem, 8vw, 3.75rem);
    --section-heading-accent-style: normal;
    --section-heading-copy-margin: 0;
  }

  .lnt-principles .certification span,
  .lnt-principles .principle-label span {
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .lnt-principles .partner {
    display: grid;
    gap: 2rem;
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
  }

  .lnt-principles .logo-card {
    position: relative;
    border: 2px solid var(--color-brand-strong);
    background: var(--color-surface);
    padding: 2rem;
    box-shadow: 0 1px 2px rgb(0 0 0 / 5%);
    transition: box-shadow 500ms;
  }

  .lnt-principles .logo-card:hover {
    box-shadow: var(--shadow-accent-md);
  }

  :global(.lnt-principles .logo) {
    width: 100%;
    max-width: 10rem;
    height: auto;
    margin-inline: auto;
  }

  .lnt-principles .certification {
    margin-top: 1.5rem;
    text-align: center;
  }

  .lnt-principles .certification span,
  .lnt-principles .principle-label span {
    color: var(--color-brand-strong);
  }

  .lnt-principles .rules-link {
    display: block;
    text-align: center;
  }

  .lnt-principles .list {
    display: grid;
    gap: 1px;
    background: var(--color-border);
  }

  .lnt-principles .card {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    background: var(--color-page);
    padding: clamp(2rem, 4vw, 3rem);
    transition: background-color var(--duration-fast);
  }

  .lnt-principles .card:hover {
    background: var(--color-surface);
  }

  .lnt-principles .card-head {
    display: grid;
    gap: 1rem;
  }

  .lnt-principles .number-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .lnt-principles .number-row span {
    color: var(--color-accent-strong);
    font-family: var(--font-label);
    font-size: 2.25rem;
    font-weight: 900;
    transition: color var(--duration-fast);
  }

  .lnt-principles .card:hover .number-row span {
    color: var(--color-accent);
  }

  .lnt-principles .number-row div {
    width: 3rem;
    height: 1px;
    margin-top: 1.25rem;
    background: var(--color-border-muted);
    transition: background-color var(--duration-fast);
  }

  .lnt-principles .card:hover .number-row div {
    background: var(--color-brand-strong);
  }

  .lnt-principles .card h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
    transition: color var(--duration-fast);
  }

  .lnt-principles .card:hover h3 {
    color: var(--color-brand-strong);
  }

  .lnt-principles .media {
    aspect-ratio: 16 / 10;
    --media-frame-border-color: var(--color-border-muted);
  }

  .lnt-principles .copy {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .lnt-principles .principle-label {
    margin-top: auto;
    border-top: 1px solid var(--color-border-muted);
    padding-top: 1.5rem;
  }

  .lnt-principles .principle-label span {
    font-size: 0.5625rem;
  }

  @media (min-width: 48rem) {
    .lnt-principles .list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .lnt-principles .layout {
      grid-template-columns: 4fr 8fr;
    }

    .lnt-principles .intro {
      border-right: 1px solid var(--color-border);
      border-bottom: 0;
    }

    .lnt-principles .intro-sticky {
      position: sticky;
      top: 6rem;
    }
  }
</style>
