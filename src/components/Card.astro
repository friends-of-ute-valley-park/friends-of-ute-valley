---
export interface Props {
  title: string;
  image: ImageMetadata;
  previewText: string;
  href: string | undefined;
  publishedOn: Date;
  canBeWide?: boolean | undefined;
}

const { title, image, publishedOn, href, previewText } = Astro.props as Props;

import { Image } from "astro:assets";
import { formatShortMonthDayYear, formatShortMonthYear } from "@/utils/date";
---

<a href={"/news/" + href} class="news-teaser">
  <article class="media media-frame media-zoom-frame">
    <Image
      src={image}
      width={800}
      height={500}
      quality="80"
      alt={title}
      class="image media-cover media-zoom media-zoom--slow"
    />

    <div class="matte media-matte"></div>

    <div class="date meta-label">
      {
        formatShortMonthDayYear(publishedOn)
      }
    </div>

    <div class="action">
      <span class="meta-label">Read More →</span>
    </div>
  </article>

  <div class="body">
    <div class="meta">
      <span></span>
      <span class="meta-label">
        {formatShortMonthYear(publishedOn)}
      </span>
    </div>
    <h3 class="title card-title">
      {title}
    </h3>
    <p class="preview">
      {previewText}
    </p>
  </div>
</a>

<style>
  .news-teaser {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .news-teaser .media {
    position: relative;
    aspect-ratio: 16 / 10;
    transition: border-color var(--duration-fast);
  }

  .news-teaser:hover .media {
    border-color: var(--color-brand-strong);
  }

  .news-teaser .matte {
    --media-matte-border: 1rem solid color-mix(in oklab, var(--color-surface) 10%, transparent);
  }

  .news-teaser .date {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-brand-strong);
    color: var(--color-text-inverse);
    padding: 0.25rem 0.5rem;
    font-variant-numeric: tabular-nums;
  }

  .news-teaser .action {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    border: 1px solid var(--color-border-muted);
    background: color-mix(in oklab, var(--color-surface) 90%, transparent);
    padding: 0.25rem 0.75rem;
    opacity: 0;
    transition: opacity 500ms;
  }

  .news-teaser:hover .action {
    opacity: 1;
  }

  .news-teaser .action span {
    color: var(--color-brand-strong);
  }

  .news-teaser .body {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .news-teaser .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-subtle);
    transition: color var(--duration-fast);
  }

  .news-teaser .meta span:first-child {
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: var(--color-border);
    transition: background-color var(--duration-fast);
  }

  .news-teaser:hover .meta {
    color: var(--color-brand-strong);
  }

  .news-teaser:hover .meta span:first-child {
    background: var(--color-brand-strong);
  }

  .news-teaser:hover .title {
    color: var(--color-brand-strong);
  }

  .news-teaser .preview {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
    text-wrap: pretty;
  }
</style>
