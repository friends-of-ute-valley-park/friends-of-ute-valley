---
import SocialLinks from "./SocialLinks.astro";

const footerItems = [
  { name: "About", link: "/about/" },
  { name: "News", link: "/news/" },
  { name: "Volunteer", link: "/volunteer/" },
  { name: "FAQ", link: "/faq/" },
  { name: "Privacy Policy", link: "/privacy/" },
  { name: "Donate", link: "/donate/" },
  { name: "Park Regulations", link: "/rules/" },
  { name: "Brand Assets", link: "/assets/" },
];
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__panel">
      <!-- Branding & Legal -->
      <div class="site-footer__brand">
        <div class="site-footer__brand-stack">
          <div>
            <h2 class="site-footer__title">
              Friends of <br />
              <span>Ute Valley Park.</span>
            </h2>
            <p class="site-footer__summary">
              Established for the preservation, maintenance, and community
              education of the 550-acre Ute Valley urban wildland.
            </p>
          </div>

          <div class="site-footer__social">
            <SocialLinks />
          </div>

          <div class="site-footer__legal">
            <p>
              Fiscally sponsored fund of the Trails and Open Space Coalition
              (501(c)(3)). Contributions are tax-deductible as permitted by law.
            </p>
            <p class="site-footer__copyright">
              © {currentYear} Friends of Ute Valley Park — ALL RIGHTS RESERVED.
            </p>
          </div>
        </div>
      </div>

      <!-- Navigation Links -->
      <div class="site-footer__nav">
        {
          footerItems.map((item) => (
            <a href={item.link} class="site-footer__nav-link">
              <span>{item.name}</span>
              <span aria-hidden="true">→</span>
            </a>
          ))
        }
        <a href="/sitemap-index.xml" class="site-footer__nav-link site-footer__nav-link--wide">
          <span>Sitemap</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <!-- Coordinate Detail -->
    <div class="site-footer__coordinates">
      <span>38.9189° N, 104.8558° W</span>
      <span>Colorado Springs, CO</span>
      <span>Urban Open Space</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-page);
    padding-block: 5rem 3rem;
  }

  .site-footer__inner {
    width: min(100% - (var(--space-page-x) * 2), var(--container-wide));
    margin-inline: auto;
  }

  .site-footer__panel {
    display: grid;
    gap: 3rem;
    border: 1px solid var(--color-border);
  }

  .site-footer__brand {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: clamp(2rem, 5vw, 3rem);
  }

  .site-footer__brand-stack {
    display: grid;
    gap: 2rem;
  }

  .site-footer__title {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .site-footer__title span {
    color: var(--color-brand);
  }

  .site-footer__summary {
    max-width: 24rem;
    margin: 1.5rem 0 0;
    color: var(--color-text-subtle);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .site-footer__social {
    border-top: 1px solid var(--color-border-muted);
    padding-top: 2rem;
  }

  .site-footer__legal {
    display: grid;
    gap: 1rem;
  }

  .site-footer__legal p {
    margin: 0;
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: var(--text-label);
    line-height: var(--leading-tight);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .site-footer__legal .site-footer__copyright {
    color: var(--color-brand);
    font-weight: 900;
  }

  .site-footer__nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .site-footer__nav-link {
    display: flex;
    min-height: 8rem;
    flex-direction: column;
    justify-content: space-between;
    border-color: var(--color-border);
    border-style: solid;
    border-width: 0 1px 1px 0;
    padding: 2rem;
    text-decoration: none;
    transition: background-color 200ms;
  }

  .site-footer__nav-link:hover {
    background: var(--color-surface);
  }

  .site-footer__nav-link span:first-child {
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    transition: color 200ms;
  }

  .site-footer__nav-link span:last-child {
    align-self: end;
    color: var(--color-brand);
    opacity: 0;
    transition: opacity 200ms;
  }

  .site-footer__nav-link:hover span:first-child {
    color: var(--color-brand);
  }

  .site-footer__nav-link:hover span:last-child {
    opacity: 1;
  }

  .site-footer__nav-link--wide {
    grid-column: span 2;
  }

  .site-footer__nav-link--wide:hover span:first-child,
  .site-footer__nav-link--wide span:last-child {
    color: var(--color-accent-strong);
  }

  .site-footer__coordinates {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .site-footer__coordinates span:first-child,
  .site-footer__coordinates span:last-child {
    color: var(--color-brand);
  }

  .site-footer__coordinates span:nth-child(2) {
    display: none;
  }

  @media (min-width: 48rem) {
    .site-footer__nav {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .site-footer__nav-link--wide {
      grid-column: span 1;
    }

    .site-footer__coordinates {
      flex-direction: row;
      justify-content: space-between;
    }

    .site-footer__coordinates span:nth-child(2) {
      display: block;
      border-inline: 1px solid var(--color-border-muted);
      padding-inline: 2rem;
    }
  }

  @media (min-width: 64rem) {
    .site-footer__panel {
      grid-template-columns: 5fr 7fr;
      gap: 0;
    }

    .site-footer__brand {
      border-right: 1px solid var(--color-border);
      border-bottom: 0;
    }
  }
</style>
