---
import Layout from "@layouts/Layout.astro";

import { Picture } from "astro:assets";
import heroImage from "../assets/images/ute-valley-park-biker.jpg";
import DogImage from "../assets/images/dog.jpg";
import uteValleyParkMap from "../assets/images/maps/ute-valley-park-map-full.jpg";

import LeaveNoTrace from "@components/LeaveNoTrace.astro";
import { getSortedTrailheads } from "@/utils/content";
const sortedTrailheads = await getSortedTrailheads();
---

<Layout
  title="Visit"
  description="Plan your visit to Ute Valley Park with trailhead locations, map access, park hours, and trail information."
>
  <main class="page visit-page">
    <!-- Technical Hero Section -->
    <section class="visit-hero">
      <div class="visit-hero__layout">
        <!-- Identity Column -->
        <div class="visit-hero__identity">
          <div class="visit-hero__stack">
            <div class="page-eyebrow">
              <span>
                Getting Here
              </span>
            </div>

            <h1 class="page-title">
              Visit Ute<br /> Valley <br />
              <span>Park.</span>
            </h1>

            <p>
              Ute Valley Park is nestled between Centennial Blvd, Vindicator Dr
              and I-25 in Colorado Springs. Access is provided via five primary
              parking areas.
            </p>

            <div class="visit-hero__facts">
              <div>
                <p>
                  Park Coordinates
                </p>
                <p>
                  38.9189° N, 104.8558° W
                </p>
              </div>
              <div>
                <p>
                  Elevation
                </p>
                <p>
                  6,400'-6,800'
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Visual Context Column -->
        <div class="visit-hero__media">
          <Picture
            src={heroImage}
            formats={["avif", "webp"]}
            alt="Biker in Ute Valley"
            width="1200"
            height="1200"
            class="visit-hero__image"
          />
          <div class="visit-hero__matte"></div>
        </div>
      </div>
    </section>

    <!-- Map & Entry Points -->
    <section class="article-layout content-defer">
      <div class="article-layout__inner">
        <div class="visit-map">
          <!-- Trailheads -->
          <div class="visit-map__trailheads">
            <div class="visit-section-heading">
              <h2>
                Where to <span>Park.</span>
              </h2>
              <p>
                Find your trailhead and get directions.
              </p>
            </div>

            <div class="trailhead-list">
              {
                sortedTrailheads.map((trailhead) => (
                  <a
                    href={`/trailheads/${trailhead.id}/`}
                    class="trailhead-list__item"
                  >
                    <div>
                      <div class="trailhead-list__title">
                        <span>
                          [{trailhead.data.id.toString().padStart(2, "0")}]
                        </span>
                        <h3>
                          {trailhead.data.name}
                        </h3>
                      </div>
                      <p>
                        {trailhead.data.description}
                      </p>
                    </div>
                    <span>
                      →
                    </span>
                  </a>
                ))
              }
            </div>
          </div>

          <!-- Cartographic Context -->
          <div class="visit-map__context">
            <div class="visit-map__sticky">
              <div class="article-photo-card">
                <a
                  href="/images/maps/ute-valley-park-map-full.jpg"
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                >
                  <Picture
                    src={uteValleyParkMap}
                    formats={["avif", "webp"]}
                    alt="Map of Ute Valley Park"
                    width="1200"
                    height="900"
                    class="visit-map__image"
                  />
                  <div class="article-photo-card__meta">
                    <span>Trail Map</span>
                    <span>View Fullsize PDF</span>
                  </div>
                </a>
              </div>
              <div class="visit-fact-grid">
                <div>
                  <p>
                    Park Hours
                  </p>
                  <p>
                    5:00 AM — 9:00 PM Winter
                  </p>
                  <p>
                    5:00 AM — 10:00 PM Summer
                  </p>
                </div>
                <div>
                  <p>
                    Entry Fee
                  </p>
                  <p>
                    NO CHARGE
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Park Rules -->
    <section class="visit-rules content-defer">
      <!-- Background technical markers -->
      <div class="visit-rules__marker"></div>

      <div class="visit-rules__inner">
        <div class="visit-rules__layout">
          <div class="visit-rules__copy section-heading section-heading--inverse">
            <div class="visit-rules__eyebrow section-kicker section-kicker--wide section-kicker--accent section-kicker--inverse">
              <span class="section-kicker__rule"></span>
              <span class="section-kicker__text">
                Rules & Etiquette
              </span>
            </div>
            <h2 class="section-heading__title">
              Park <br />
              <span>Rules.</span>
            </h2>
            <p class="section-heading__copy">
              To maintain the ecological integrity of this urban wildland, all
              visitors must adhere to municipal park codes and stewardship
              guidelines.
            </p>
            <a
              href="/rules/"
              class="visit-rules__link"
            >
              Review Full Rules
            </a>
          </div>

          <div>
            <div class="visit-rules__media">
              <Picture
                src={DogImage}
                formats={["avif", "webp"]}
                alt="Dog in park"
                width="800"
                height="450"
                class="visit-rules__image"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Trails -->
    <section class="page-section content-defer">
      <div class="page-section__inner">
        <div class="visit-section-heading visit-section-heading--spaced">
          <h2>
            Our <span>Trails.</span>
          </h2>
          <p>
            Ute Valley Park offers trails for every skill level, from easy
            strolls to technical challenges.
          </p>
        </div>

        <div class="trail-grid">
          {
            [
              {
                name: "BeaUTEiful Loop",
                desc: "Ridge top views of Pikes Peak, Black Forest and Rockrimmon as well as meandering through dense forest and rocky outcrops.",
              },
              {
                name: "Rattlesnake Ridge",
                desc: "Breathtaking views on a razor ridge. Extremely technical, sharp, rocky trail. recommended for experienced hikers and bikers only.",
              },
              {
                name: "High Arches loop",
                desc: "Quick loop near Vindicator Parking Lot. Winding valley of an old ranch leading to a natural sandstone arch.",
              },
              {
                name: "Black and Blue Loop",
                desc: "Challenging terrain featuring sharp rock gardens, steep grades, and a massive bridge, mine tailings, and a cave! Very technical.",
              },
            ].map((trail, i) => (
              <div class="trail-card">
                <div>
                  <span>
                    Trail {String(i + 1).padStart(2, "0")}
                  </span>
                  <h3>
                    {trail.name}
                  </h3>
                  <p>
                    {trail.desc}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div class="content-defer">
      <LeaveNoTrace />
    </div>
  </main>
</Layout>

<style>
  .visit-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .visit-hero__layout,
  .visit-map {
    display: grid;
  }

  .visit-hero__identity {
    padding: clamp(3rem, 8vw, 8rem) var(--space-page-x) clamp(5rem, 10vw, 10rem);
  }

  .visit-hero__stack {
    display: grid;
    gap: 2rem;
  }

  .visit-hero__stack > p {
    max-width: 36rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .visit-hero__facts {
    display: flex;
    flex-wrap: wrap;
    gap: 3rem;
    padding-top: 2rem;
  }

  .visit-hero__facts p {
    margin: 0;
    font-family: var(--font-label);
    text-transform: uppercase;
  }

  .visit-hero__facts p:first-child {
    color: var(--color-text-subtle);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
  }

  .visit-hero__facts p:last-child {
    color: var(--color-brand-strong);
    font-size: var(--text-body-small);
    font-weight: 900;
  }

  .visit-hero__media {
    position: relative;
    overflow: hidden;
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
  }

  :global(.visit-hero__image) {
    width: 100%;
    height: 100%;
    min-height: 28rem;
    object-fit: cover;
    transform: scale(1.05);
    transition: transform 1000ms;
  }

  .visit-hero__media:hover :global(.visit-hero__image) {
    transform: scale(1);
  }

  .visit-hero__matte {
    position: absolute;
    inset: 0;
    border: 1.5rem solid color-mix(in oklab, var(--color-surface) 20%, transparent);
    pointer-events: none;
  }

  .visit-map__trailheads {
    padding: var(--space-section) var(--space-page-x);
  }

  .visit-section-heading h2 {
    margin: 0 0 1rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 5vw, 3.75rem);
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .visit-section-heading h2 span {
    color: var(--color-brand-strong);
    font-style: italic;
  }

  .visit-section-heading p {
    max-width: 42rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .visit-section-heading--spaced {
    margin-bottom: 4rem;
  }

  .trailhead-list {
    border-top: 1px solid var(--color-border-muted);
  }

  .trailhead-list__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-border-muted);
    color: inherit;
    padding: 1.5rem 0.5rem;
    text-decoration: none;
    transition: background-color 200ms;
  }

  .trailhead-list__item:hover {
    background: var(--color-surface-muted);
  }

  .trailhead-list__title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .trailhead-list__title span {
    color: var(--color-accent-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
  }

  .trailhead-list h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: var(--text-body-large);
    font-weight: 700;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-color: var(--color-brand-strong);
    text-decoration-thickness: 4px;
    text-underline-offset: 0.125rem;
    text-transform: uppercase;
    transition: color 200ms;
  }

  .trailhead-list__item:hover h3,
  .trailhead-list__item:hover > span {
    color: var(--color-brand-strong);
  }

  .trailhead-list p {
    max-width: 24rem;
    margin: 0.25rem 0 0 2rem;
    color: var(--color-text-subtle);
    font-size: 0.75rem;
    font-weight: 500;
  }

  .trailhead-list__item > span {
    color: var(--color-accent-strong);
    transition: color 200ms;
  }

  .visit-map__context {
    background: var(--color-page);
    padding: clamp(2rem, 4vw, 3rem);
  }

  .visit-map__sticky {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 64rem) {
    .visit-map__sticky {
      position: sticky;
      top: 6rem;
    }
  }

  :global(.visit-map__image) {
    width: 100%;
    height: auto;
    transition: transform 700ms;
  }

  .visit-fact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .visit-fact-grid > div {
    border: 1px solid var(--color-border-muted);
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
    padding: 1.5rem;
  }

  .visit-fact-grid p {
    margin: 0;
    font-family: var(--font-label);
    text-transform: uppercase;
  }

  .visit-fact-grid p:first-child {
    margin-bottom: 0.5rem;
    color: var(--color-text-subtle);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
  }

  .visit-fact-grid p:not(:first-child) {
    color: var(--color-text-strong);
    font-size: var(--text-body-small);
    font-weight: 900;
  }

  .visit-rules {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-inverse);
    color: var(--color-text-inverse);
    padding-block: var(--space-section);
  }

  .visit-rules__marker {
    position: absolute;
    top: 0;
    right: 0;
    display: none;
    width: 33%;
    height: 100%;
    border-left: 1px solid color-mix(in oklab, var(--color-text-inverse) 5%, transparent);
    pointer-events: none;
  }

  .visit-rules__inner {
    position: relative;
    z-index: 1;
    width: min(100% - (var(--space-page-x) * 2), var(--container-wide));
    margin-inline: auto;
  }

  .visit-rules__layout {
    display: grid;
    align-items: center;
    gap: 4rem;
  }

  .visit-rules__copy {
    --section-heading-gap: 2rem;
    --section-heading-copy-margin: 0;
  }

  .visit-rules__link {
    display: inline-block;
    width: fit-content;
    border: 2px solid var(--color-accent);
    color: var(--color-accent);
    padding: 1rem 2rem;
    font-family: var(--font-label);
    font-size: var(--text-body-small);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 200ms,
      color 200ms,
      transform 200ms;
  }

  .visit-rules__link:hover {
    background: var(--color-accent);
    color: var(--color-surface-inverse);
  }

  .visit-rules__link:active {
    transform: scale(0.96);
  }

  .visit-rules__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-text-inverse) 10%, transparent);
    background: var(--color-surface-inverse-muted);
  }

  :global(.visit-rules__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    transition: opacity 1000ms;
  }

  .visit-rules__media:hover :global(.visit-rules__image) {
    opacity: 1;
  }

  .trail-grid {
    display: grid;
    gap: 1px;
    border: 1px solid var(--color-border);
    background: var(--color-border);
  }

  .trail-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--color-surface);
    padding: 2rem;
    transition: background-color 200ms;
  }

  .trail-card:hover {
    background: var(--color-page);
  }

  .trail-card > div {
    display: grid;
    gap: 1rem;
  }

  .trail-card span {
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    transition: color 200ms;
  }

  .trail-card:hover span {
    color: var(--color-brand-strong);
  }

  .trail-card h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .trail-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  @media (min-width: 48rem) {
    .trail-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .visit-hero__layout {
      grid-template-columns: 7fr 5fr;
    }

    .visit-hero__identity {
      border-right: 1px solid var(--color-border);
      padding-inline: var(--space-page-x) 3rem;
    }

    .visit-map {
      grid-template-columns: 5fr 7fr;
    }

    .visit-map__trailheads {
      border-right: 1px solid var(--color-border);
      padding-inline: var(--space-page-x) 3rem;
    }

    .visit-rules__marker {
      display: block;
    }

    .visit-rules__layout {
      grid-template-columns: 5fr 7fr;
    }

    .trail-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
