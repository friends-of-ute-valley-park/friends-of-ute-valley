---
import Layout from "@layouts/Layout.astro";

import { Picture } from "astro:assets";
import heroImage from "../assets/images/ute-valley-park-biker.jpg";
import DogImage from "../assets/images/dog.jpg";

import LeaveNoTrace from "@components/LeaveNoTrace.astro";
import VisitTrailMap from "@components/VisitTrailMap.vue";
import { getSortedTrailheads } from "@/utils/content";
import type { TrailheadMapPoint } from "@/utils/trailheadHover";
const sortedTrailheads = await getSortedTrailheads();
const mapTrailheads: TrailheadMapPoint[] = sortedTrailheads.map((trailhead) => ({
  id: String(trailhead.id),
  name: trailhead.data.name,
  description: trailhead.data.description,
  coordinates: [trailhead.data.longitude, trailhead.data.latitude] as [number, number],
  url: `/trailheads/${trailhead.id}/`,
}));
---

<Layout
  title="Visit"
  description="Plan your visit to Ute Valley Park with trailhead locations, map access, park hours, and trail information."
>
  <main class="page visit-page">
    <!-- Visit Hero Section -->
    <section class="visit-hero">
      <div class="layout">
        <!-- Identity Column -->
        <div class="identity">
          <div class="stack">
            <div class="page-eyebrow">
              <span>
                Getting Here
              </span>
            </div>

            <h1 class="page-title">
              Visit Ute<br /> Valley <br />
              <span>Park.</span>
            </h1>

            <p>
              Ute Valley Park is nestled between Centennial Blvd, Vindicator Dr
              and I-25 in Colorado Springs. Access is provided via five primary
              parking areas.
            </p>

            <div class="facts">
              <div>
                <p>
                  Park Coordinates
                </p>
                <p>
                  38.9189° N, 104.8558° W
                </p>
              </div>
              <div>
                <p>
                  Elevation
                </p>
                <p>
                  6,400'-6,800'
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Visual Context Column -->
        <div class="media media-zoom-frame">
          <Picture
            src={heroImage}
            formats={["avif", "webp"]}
            alt="Biker in Ute Valley"
            width="1200"
            height="1200"
            class="image media-cover media-zoom media-zoom--slow"
          />
          <div class="matte media-matte"></div>
        </div>
      </div>
    </section>

    <!-- Map & Entry Points -->
    <section class="article-layout content-defer">
      <div class="article-layout__inner">
        <div class="visit-map">
          <!-- Trailheads -->
          <div class="trailheads">
            <div class="visit-section-heading section-heading">
              <h2 class="section-heading__title">
                Where to <span>Park.</span>
              </h2>
              <p class="section-heading__copy">
                Find your trailhead and get directions.
              </p>
            </div>

            <div class="trailhead-list">
              {
                sortedTrailheads.map((trailhead) => (
                  <a
                    href={`/trailheads/${trailhead.id}/`}
                    class="item"
                    data-trailhead-id={String(trailhead.id)}
                  >
                    <div>
                      <div class="title">
                        <span>
                          [{trailhead.data.id.toString().padStart(2, "0")}]
                        </span>
                        <h3>
                          {trailhead.data.name}
                        </h3>
                      </div>
                      <p>
                        {trailhead.data.description}
                      </p>
                    </div>
                    <span>
                      →
                    </span>
                  </a>
                ))
              }
            </div>
          </div>

          <!-- Cartographic Context -->
          <div class="context">
            <div class="sticky">
              <VisitTrailMap trailheads={mapTrailheads} client:visible />
              <a
                class="static-map-link"
                href="/images/maps/ute-valley-park-map-full.jpg"
                target="_blank"
                rel="noopener noreferrer nofollow"
              >
                <span>Official Park Map</span>
                <span>Open Full Size</span>
              </a>
              <div class="visit-fact-grid">
                <div>
                  <p>
                    Park Hours
                  </p>
                  <p>
                    5:00 AM — 9:00 PM Winter
                  </p>
                  <p>
                    5:00 AM — 10:00 PM Summer
                  </p>
                </div>
                <div>
                  <p>
                    Entry Fee
                  </p>
                  <p>
                    NO CHARGE
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Park Rules -->
    <section class="visit-rules content-defer">
      <!-- Background map markers -->
      <div class="marker"></div>

      <div class="inner l-container">
        <div class="layout">
          <div class="copy section-heading section-heading--inverse">
            <div class="eyebrow section-kicker section-kicker--wide section-kicker--accent section-kicker--inverse">
              <span class="section-kicker__rule"></span>
              <span class="section-kicker__text">
                Rules & Etiquette
              </span>
            </div>
            <h2 class="section-heading__title">
              Park <br />
              <span>Rules.</span>
            </h2>
            <p class="section-heading__copy">
              To maintain the ecological integrity of this urban wildland, all
              visitors are expected to follow municipal park codes and stewardship
              guidelines.
            </p>
            <a
              href="/rules/"
              class="link"
            >
              Review Full Rules
            </a>
          </div>

          <div>
            <div class="media">
              <Picture
                src={DogImage}
                formats={["avif", "webp"]}
                alt="Dog in park"
                width="800"
                height="450"
                class="image media-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Trails -->
    <section class="page-section content-defer">
      <div class="page-section__inner">
        <div class="visit-section-heading visit-section-heading--spaced section-heading">
          <h2 class="section-heading__title">
            Our <span>Trails.</span>
          </h2>
          <p class="section-heading__copy">
            Ute Valley Park offers trails for every skill level, from easy
            strolls to technical challenges.
          </p>
        </div>

        <div class="trail-grid">
          {
            [
              {
                name: "BeaUTEiful Loop",
                desc: "Ridge top views of Pikes Peak, Black Forest and Rockrimmon as well as meandering through dense forest and rocky outcrops.",
              },
              {
                name: "Rattlesnake Ridge",
                desc: "Breathtaking views on a razor ridge. Extremely technical, sharp, rocky trail. recommended for experienced hikers and bikers only.",
              },
              {
                name: "High Arches loop",
                desc: "Quick loop near Vindicator Parking Lot. Winding valley of an old ranch leading to a natural sandstone arch.",
              },
              {
                name: "Black and Blue Loop",
                desc: "Challenging terrain featuring sharp rock gardens, steep grades, and a massive bridge, mine tailings, and a cave! Very technical.",
              },
            ].map((trail, i) => (
              <div class="trail-card">
                <div>
                  <span>
                    Trail {String(i + 1).padStart(2, "0")}
                  </span>
                  <h3>
                    {trail.name}
                  </h3>
                  <p>
                    {trail.desc}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div class="content-defer">
      <LeaveNoTrace />
    </div>
  </main>
</Layout>

<script>
  import {
    dispatchTrailheadHover,
    trailheadHoverEvent,
    type TrailheadHoverDetail,
  } from "@/utils/trailheadHover";

  const visitWindow = window as Window & {
    __visitTrailheadHoverCleanup?: () => void;
    __visitTrailheadHoverBridgeReady?: boolean;
  };

  const setHighlightedTrailhead = (trailheadId?: string) => {
    document.querySelectorAll<HTMLElement>("[data-trailhead-id]").forEach((item) => {
      item.classList.toggle("is-map-highlighted", item.dataset.trailheadId === trailheadId);
    });
  };

  const initializeTrailheadHoverBridge = () => {
    const trailheadItems = document.querySelectorAll<HTMLElement>("[data-trailhead-id]");

    visitWindow.__visitTrailheadHoverCleanup?.();

    if (!trailheadItems.length) {
      return;
    }

    const cleanupHandlers: Array<() => void> = [];
    const addCleanupHandler = (
      target: EventTarget,
      type: string,
      listener: EventListenerOrEventListenerObject,
      options?: AddEventListenerOptions,
    ) => {
      target.addEventListener(type, listener, options);
      cleanupHandlers.push(() => target.removeEventListener(type, listener, options));
    };

    const handleTrailheadHover = (event: Event) => {
      if (!(event instanceof CustomEvent)) {
        return;
      }

      setHighlightedTrailhead((event as CustomEvent<TrailheadHoverDetail>).detail?.trailheadId);
    };

    trailheadItems.forEach((item) => {
      const activateTrailhead = () => {
        dispatchTrailheadHover(item.dataset.trailheadId);
      };

      const clearTrailhead = () => {
        dispatchTrailheadHover();
      };

      addCleanupHandler(item, "mouseenter", activateTrailhead);
      addCleanupHandler(item, "focus", activateTrailhead);
      addCleanupHandler(item, "mouseleave", clearTrailhead);
      addCleanupHandler(item, "blur", clearTrailhead);
    });

    addCleanupHandler(document, trailheadHoverEvent, handleTrailheadHover);

    const cleanupTrailheadHoverBridge = () => {
      cleanupHandlers.splice(0).forEach((cleanup) => cleanup());
      setHighlightedTrailhead();

      if (visitWindow.__visitTrailheadHoverCleanup === cleanupTrailheadHoverBridge) {
        delete visitWindow.__visitTrailheadHoverCleanup;
      }
    };

    visitWindow.__visitTrailheadHoverCleanup = cleanupTrailheadHoverBridge;
  };

  if (!visitWindow.__visitTrailheadHoverBridgeReady) {
    document.addEventListener("astro:page-load", initializeTrailheadHoverBridge);
    document.addEventListener("astro:before-swap", () => visitWindow.__visitTrailheadHoverCleanup?.());
    visitWindow.__visitTrailheadHoverBridgeReady = true;
  }

  initializeTrailheadHoverBridge();
</script>

<style>
  .visit-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .visit-hero .layout,
  .visit-map {
    display: grid;
  }

  .visit-hero .identity {
    padding: clamp(3rem, 8vw, 8rem) var(--space-page-x) clamp(5rem, 10vw, 10rem);
  }

  .visit-hero .stack {
    display: grid;
    gap: 2rem;
  }

  .visit-hero .stack > p {
    max-width: 36rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .visit-hero .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 3rem;
    padding-top: 2rem;
  }

  .visit-hero .facts p {
    margin: 0;
    font-family: var(--font-label);
    text-transform: uppercase;
  }

  .visit-hero .facts p:first-child {
    color: var(--color-text-subtle);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
  }

  .visit-hero .facts p:last-child {
    color: var(--color-brand-strong);
    font-size: var(--text-body-small);
    font-weight: 900;
  }

  .visit-hero .media {
    position: relative;
    overflow: hidden;
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
  }

  :global(.visit-hero .image) {
    min-height: 28rem;
  }

  .visit-hero .matte {
    --media-matte-border: 1.5rem solid color-mix(in oklab, var(--color-surface) 20%, transparent);
  }

  .visit-map .trailheads {
    padding: var(--space-section) var(--space-page-x);
  }

  .visit-section-heading {
    --section-heading-title-size: clamp(1.875rem, 5vw, 3.75rem);
    --section-heading-title-leading: normal;
    --section-heading-copy-size: var(--text-body-small);
    --section-heading-copy-margin: 0;
  }

  .visit-section-heading--spaced {
    margin-bottom: 4rem;
  }

  .trailhead-list {
    border-top: 1px solid var(--color-border-muted);
  }

  .trailhead-list .item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-border-muted);
    color: inherit;
    padding: 1.5rem 0.5rem;
    text-decoration: none;
    transition: background-color var(--duration-fast);
  }

  .trailhead-list .item:hover {
    background: var(--color-surface-muted);
  }

  .trailhead-list .item.is-map-highlighted {
    background: var(--color-surface-muted);
    box-shadow: inset 0.25rem 0 0 var(--color-brand-strong);
  }

  .trailhead-list .title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .trailhead-list .title span {
    color: var(--color-accent-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
  }

  .trailhead-list h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: var(--text-body-large);
    font-weight: 700;
    letter-spacing: 0;
    text-decoration: underline;
    text-decoration-color: var(--color-brand-strong);
    text-decoration-thickness: 4px;
    text-underline-offset: 0.125rem;
    text-transform: uppercase;
    transition: color var(--duration-fast);
  }

  .trailhead-list .item:hover h3,
  .trailhead-list .item:hover > span,
  .trailhead-list .item.is-map-highlighted h3,
  .trailhead-list .item.is-map-highlighted > span {
    color: var(--color-brand-strong);
  }

  .trailhead-list p {
    max-width: 24rem;
    margin: 0.25rem 0 0 2rem;
    color: var(--color-text-subtle);
    font-size: 0.75rem;
    font-weight: 500;
  }

  .trailhead-list .item > span {
    color: var(--color-accent-strong);
    transition: color var(--duration-fast);
  }

  .visit-map .context {
    background: var(--color-page);
    padding: clamp(2rem, 4vw, 3rem);
  }

  .visit-map .sticky {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 64rem) {
    .visit-map .sticky {
      position: sticky;
      top: 6rem;
    }
  }

  :global(.visit-map .image) {
    width: 100%;
    height: auto;
    transition: transform var(--duration-slow);
  }

  .static-map-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border: 1px solid var(--color-border-muted);
    background: var(--color-surface);
    color: inherit;
    padding: 1rem;
    text-decoration: none;
    transition:
      background-color var(--duration-fast),
      color var(--duration-fast);
  }

  .static-map-link:hover {
    background: var(--color-surface-muted);
  }

  .static-map-link span {
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .static-map-link span:first-child {
    color: var(--color-text-subtle);
  }

  .static-map-link span:last-child {
    color: var(--color-brand-strong);
  }

  .visit-fact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .visit-fact-grid > div {
    border: 1px solid var(--color-border-muted);
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
    padding: 1.5rem;
  }

  .visit-fact-grid p {
    margin: 0;
    font-family: var(--font-label);
    text-transform: uppercase;
  }

  .visit-fact-grid p:first-child {
    margin-bottom: 0.5rem;
    color: var(--color-text-subtle);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
  }

  .visit-fact-grid p:not(:first-child) {
    color: var(--color-text-strong);
    font-size: var(--text-body-small);
    font-weight: 900;
  }

  .visit-rules {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-inverse);
    color: var(--color-text-inverse);
    padding-block: var(--space-section);
  }

  .visit-rules .marker {
    position: absolute;
    top: 0;
    right: 0;
    display: none;
    width: 33%;
    height: 100%;
    border-left: 1px solid color-mix(in oklab, var(--color-text-inverse) 5%, transparent);
    pointer-events: none;
  }

  .visit-rules .inner {
    position: relative;
    z-index: 1;
  }

  .visit-rules .layout {
    display: grid;
    align-items: center;
    gap: 4rem;
  }

  .visit-rules .copy {
    --section-heading-gap: 2rem;
    --section-heading-copy-margin: 0;
  }

  .visit-rules .link {
    display: inline-block;
    width: fit-content;
    border: 2px solid var(--color-accent);
    color: var(--color-accent);
    padding: 1rem 2rem;
    font-family: var(--font-label);
    font-size: var(--text-body-small);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color var(--duration-fast),
      color var(--duration-fast),
      transform var(--duration-fast);
  }

  .visit-rules .link:hover {
    background: var(--color-accent);
    color: var(--color-surface-inverse);
  }

  .visit-rules .link:active {
    transform: scale(0.96);
  }

  .visit-rules .media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-text-inverse) 10%, transparent);
    background: var(--color-surface-inverse-muted);
  }

  :global(.visit-rules .image) {
    opacity: 0.5;
    transition: opacity var(--duration-slower);
  }

  .visit-rules .media:hover :global(.image) {
    opacity: 1;
  }

  .trail-grid {
    display: grid;
    gap: 1px;
    border: 1px solid var(--color-border);
    background: var(--color-border);
  }

  .trail-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--color-surface);
    padding: 2rem;
    transition: background-color var(--duration-fast);
  }

  .trail-card:hover {
    background: var(--color-page);
  }

  .trail-card > div {
    display: grid;
    gap: 1rem;
  }

  .trail-card span {
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    transition: color var(--duration-fast);
  }

  .trail-card:hover span {
    color: var(--color-brand-strong);
  }

  .trail-card h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .trail-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  @media (min-width: 48rem) {
    .trail-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .visit-hero .layout {
      grid-template-columns: 7fr 5fr;
    }

    .visit-hero .identity {
      border-right: 1px solid var(--color-border);
      padding-inline: var(--space-page-x) 3rem;
    }

    .visit-map {
      grid-template-columns: 5fr 7fr;
    }

    .visit-map .trailheads {
      border-right: 1px solid var(--color-border);
      padding-inline: var(--space-page-x) 3rem;
    }

    .visit-rules .marker {
      display: block;
    }

    .visit-rules .layout {
      grid-template-columns: 5fr 7fr;
    }

    .trail-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
