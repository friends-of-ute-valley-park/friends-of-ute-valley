---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { MeetingLocationParser } from "../../utils/EventData";
import { formatShortMonthDayYear } from "../../utils/date";
import { Image } from "astro:assets";
import volunteerImage from "../../assets/images/volunteer.jpg";

export async function getStaticPaths() {
  const eventsEntries = await getCollection("events");
  return eventsEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const meetingLocations = await getCollection("trailheads");
const locationInformation = MeetingLocationParser(entry.data, meetingLocations);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <main class="page event-detail">
    <section class="page-hero">
      <div class="page-hero__inner hero">
        <div class="page-eyebrow">
          <span>Volunteer Event</span>
        </div>
        <h1 class="title">{entry.data.title}</h1>
      </div>
    </section>

    <section class="page-section">
      <div class="inner">
        <Image
          src={volunteerImage}
          class="image"
          alt="volunteers working in Ute Valley Park"
        />

        <div class="meta-panel">
          <a class="meta-link" href={locationInformation.directionsLink}>
            <svg
              class="icon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                clip-rule="evenodd"></path>
            </svg>
            {locationInformation.name}
          </a>
          {
            entry.data.meetingLocation.notes && (
              <span class="notes">
                {entry.data.meetingLocation.notes}
              </span>
            )
          }
          <div class="meta-line">
            <svg
              class="icon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                clip-rule="evenodd"></path>
            </svg>
            {formatShortMonthDayYear(entry.data.date)}&nbsp;
            {entry.data.time}
          </div>
        </div>

        <div class="prose-content content">
          <Content />
        </div>

        {
          entry.data.link && (
            <div class="registration">
              <p>
                You must register to participate in this event.
              </p>
              <a href={entry.data.link} class="button button--brand">
                Register
              </a>
            </div>
          )
        }
      </div>
    </section>
  </main>
</Layout>

<style>
  .event-detail {
    position: relative;
    overflow: hidden;
  }

  .event-detail::before,
  .event-detail::after {
    position: absolute;
    z-index: 0;
    display: none;
    width: 25rem;
    height: 24rem;
    background-image: radial-gradient(var(--color-border-muted) 2px, transparent 2px);
    background-size: 20px 20px;
    content: '';
    pointer-events: none;
  }

  .event-detail::before {
    top: 8rem;
    left: calc(50% + 24rem);
  }

  .event-detail::after {
    top: 30rem;
    right: calc(50% + 24rem);
  }

  .event-detail .hero,
  .event-detail .inner {
    position: relative;
    z-index: 1;
  }

  .event-detail .title {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 900;
    line-height: var(--leading-tight);
    letter-spacing: 0;
    text-align: center;
    text-transform: uppercase;
  }

  .event-detail .inner {
    width: min(100% - (var(--space-page-x) * 2), 65ch);
    margin-inline: auto;
  }

  :global(.event-detail .image) {
    width: 100%;
    height: 24rem;
    object-fit: cover;
    border: 1px solid var(--color-border);
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 10%);
  }

  .event-detail .meta-panel {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.5rem;
    color: var(--color-text-subtle);
  }

  .event-detail .meta-link,
  .event-detail .meta-line {
    display: flex;
    align-items: center;
    color: var(--color-text-subtle);
  }

  .event-detail .meta-link {
    color: var(--color-brand);
    font-size: var(--text-body-large);
    text-decoration: underline;
  }

  .event-detail .notes {
    max-width: 24rem;
    color: var(--color-text-subtle);
    font-size: var(--text-body-small);
  }

  .event-detail .icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    margin-right: 0.375rem;
    color: var(--color-text-subtle);
  }

  .event-detail .content {
    padding-block: 2rem;
  }

  .event-detail .registration {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .event-detail .registration p {
    margin: 0;
    color: var(--color-brand);
    font-weight: 700;
  }

  @media (min-width: 64rem) {
    .event-detail::before,
    .event-detail::after {
      display: block;
    }
  }
</style>
