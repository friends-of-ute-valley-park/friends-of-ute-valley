---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { formatShortMonthDayYear } from '../../utils/date';
import { Picture } from 'astro:assets';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.previewText}>
  <main class="page">
    <!-- News Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            News
          </span>
        </div>

        <h1 class="title">
          {entry.data.title}
        </h1>

        <div class="meta">
          <span>
            Publish Date
          </span>
          <time
            datetime={entry.data.publishedOn.toString()}
          >
            {formatShortMonthDayYear(entry.data.publishedOn)}
          </time>
        </div>
      </div>
    </section>

    <!-- Field Report -->
    <section class="page-section">
      <div class="page-section__inner">
        <div class="layout">
          <div>
            <div class="article-photo-card">
              <Picture
                loading="lazy"
                formats={["avif", "webp"]}
                width={1200}
                height={800}
                class="image"
                src={entry.data.coverImage}
                alt={`${entry.data.title} cover image`}
              />
            </div>
          </div>
          <div>
            <div class="notes">
              <div class="notes-eyebrow">
                <span></span>
                <span>
                  Field Notes
                </span>
              </div>
              <div class="prose-content">
                <Content />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .news-detail .title {
    max-width: 62rem;
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 4.5rem);
    font-weight: 900;
    letter-spacing: 0;
    text-wrap: balance;
    text-transform: uppercase;
  }

  .news-detail .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .news-detail .meta span,
  .news-detail .meta time,
  .news-detail .notes-eyebrow span:last-child {
    font-family: var(--font-label);
    font-weight: 900;
    text-transform: uppercase;
  }

  .news-detail .meta span {
    color: var(--color-brand-strong);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
  }

  .news-detail .meta time {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
  }

  .news-detail .layout {
    display: grid;
    align-items: start;
    gap: 3rem;
  }

  :global(.news-detail .image) {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .news-detail .notes {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 2rem;
  }

  .news-detail .notes-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .news-detail .notes-eyebrow span:first-child {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--color-brand-strong);
  }

  .news-detail .notes-eyebrow span:last-child {
    color: var(--color-text-subtle);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
  }

  @media (min-width: 64rem) {
    .news-detail .layout {
      grid-template-columns: 7fr 5fr;
    }
  }
</style>
