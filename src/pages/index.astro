---
import Layout from "@layouts/Layout.astro";
import LeaveNoTrace from "@components/LeaveNoTrace.astro";
import EmailForm from "@components/EmailForm.vue";

import ChevronRightIcon from "~icons/heroicons/chevron-right";
import AccountGroupIcon from "~icons/mdi/account-group";
import ClockIcon from "~icons/mdi/clock-outline";
import DogIcon from "~icons/mdi/dog-side";
import EmailNewsletterIcon from "~icons/mdi/email-newsletter";
import HeartIcon from "~icons/mdi/heart";
import HikingIcon from "~icons/mdi/hiking";
import LeafIcon from "~icons/mdi/leaf";
import PineTreeIcon from "~icons/mdi/pine-tree";
import { Picture } from "astro:assets";
import heroImage from "../assets/images/ute-valley-park-hero-full.jpg";
import heroImage2 from "../assets/images/ute-valley-park-hero-2.jpg";
import mountainViewsImage from "../assets/images/volunteer-7.jpg";
import cta from "../assets/images/volunteer-5.jpg";

import { getCollection, getEntry } from "astro:content";
const trailConditionsEntry = await getEntry("trail-conditions", "current");
if (!trailConditionsEntry) {
  throw new Error("Trail conditions data missing");
}
const trailConditions = trailConditionsEntry.data;
const publishedNewsEntries = await getCollection("news", ({ data }) => {
  return data.published === true;
});
const currentMonthYear = new Intl.DateTimeFormat("en-US", {
  month: "short",
  year: "numeric",
}).format(new Date());

const formattedLastUpdated = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(trailConditions.last_updated));

// Park hours by season (from FAQ: Winter Nov 1–Apr 30, Summer May 1–Oct 31)
const currentMonth = new Date().getMonth() + 1; // 1-12
const isWinter = currentMonth >= 11 || currentMonth <= 4;
const parkSeason = isWinter ? "Winter" : "Summer";
const parkHours = isWinter ? "5AM to 9PM" : "5AM to 10PM";

const springTips = [
  {
    id: "01",
    title: "Avoid Muddy Trails",
    description:
      "Spring thaw and rains softens the ground. Walking muddy trails causes erosion and lasting damage—turn back or stick to drier routes.",
    tag: "EROSION CONTROL",
  },
  {
    id: "02",
    title: "Dress for Shifting Weather",
    description:
      "Spring in Colorado swings from sun to snow. Bring layers, sun protection, and extra water on every outing.",
    tag: "SAFETY FIRST",
  },
  {
    id: "03",
    title: "Give Wildlife Space",
    description:
      "Nesting birds and newborn animals are active this season. Keep dogs leashed and stay well back from wildlife.",
    tag: "HABITAT PRESERVATION",
  },
  {
    id: "04",
    title: "Pack Out Everything",
    description:
      "Melting snow exposes trash and pet waste left behind over winter. Carry out everything you bring in.",
    tag: "WASTE MGMT",
  },
];
---

<Layout
  title="Home"
  description="Friends of Ute Valley Park helps protect and maintain a 550-acre urban wildland in Colorado Springs through stewardship, education, and community action."
>
  <main
    class="bg-stone-50 text-stone-950 selection:bg-accent/30 selection:text-primary-dark"
  >
    <!-- Hero Section: The Field Report -->
    <section
      class="relative isolate min-h-[calc(100svh-5rem)] overflow-hidden border-b border-stone-300 bg-stone-50"
    >
      <Picture
        src={heroImage}
        formats={["avif", "webp"]}
        width="1800"
        height="1355"
        loading="eager"
        fetchpriority="high"
        alt="Ute Valley Park sandstone, pines, and Pikes Peak under a spring sky"
        class="absolute inset-0 -z-20 h-full w-full object-cover object-[62%_45%]"
      />
      <div class="absolute inset-0 -z-10 bg-grid-subtle opacity-35"></div>
      <div class="hero-fade-x absolute inset-0 -z-10"></div>
      <div class="hero-fade-corner absolute inset-x-0 bottom-0 -z-10 h-2/5"></div>

      <div class="mx-auto flex min-h-[calc(100svh-15rem)] max-w-(--breakpoint-2xl) items-end px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid w-full items-end gap-10 lg:grid-cols-12">
          <div class="max-w-3xl lg:col-span-7">
            <div class="mb-8 flex items-center gap-4">
              <span class="h-px w-12 bg-primary-dark"></span>
              <span
                class="font-mono text-xs font-medium tracking-tight text-stone-700"
              >
                Park update for {currentMonthYear}
              </span>
            </div>

            <h1
              class="font-serif text-[clamp(5rem,14vw,7rem)] leading-[0.78] font-black tracking-[-0.055em] text-stone-950 uppercase text-balance"
            >
              Ute <br /> Valley <br />
              <span class="text-primary-dark">Park.</span>
            </h1>

            <span class="mt-6 mb-6 block h-px w-8 bg-primary-dark"></span>

            <p
              class="max-w-[34rem] text-xl leading-relaxed font-medium text-stone-700 sm:text-2xl"
            >
              A 550-acre urban wildland in Colorado Springs. We are the
              stewards dedicated to its preservation, maintenance, and community
              education.
            </p>

            <div class="mt-10 flex flex-wrap gap-4">
              <a href="/visit/" class="btn-primary-cta">
                <span class="relative z-10 flex items-center gap-2">
                  Plan Visit <ChevronRightIcon class="h-4 w-4" />
                </span>
              </a>
              <a
                href="/volunteer/"
                class="inline-flex items-center justify-center border-2 border-primary-dark bg-stone-50/70 px-8 py-4 font-mono text-sm font-black text-primary-dark uppercase backdrop-blur-xs transition-[background-color,border-color,color,transform] duration-200 hover:bg-stone-50 active:scale-96 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
              >
                Volunteer
              </a>
            </div>
          </div>

          <aside
            class="rounded-lg bg-stone-50/95 p-6 shadow-2xl shadow-stone-900/15 ring-1 ring-stone-200 backdrop-blur-xs lg:col-span-4 lg:col-start-9 lg:p-8"
            aria-labelledby="park-status-title"
          >
            <div class="mb-6 flex items-center gap-4 border-b border-stone-300 pb-5">
              <span
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-50 text-primary-dark ring-1 ring-primary-200"
              >
                <PineTreeIcon class="h-5 w-5" aria-hidden="true" />
              </span>
              <h2
                id="park-status-title"
                class="font-serif text-lg font-bold tracking-tight text-primary-dark"
              >
                Current park status
              </h2>
            </div>

            <dl class="space-y-5">
              <div class="grid grid-cols-[1fr_auto] items-center gap-4">
                <dt class="flex items-center gap-4">
                  <span
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-stone-200 text-stone-700"
                  >
                    <HikingIcon class="h-5 w-5" aria-hidden="true" />
                  </span>
                  <span class="font-mono text-xs font-medium text-stone-600"
                    >Trail conditions</span
                  >
                </dt>
                <dd class="font-mono text-sm font-bold text-accent-darker">
                  {trailConditions.status}
                </dd>
              </div>

              <div class="grid grid-cols-[1fr_auto] items-center gap-4">
                <dt class="flex items-center gap-4">
                  <span
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-stone-200 text-stone-700"
                  >
                    <ClockIcon class="h-5 w-5" aria-hidden="true" />
                  </span>
                  <span class="font-mono text-xs font-medium text-stone-600"
                    >{parkSeason} hours</span
                  >
                </dt>
                <dd class="font-mono text-sm font-bold text-stone-950">
                  {parkHours}
                </dd>
              </div>

              <div class="grid grid-cols-[1fr_auto] items-center gap-4">
                <dt class="flex items-center gap-4">
                  <span
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-stone-200 text-stone-700"
                  >
                    <DogIcon class="h-5 w-5" aria-hidden="true" />
                  </span>
                  <span class="font-mono text-xs font-medium text-stone-600"
                    >Dog policy</span
                  >
                </dt>
                <dd
                  class="font-mono text-sm font-bold whitespace-nowrap text-primary-dark"
                >
                  Leash required
                </dd>
              </div>
            </dl>

            {
              trailConditions.message && (
                <p class="mt-6 border-t border-stone-300 pt-4 text-sm leading-relaxed font-medium text-stone-600">
                  {trailConditions.message}
                </p>
              )
            }

            <div
              class="mt-8 flex items-center justify-between border-t border-stone-300 pt-5 font-mono text-xs font-medium text-stone-500"
            >
              <span>Last updated</span>
              <time datetime={trailConditions.last_updated}
                >{formattedLastUpdated}</time
              >
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Visual Interlude: The Landscape -->
    <section
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-b border-stone-300"
    >
      <div
        class="aspect-video lg:aspect-square border-r border-stone-300 overflow-hidden relative group"
      >
        <Picture
          src={heroImage2}
          formats={["avif", "webp"]}
          width="600"
          height="600"
          alt="Trail"
          class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
        />
        <div
          class="absolute bottom-4 left-4 bg-white/90 px-3 py-1 font-mono text-xs uppercase border border-stone-200 text-primary-dark font-bold"
        >
          Trail System Access
        </div>
      </div>
      <div
        class="aspect-video lg:aspect-square border-r border-stone-300 overflow-hidden relative group hidden md:block"
      >
        <Picture
          src={mountainViewsImage}
          formats={["avif", "webp"]}
          width="600"
          height="600"
          alt="Vista"
          class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
        />
        <div
          class="absolute bottom-4 left-4 bg-white/90 px-3 py-1 font-mono text-xs uppercase border border-stone-200 text-primary-dark font-bold"
        >
          Mountain Views
        </div>
      </div>
      <div
        class="aspect-video lg:aspect-square overflow-hidden relative group hidden lg:block"
      >
        <Picture
          src={cta}
          formats={["avif", "webp"]}
          width="600"
          height="600"
          alt="Volunteer"
          class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
        />
        <div
          class="absolute bottom-4 left-4 bg-white/90 px-3 py-1 font-mono text-xs uppercase border border-stone-200 text-primary-dark font-bold"
        >
          Active Stewardship
        </div>
      </div>
    </section>

    <!-- Spring Stewardship: Technical Guidelines -->
    <section class="py-24 border-b border-stone-300 content-defer">
      <div class="mx-auto max-w-(--breakpoint-2xl) px-4 sm:px-6 lg:px-8">
        <div class="mb-16">
          <h2
            class="text-4xl sm:text-6xl font-serif font-black uppercase tracking-tight text-stone-900 mb-6 text-balance"
          >
            Spring <span class="text-primary-dark italic">Essentials.</span>
          </h2>
          <p class="max-w-2xl text-lg text-stone-600 font-medium">
            The park is fragile as it emerges from winter. Here is how you can
            help keep it healthy through the thaw.
          </p>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-stone-300 border border-stone-300"
        >
          {
            springTips.map((tip) => (
              <div class="bg-stone-50 p-8 space-y-6 flex flex-col justify-between hover:bg-white transition-colors group">
                <div class="space-y-4">
                  <span class="font-mono text-4xl font-black text-accent-dark group-hover:text-accent transition-colors">
                    {tip.id}
                  </span>
                  <h3 class="text-xl font-bold font-serif uppercase tracking-tight text-stone-900 group-hover:text-primary-dark transition-colors">
                    {tip.title}
                  </h3>
                  <p class="text-sm leading-relaxed text-stone-600">
                    {tip.description}
                  </p>
                </div>
                <div class="pt-6">
                  <span class="inline-block px-2 py-1 bg-primary-dark text-white font-mono text-[10px] uppercase tracking-widest">
                    {tip.tag}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Stats Section: Redesigned in place -->
    <section class="py-24 bg-stone-900 text-white content-defer">
      <div class="mx-auto max-w-(--breakpoint-2xl) px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <span
              class="font-mono text-xs font-bold uppercase tracking-[0.3em] text-stone-300 mb-4 block"
              >Our Impact: 2025</span
            >
            <h2
              class="text-5xl sm:text-7xl font-serif font-black uppercase tracking-tighter leading-none mb-8"
            >
              Our <br />
              <span class="text-primary-light">Impact.</span>
            </h2>
            <p class="text-stone-300 text-lg max-w-md leading-relaxed">
              A year of boots-on-the-ground stewardship and a growing community
              of people who care about Ute Valley Park.
            </p>
          </div>
          <div
            class="space-y-10 border-l border-stone-800 pl-8 lg:pl-16"
          >
            {
              [
                {
                  group: "On the Ground",
                  stats: [
                    { label: "Volunteers", value: "76" },
                    { label: "Field Hours", value: "331" },
                    { label: "Stewardship Days", value: "7" },
                  ],
                },
                {
                  group: "Community Reach",
                  stats: [
                    { label: "Instagram", value: "2,500" },
                    { label: "Facebook", value: "2,100" },
                    { label: "Subscribers", value: "600" },
                  ],
                },
              ].map((section) => (
                <div>
                  <div class="flex items-center gap-3 mb-5">
                    <span class="inline-block h-px w-6 bg-primary-light" />
                    <span class="font-mono text-[10px] font-bold uppercase tracking-[0.3em] text-primary-light">
                      {section.group}
                    </span>
                  </div>
                  <div class="grid grid-cols-3 gap-6">
                    {section.stats.map((stat) => (
                      <div class="space-y-1">
                        <div class="text-3xl sm:text-5xl font-mono font-black tracking-tighter text-white">
                          {stat.value}
                        </div>
                        <div class="text-[10px] font-mono uppercase tracking-widest text-stone-300">
                          {stat.label}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- News Section: The Bulletin Board -->
    <section class="py-24 border-b border-stone-300 content-defer">
      <div class="mx-auto max-w-(--breakpoint-2xl) px-4 sm:px-6 lg:px-8">
        <div
          class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16"
        >
          <div>
            <h2
              class="text-4xl sm:text-6xl font-serif font-black uppercase tracking-tight text-stone-900 mb-4 text-balance"
            >
              Latest <span class="text-primary-dark italic">News.</span>
            </h2>
            <p class="text-stone-600 font-medium">
              News and updates from Ute Valley Park.
            </p>
          </div>
          <a
            href="/news"
            class="font-mono text-sm font-bold uppercase underline decoration-accent decoration-2 underline-offset-8 hover:text-primary transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            View All News
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
          {
            publishedNewsEntries
              .sort(
                (a, b) =>
                  new Date(b.data.publishedOn).getTime() -
                  new Date(a.data.publishedOn).getTime(),
              )
              .slice(0, 3)
              .map((post) => (
                <a
                  href={`/news/${post.id}`}
                  class="group space-y-6 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  <div class="aspect-16/10 overflow-hidden bg-stone-200 border border-stone-300 relative">
                    <Picture
                      src={post.data.coverImage}
                      formats={["avif", "webp"]}
                      width="600"
                      height="400"
                      alt={post.data.title}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                    <div class="absolute top-4 right-4 bg-primary-dark text-white px-2 py-1 font-mono text-[10px] uppercase">
                      {new Date(post.data.publishedOn).toLocaleDateString(
                        "en-US",
                        { month: "short", day: "2-digit", year: "numeric" },
                      )}
                    </div>
                  </div>
                  <div class="space-y-3">
                    <h3 class="text-2xl font-serif font-bold leading-tight group-hover:text-primary-dark transition-colors">
                      {post.data.title}
                    </h3>
                    <p class="text-sm text-stone-600 line-clamp-2 leading-relaxed">
                      {post.data.previewText}
                    </p>
                  </div>
                </a>
              ))
          }
        </div>
      </div>
    </section>

    <!-- Engagement: Direct Action -->
    <section class="py-24 bg-stone-100 content-defer">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="support-split relative overflow-hidden border-2 border-primary-dark bg-white shadow-accent-xl">
          <div class="support-split__grid relative z-10">
            <div class="support-split__col support-split__col--donate">
              <div class="support-split__meta text-primary-dark">
                <span class="support-split__mark"><HeartIcon aria-hidden="true" /></span>
                <span class="support-split__eyebrow">Donate</span>
              </div>
              <h2 class="support-split__headline">Support Ute Valley Park.</h2>
              <p class="text-lg leading-relaxed font-medium text-stone-700">
                Your donation directly funds trail restoration, invasive species management, and educational programming. Together, we can protect and enhance our park for generations to come.
              </p>
              <ul class="support-split__benefits text-primary-dark">
                <li><PineTreeIcon class="text-primary" aria-hidden="true" /><span>Restore Trails</span></li>
                <li><LeafIcon class="text-primary" aria-hidden="true" /><span>Protect Wildlife</span></li>
                <li><AccountGroupIcon class="text-primary" aria-hidden="true" /><span>Inspire Community</span></li>
              </ul>
              <a href="/donate/" class="btn-primary-cta inline-flex w-full items-center justify-center gap-3 text-center">
                <HeartIcon class="h-5 w-5" aria-hidden="true" />
                Make a Donation
              </a>
            </div>

            <div class="support-split__rule" aria-hidden="true"></div>
            <div class="support-split__or">Or</div>

            <div class="support-split__col support-split__col--newsletter">
              <div class="support-split__meta text-accent-dark">
                <span class="support-split__mark"><EmailNewsletterIcon aria-hidden="true" /></span>
                <span class="support-split__eyebrow">Email Newsletter</span>
              </div>
              <h2 class="support-split__headline">Stay in the Loop.</h2>
              <p class="text-lg leading-relaxed font-medium text-stone-700">
                Get park updates, volunteer opportunities, event announcements, and conservation news delivered straight to your inbox.
              </p>
              <EmailForm client:idle />
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="bg-stone-50 border-t border-stone-300 content-defer">
      <LeaveNoTrace />
    </div>
  </main>
</Layout>

<style>
  /* Grid pattern overlay for that technical field-notes look */
  .bg-grid-subtle {
    background-image: radial-gradient(
      circle,
      var(--color-stone-300) 1px,
      transparent 1px
    );
    background-size: 24px 24px;
  }

  /* Hero photo fades — referenced from var(--color-stone-50) so the
     overlay stays in sync if the brand neutral shifts. */
  .hero-fade-x {
    background: linear-gradient(
      90deg,
      var(--color-stone-50) 0%,
      color-mix(in oklab, var(--color-stone-50) 92%, transparent) 34%,
      color-mix(in oklab, var(--color-stone-50) 34%, transparent) 58%,
      transparent 82%
    );
  }
  @media (min-width: 1024px) {
    .hero-fade-x {
      background: linear-gradient(
        90deg,
        var(--color-stone-50) 0%,
        var(--color-stone-50) 36%,
        color-mix(in oklab, var(--color-stone-50) 92%, transparent) 42%,
        color-mix(in oklab, var(--color-stone-50) 46%, transparent) 50%,
        color-mix(in oklab, var(--color-stone-50) 12%, transparent) 58%,
        transparent 66%
      );
    }
  }
  .hero-fade-corner {
    background: radial-gradient(
      ellipse at 22% 100%,
      color-mix(in oklab, var(--color-stone-50) 92%, transparent) 0%,
      color-mix(in oklab, var(--color-stone-50) 50%, transparent) 38%,
      transparent 70%
    );
  }
  @media (min-width: 1024px) {
    .hero-fade-corner {
      background: radial-gradient(
        ellipse at 23% 100%,
        color-mix(in oklab, var(--color-stone-50) 96%, transparent) 0%,
        color-mix(in oklab, var(--color-stone-50) 62%, transparent) 34%,
        color-mix(in oklab, var(--color-stone-50) 14%, transparent) 56%,
        transparent 74%
      );
    }
  }

  /* Donate / Newsletter split: two columns edge-to-edge inside the outer
     border, separated by a full-height rule with a centered "Or" pill. */
  .support-split {
    padding: 0;
  }
  .support-split__grid {
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 1024px) {
    .support-split__grid {
      grid-template-columns: 1fr 1px 1fr;
    }
  }
  .support-split__col {
    position: relative;
    padding: 2rem;
  }
  @media (min-width: 640px) {
    .support-split__col {
      padding: 2.5rem;
    }
  }
  @media (min-width: 1024px) {
    .support-split__col {
      padding: 3rem;
    }
  }
  .support-split__col--donate {
    background: oklch(0.97 0.012 155 / 0.55);
  }
  .support-split__col--newsletter {
    background: oklch(0.97 0.02 80 / 0.45);
  }
  .support-split__col > * + * {
    margin-top: 1.5rem;
  }

  .support-split__rule {
    display: none;
    position: relative;
    z-index: 2;
    background: oklch(0.82 0.005 60);
  }
  @media (min-width: 1024px) {
    .support-split__rule {
      display: block;
    }
    .support-split__rule::after {
      content: "Or";
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      padding: 0.5rem 0.875rem;
      background: #fff;
      border: 1px solid oklch(0.82 0.005 60);
      border-radius: 9999px;
      color: var(--color-primary-dark, oklch(0.25 0.05 155));
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.75rem;
      font-weight: 900;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      white-space: nowrap;
    }
  }

  .support-split__or {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding-block: 1.25rem;
    border-top: 1px solid oklch(0.82 0.005 60);
    border-bottom: 1px solid oklch(0.82 0.005 60);
    color: var(--color-primary-dark, oklch(0.25 0.05 155));
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    font-weight: 900;
