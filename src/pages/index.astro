---
import Layout from "@layouts/Layout.astro";
import LeaveNoTrace from "@components/LeaveNoTrace.astro";
import EmailForm from "@components/EmailForm.vue";

import ChevronRightIcon from "~icons/heroicons/chevron-right";
import AccountGroupIcon from "~icons/mdi/account-group";
import ClockIcon from "~icons/mdi/clock-outline";
import DogIcon from "~icons/mdi/dog-side";
import EmailNewsletterIcon from "~icons/mdi/email-newsletter";
import HeartIcon from "~icons/mdi/heart";
import HikingIcon from "~icons/mdi/hiking";
import LeafIcon from "~icons/mdi/leaf";
import PineTreeIcon from "~icons/mdi/pine-tree";
import { Picture } from "astro:assets";
import heroImage from "../assets/images/ute-valley-park-hero-full.jpg";
import heroImage2 from "../assets/images/ute-valley-park-hero-2.jpg";
import mountainViewsImage from "../assets/images/volunteer-7.jpg";
import cta from "../assets/images/volunteer-5.jpg";

import { getEntry } from "astro:content";
import { formatShortMonthDayYear, formatShortMonthYear, getParkHoursForDate } from "@/utils/date";
import { getPublishedNewsEntries } from "@/utils/content";
const trailConditionsEntry = await getEntry("trail-conditions", "current");
if (!trailConditionsEntry) {
  throw new Error("Trail conditions data missing");
}
const trailConditions = trailConditionsEntry.data;
const publishedNewsEntries = await getPublishedNewsEntries();
const currentMonthYear = formatShortMonthYear(new Date());

const formattedLastUpdated = formatShortMonthDayYear(trailConditions.last_updated);

// Park hours by season (from FAQ: Winter Nov 1–Apr 30, Summer May 1–Oct 31)
const { season: parkSeason, hours: parkHours } = getParkHoursForDate();

const springTips = [
  {
    id: "01",
    title: "Avoid Muddy Trails",
    description:
      "Spring thaw and rains softens the ground. Walking muddy trails causes erosion and lasting damage—turn back or stick to drier routes.",
    tag: "EROSION CONTROL",
  },
  {
    id: "02",
    title: "Dress for Shifting Weather",
    description:
      "Spring in Colorado swings from sun to snow. Bring layers, sun protection, and extra water on every outing.",
    tag: "SAFETY FIRST",
  },
  {
    id: "03",
    title: "Give Wildlife Space",
    description:
      "Nesting birds and newborn animals are active this season. Keep dogs leashed and stay well back from wildlife.",
    tag: "HABITAT PRESERVATION",
  },
  {
    id: "04",
    title: "Pack Out Everything",
    description:
      "Melting snow exposes trash and pet waste left behind over winter. Carry out everything you bring in.",
    tag: "WASTE MGMT",
  },
];
---

<Layout
  title="Home"
  description="Friends of Ute Valley Park helps protect and maintain a 550-acre urban wildland in Colorado Springs through stewardship, education, and community action."
>
  <main class="home-page">
    <!-- Hero Section: The Field Report -->
    <section class="home-hero">
      <Picture
        src={heroImage}
        formats={["avif", "webp"]}
        width="1800"
        height="1355"
        loading="eager"
        fetchpriority="high"
        alt="Ute Valley Park sandstone, pines, and Pikes Peak under a spring sky"
        class="image"
      />
      <div class="home-field-pattern grid"></div>
      <div class="hero-fade-x fade-x"></div>
      <div class="hero-fade-corner fade-corner"></div>

      <div class="l-container container">
        <div class="layout">
          <div class="copy">
            <div class="home-kicker">
              <span class="rule"></span>
              <span class="text">Park update for {currentMonthYear}</span>
            </div>

            <h1 class="title">
              Ute <br /> Valley <br />
              <span>Park.</span>
            </h1>

            <span class="rule"></span>

            <p class="lede">
              A 550-acre urban wildland in Colorado Springs. We are the
              stewards dedicated to its preservation, maintenance, and community
              education.
            </p>

            <div class="home-actions">
              <a href="/visit/" class="button button--brand">
                <span class="home-button-content">
                  Plan Visit <ChevronRightIcon class="home-button-icon" />
                </span>
              </a>
              <a href="/volunteer/" class="button home-button-secondary">
                Volunteer
              </a>
            </div>
          </div>

          <aside class="park-status" aria-labelledby="park-status-title">
            <div class="header">
              <span class="brand-icon">
                <PineTreeIcon aria-hidden="true" />
              </span>
              <h2 id="park-status-title" class="title">
                Current park status
              </h2>
            </div>

            <dl class="list">
              <div class="item">
                <dt class="term">
                  <span class="icon">
                    <HikingIcon aria-hidden="true" />
                  </span>
                  <span>Trail conditions</span>
                </dt>
                <dd class="value accent">
                  {trailConditions.status}
                </dd>
              </div>

              <div class="item">
                <dt class="term">
                  <span class="icon">
                    <ClockIcon aria-hidden="true" />
                  </span>
                  <span>{parkSeason} hours</span>
                </dt>
                <dd class="value">{parkHours}</dd>
              </div>

              <div class="item">
                <dt class="term">
                  <span class="icon">
                    <DogIcon aria-hidden="true" />
                  </span>
                  <span>Dog policy</span>
                </dt>
                <dd class="value brand">
                  Leash required
                </dd>
              </div>
            </dl>

            {
              trailConditions.message && (
                <p class="message">
                  {trailConditions.message}
                </p>
              )
            }

            <div class="updated">
              <span>Last updated</span>
              <time datetime={trailConditions.last_updated}
                >{formattedLastUpdated}</time
              >
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Visual Interlude: The Landscape -->
    <section class="landscape-strip">
      <div class="item">
        <Picture
          src={heroImage2}
          formats={["avif", "webp"]}
          width="600"
          height="600"
          alt="Trail"
          class="image"
        />
        <div class="label">Trail System Access</div>
      </div>
      <div class="item tablet">
        <Picture
          src={mountainViewsImage}
          formats={["avif", "webp"]}
          width="600"
          height="600"
          alt="Vista"
          class="image"
        />
        <div class="label">Mountain Views</div>
      </div>
      <div class="item desktop">
        <Picture
          src={cta}
          formats={["avif", "webp"]}
          width="600"
          height="600"
          alt="Volunteer"
          class="image"
        />
        <div class="label">Active Stewardship</div>
      </div>
    </section>

    <!-- Spring Stewardship: Technical Guidelines -->
    <section class="l-section band spring-section content-defer">
      <div class="l-container">
        <div class="section-heading">
          <h2 class="t-section-title">
            Spring <span>Essentials.</span>
          </h2>
          <p>
            The park is fragile as it emerges from winter. Here is how you can
            help keep it healthy through the thaw.
          </p>
        </div>

        <div class="spring-grid">
          {
            springTips.map((tip) => (
              <div class="spring-card">
                <div class="content">
                  <span class="number">{tip.id}</span>
                  <h3>{tip.title}</h3>
                  <p>{tip.description}</p>
                </div>
                <div class="footer">
                  <span>{tip.tag}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Stats Section: Redesigned in place -->
    <section class="l-section band band--inverse impact-section content-defer">
      <div class="l-container">
        <div class="layout">
          <div>
            <span class="kicker">Our Impact: 2025</span>
            <h2 class="title">
              Our <br />
              <span>Impact.</span>
            </h2>
            <p class="lede">
              A year of boots-on-the-ground stewardship and a growing community
              of people who care about Ute Valley Park.
            </p>
          </div>
          <div class="impact-groups">
            {
              [
                {
                  group: "On the Ground",
                  stats: [
                    { label: "Volunteers", value: "76" },
                    { label: "Field Hours", value: "331" },
                    { label: "Stewardship Days", value: "7" },
                  ],
                },
                {
                  group: "Community Reach",
                  stats: [
                    { label: "Instagram", value: "2,500" },
                    { label: "Facebook", value: "2,100" },
                    { label: "Subscribers", value: "600" },
                  ],
                },
              ].map((section) => (
                <div class="impact-group">
                  <div class="heading">
                    <span />
                    <span>{section.group}</span>
                  </div>
                  <div class="impact-stats">
                    {section.stats.map((stat) => (
                      <div class="impact-stat">
                        <div class="value">{stat.value}</div>
                        <div class="label">{stat.label}</div>
                      </div>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- News Section: The Bulletin Board -->
    <section class="l-section band news-section content-defer">
      <div class="l-container">
        <div class="heading">
          <div>
            <h2 class="t-section-title">
              Latest <span>News.</span>
            </h2>
            <p>News and updates from Ute Valley Park.</p>
          </div>
          <a href="/news" class="all-link">
            View All News
          </a>
        </div>

        <div class="news-grid">
          {
            publishedNewsEntries
              .slice(0, 3)
              .map((post) => (
                <a href={`/news/${post.id}`} class="news-card">
                  <div class="media">
                    <Picture
                      src={post.data.coverImage}
                      formats={["avif", "webp"]}
                      width="600"
                      height="400"
                      alt={post.data.title}
                      class="image"
                    />
                    <div class="date">
                      {formatShortMonthDayYear(post.data.publishedOn)}
                    </div>
                  </div>
                  <div class="body">
                    <h3>{post.data.title}</h3>
                    <p>{post.data.previewText}</p>
                  </div>
                </a>
              ))
          }
        </div>
      </div>
    </section>

    <!-- Engagement: Direct Action -->
    <section class="l-section band band--muted support-section content-defer">
      <div class="container">
        <div class="support-split">
          <div class="grid">
            <div class="col donate">
              <div class="meta brand">
                <span class="mark"><HeartIcon aria-hidden="true" /></span>
                <span class="eyebrow t-label">Mail Support</span>
              </div>
              <h2 class="headline">Support Ute Valley Park.</h2>
              <p class="copy">
                Online donations are temporarily paused while we transition away from our fiscal sponsor. Please mail donations and correspondence directly to Friends of Ute Valley Park.
              </p>
              <ul class="benefits">
                <li><PineTreeIcon aria-hidden="true" /><span>Restore Trails</span></li>
                <li><LeafIcon aria-hidden="true" /><span>Protect Wildlife</span></li>
                <li><AccountGroupIcon aria-hidden="true" /><span>Inspire Community</span></li>
              </ul>
              <address class="mail-address">
                <span>Friends of Ute Valley Park</span>
                <span>PO Box 50122</span>
                <span>Colorado Springs, CO 80919</span>
              </address>
            </div>

            <div class="rule" aria-hidden="true"></div>
            <div class="or">Or</div>

            <div class="col newsletter">
              <div class="meta accent">
                <span class="mark"><EmailNewsletterIcon aria-hidden="true" /></span>
                <span class="eyebrow t-label">Email Newsletter</span>
              </div>
              <h2 class="headline">Stay in the Loop.</h2>
              <p class="copy">
                Get park updates, volunteer opportunities, event announcements, and conservation news delivered straight to your inbox.
              </p>
              <EmailForm client:idle />
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="leave-no-trace-band content-defer">
      <LeaveNoTrace />
    </div>
  </main>
</Layout>

<style>
  .home-page {
    background: var(--color-page);
    color: var(--color-text);
  }

  .home-page ::selection {
    background: color-mix(in oklab, var(--color-accent) 30%, transparent);
    color: var(--color-brand-strong);
  }

  .home-hero {
    position: relative;
    isolation: isolate;
    min-height: calc(100svh - 5rem);
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-page);
  }

  :global(.home-hero .image) {
    position: absolute;
    inset: 0;
    z-index: -20;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 62% 45%;
  }

  .home-hero .grid,
  .home-hero .fade-x {
    position: absolute;
    inset: 0;
    z-index: -10;
  }

  .home-hero .grid {
    opacity: 0.35;
  }

  .home-hero .fade-corner {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: -10;
    height: 40%;
  }

  .home-hero .container {
    display: flex;
    min-height: calc(100svh - 15rem);
    align-items: end;
    padding-block: 3rem;
  }

  .home-hero .layout {
    display: grid;
    width: 100%;
    align-items: end;
    gap: 2.5rem;
  }

  .home-hero .copy {
    max-width: 48rem;
  }

  .home-kicker,
  .home-actions,
  .home-button-content,
  .park-status .header,
  .park-status .term,
  .park-status .updated,
  .impact-group .heading {
    display: flex;
    align-items: center;
  }

  .home-kicker {
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .home-kicker .rule,
  .home-hero .rule,
  .impact-group .heading span:first-child {
    display: block;
    height: 1px;
    background: var(--color-brand-strong);
  }

  .home-kicker .rule {
    width: 3rem;
  }

  .home-kicker .text {
    color: var(--color-text-muted);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0;
  }

  .home-hero .title {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: var(--text-display-xl);
    font-weight: 900;
    line-height: 0.78;
    letter-spacing: 0;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .home-hero .title span {
    color: var(--color-brand-strong);
  }

  .home-hero .rule {
    width: 2rem;
    margin-block: 1.5rem;
  }

  .home-hero .lede {
    max-width: 34rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.625;
  }

  .home-actions {
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .home-button-content {
    position: relative;
    z-index: 1;
    gap: 0.5rem;
  }

  .home-button-icon,
  .support-split .button svg {
    width: 1rem;
    height: 1rem;
  }

  .home-button-secondary {
    border: 2px solid var(--color-brand-strong);
    background: color-mix(in oklab, var(--color-page) 70%, transparent);
    color: var(--color-brand-strong);
    font-weight: 900;
    backdrop-filter: blur(4px);
    transition-duration: 200ms;
  }

  .home-button-secondary:hover {
    background: var(--color-page);
  }

  .home-button-secondary:active {
    transform: scale(0.96);
  }

  .park-status {
    padding: 1.5rem;
    border-radius: 0.5rem;
    background: color-mix(in oklab, var(--color-page) 95%, transparent);
    box-shadow: 0 25px 50px -12px color-mix(in oklab, var(--color-surface-inverse) 15%, transparent);
    backdrop-filter: blur(4px);
    outline: 1px solid var(--color-border-muted);
  }

  .park-status .header {
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .park-status .brand-icon,
  .park-status .icon {
    display: flex;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
  }

  .park-status .brand-icon {
    background: var(--color-brand-subtle);
    color: var(--color-brand-strong);
    outline: 1px solid var(--color-brand-muted);
  }

  .park-status .brand-icon svg,
  .park-status .icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .park-status .title {
    margin: 0;
    color: var(--color-brand-strong);
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .park-status .list {
    display: grid;
    gap: 1.25rem;
    margin: 0;
  }

  .park-status .item {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .park-status .term {
    gap: 1rem;
  }

  .park-status .icon {
    background: var(--color-border-muted);
    color: var(--color-text-muted);
  }

  .park-status .term span:last-child,
  .park-status .updated {
    color: var(--color-text-muted);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 500;
  }

  .park-status .value {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-label);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .park-status .value.accent {
    color: var(--color-accent-strong);
  }

  .park-status .value.brand {
    color: var(--color-brand-strong);
    white-space: nowrap;
  }

  .park-status .message {
    margin: 1.5rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .park-status .updated {
    justify-content: space-between;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .landscape-strip {
    display: grid;
    grid-template-columns: 1fr;
    border-bottom: 1px solid var(--color-border);
  }

  .landscape-strip .item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border-right: 1px solid var(--color-border);
  }

  .landscape-strip .item.tablet,
  .landscape-strip .item.desktop {
    display: none;
  }

  :global(.landscape-strip .image),
  :global(.news-card .image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1000ms;
  }

  .landscape-strip .item:hover :global(.image),
  .news-card:hover :global(.image) {
    transform: scale(1.05);
  }

  .landscape-strip .label {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    border: 1px solid var(--color-border-muted);
    background: color-mix(in oklab, var(--color-surface) 90%, transparent);
    color: var(--color-brand-strong);
    padding: 0.25rem 0.75rem;
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .spring-section,
  .news-section,
  .leave-no-trace-band {
    border-bottom: 1px solid var(--color-border);
  }

  .section-heading,
  .news-section .heading {
    margin-bottom: 4rem;
  }

  .section-heading h2,
  .news-section .heading h2 {
    margin: 0 0 1.5rem;
    color: var(--color-text-strong);
    text-wrap: balance;
  }

  .section-heading h2 span,
  .news-section .heading h2 span {
    color: var(--color-brand-strong);
    font-style: italic;
  }

  .section-heading p {
    max-width: 42rem;
    margin: 0;
  }

  .section-heading p,
  .news-section .heading p,
  .support-split .copy {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .spring-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border: 0;
    background: transparent;
  }

  .spring-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-page);
    padding: 2rem;
    transition:
      background-color 200ms,
      color 200ms;
  }

  .spring-card:hover {
    background: var(--color-surface);
  }

  .spring-card .content > * + * {
    margin-top: 1rem;
  }

  .spring-card .number {
    color: var(--color-accent-hover);
    font-family: var(--font-label);
    font-size: 2.25rem;
    font-weight: 900;
    transition: color 200ms;
  }

  .spring-card:hover .number {
    color: var(--color-accent);
  }

  .spring-card h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    transition: color 200ms;
  }

  .spring-card:hover h3 {
    color: var(--color-brand-strong);
  }

  .spring-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: var(--leading-body);
  }

  .spring-card .footer {
    padding-top: 1.5rem;
  }

  .spring-card .footer span {
    display: inline-block;
    background: var(--color-brand-strong);
    color: var(--color-text-inverse);
    padding: 0.25rem 0.5rem;
    font-family: var(--font-label);
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .impact-section .layout {
    display: grid;
    align-items: center;
    gap: 4rem;
  }

  .impact-section .kicker {
    display: block;
    margin-bottom: 1rem;
    color: var(--color-text-inverse-muted);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .impact-section .title {
    margin: 0 0 2rem;
    color: var(--color-text-inverse);
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .impact-section .title span,
  .impact-group .heading span:last-child {
    color: var(--color-brand-hover);
  }

  .impact-section .lede {
    max-width: 28rem;
    margin: 0;
    color: var(--color-text-inverse-muted);
    font-size: 1.125rem;
    line-height: var(--leading-body);
  }

  .impact-groups {
    display: grid;
    gap: 2.5rem;
    border-left: 1px solid var(--color-surface-inverse-muted);
    padding-left: 2rem;
  }

  .impact-group .heading {
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .impact-group .heading span:first-child {
    width: 1.5rem;
