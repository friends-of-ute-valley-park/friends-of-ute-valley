---
import LeaveNoTrace from "@components/LeaveNoTrace.astro";
import Layout from "@layouts/Layout.astro";
import { Picture } from "astro:assets";
import trailRightOfWay from "../assets/images/trail-right-of-way.png";

const parkRules = [
  {
    code: "9.9.410",
    title: "Alcoholic Beverages",
    description: "Prohibited in all City Parks by municipal ordinance.",
  },
  {
    code: "6.6.202",
    title: "Smoking & Vaping",
    description:
      "Prohibited on park property. No designated smoking areas exist in UVP.",
  },
  {
    code: "9.9.301",
    title: "Waste Management",
    description:
      "Removal and proper disposal of all animal excrement is mandatory.",
  },
  {
    code: "9.9.302",
    title: "Leash Requirement",
    description:
      "All animals must be physically leashed. No off-leash zones exist in UVP.",
  },
  {
    code: "OR-05",
    title: "Open Fires",
    description:
      "Open fires and charcoal grills are strictly prohibited. Propane only on hard surfaces.",
  },
  {
    code: "OR-06",
    title: "Property Integrity",
    description:
      "Unlawful to injure, deface, or remove any park property or vegetation.",
  },
];
---

<Layout
  title="Rules"
  description="Review Ute Valley Park rules and city ordinances including leash laws, park hours, trail etiquette, and safety requirements."
>
  <main class="page rules-page">
    <!-- Regulations Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            Park Rules
          </span>
        </div>

        <h1 class="page-title">
          Park <br />
          <span>Regulations.</span>
        </h1>

        <p class="page-intro">
          The City of Colorado Springs Parks, Recreation, and Cultural Services
          Department establishes and enforces the following ordinances for Ute
          Valley Park.
        </p>
      </div>
    </section>

    <!-- Essential Hours & Exceptions -->
    <section class="rules-summary">
      <div class="page-section__inner">
        <div class="grid">
          <div class="rules-summary-card">
            <h3>
              Park Hours
            </h3>
            <div class="rows">
              <div>
                <span>Winter (Nov-Apr)</span>
                <span>05:00 — 21:00</span>
              </div>
              <div>
                <span>Summer (May-Oct)</span>
                <span>05:00 — 22:00</span>
              </div>
            </div>
          </div>

          <div class="rules-summary-card">
            <h3>
              Dog Rules
            </h3>
            <p>
              NO OFF-LEASH AREAS. NO DOG PARKS. LEASHES MANDATORY AT ALL TIMES
              WITHOUT EXCEPTION.
            </p>
          </div>

          <div class="rules-summary-card">
            <h3>
              Fire Safety
            </h3>
            <p>
              SMOKING PROHIBITED. OPEN FIRES PROHIBITED. CHARCOAL PROHIBITED.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Detailed Code -->
    <section class="page-section">
      <div class="page-section__inner">
        <div class="rules-heading section-heading">
          <h2 class="section-heading__title">
            Municipal <span>Ordinances.</span>
          </h2>
        </div>

        <div class="feature-grid feature-grid--two feature-grid--three">
          {
            parkRules.map((rule) => (
              <div class="ordinance-card">
                <div>
                  <span>
                    {rule.code}
                  </span>
                </div>
                <div>
                  <h3>
                    {rule.title}
                  </h3>
                  <p>
                    {rule.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>

        <div class="additional-rules">
          <h3>
            Additional Restrictions
          </h3>
          <div>
            <p>
              • Motorized vehicles (ATVs, golf carts, etc.) are strictly
              prohibited on all trails, turf, and restricted roadways.
            </p>
            <p>
              • Amplified audio equipment requires a noise permit from the CSPD
              (Ref: 9-8-101).
            </p>
            <p>
              • Posting of unauthorized signage or hanging decorations on
              structures/vegetation is prohibited.
            </p>
            <p>
              • Attachment of ropes, wires, or other contrivances to any tree or
              plant is prohibited.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Trail Etiquette -->
    <section class="right-of-way">
      <div class="inner l-container">
        <div class="layout">
          <div class="copy section-heading section-heading--inverse">
            <div class="eyebrow section-kicker section-kicker--wide section-kicker--accent">
              <span class="section-kicker__rule"></span>
              <span class="section-kicker__text">Field Etiquette</span>
            </div>
            <h2 class="section-heading__title">
              Right of <br />
              <span>Way.</span>
            </h2>
            <ul>
              <li>
                Stay on designated trails only
              </li>
              <li>
                Yield to uphill travelers
              </li>
              <li>
                Bicyclists yield to all other users
              </li>
              <li>
                Warn others before passing on left
              </li>
            </ul>
          </div>

          <div>
            <div class="diagram">
              <Picture
                src={trailRightOfWay}
                alt="Trail right of way technical diagram"
                class="image"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <div>
      <LeaveNoTrace />
    </div>
  </main>
</Layout>

<style>
  .rules-summary {
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
    padding-block: 3rem;
  }

  .rules-summary .grid {
    display: grid;
    gap: 2rem;
  }

  .rules-summary-card {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 2rem;
  }

  .rules-summary-card h3,
  .additional-rules h3 {
    margin: 0;
    border-bottom: 1px solid var(--color-border-muted);
    padding-bottom: 0.5rem;
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .rules-summary-card .rows {
    display: grid;
    gap: 0.5rem;
  }

  .rules-summary-card .rows div {
    display: flex;
    justify-content: space-between;
  }

  .rules-summary-card span,
  p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-label);
    font-size: 0.75rem;
    line-height: var(--leading-body);
    text-transform: uppercase;
  }

  .rules-summary-card span:last-child,
  p {
    font-weight: 900;
  }

  .rules-heading {
    margin-bottom: 4rem;
    --section-heading-title-size: clamp(2.25rem, 6vw, 3.75rem);
    --section-heading-title-leading: normal;
  }

  .ordinance-card {
    display: grid;
    gap: 1.5rem;
    background: var(--color-surface);
    padding: 2rem;
    transition: background-color var(--duration-fast);
  }

  .ordinance-card:hover {
    background: var(--color-page);
  }

  .ordinance-card span {
    border: 1px solid color-mix(in oklab, var(--color-brand-strong) 20%, transparent);
    color: var(--color-brand-strong);
    padding: 0.25rem 0.5rem;
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
  }

  .ordinance-card h3 {
    margin: 0 0 0.5rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
    transition: color var(--duration-fast);
  }

  .ordinance-card:hover h3 {
    color: var(--color-brand-strong);
  }

  .ordinance-card p,
  .additional-rules p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .additional-rules {
    display: grid;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .additional-rules > div {
    display: grid;
    gap: 2rem;
  }

  .right-of-way {
    background: var(--color-surface-inverse);
    color: var(--color-text-inverse);
    padding-block: var(--space-section);
  }

  .right-of-way .layout {
    display: grid;
    align-items: center;
    gap: 4rem;
  }

  .right-of-way .copy {
    --section-heading-gap: 2rem;
  }

  .right-of-way ul {
    display: grid;
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .right-of-way li {
    border-left: 2px solid var(--color-accent);
    color: var(--color-text-inverse-muted);
    padding: 0.25rem 0 0.25rem 1rem;
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .right-of-way .diagram {
    border: 1px solid var(--color-border-inverse);
    background: color-mix(in oklab, var(--color-text-inverse) 5%, transparent);
    padding: 2rem;
  }

  :global(.right-of-way .image) {
    width: 100%;
    height: auto;
    filter: brightness(2);
  }

  @media (min-width: 48rem) {
    .rules-summary .grid,
    .additional-rules > div {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .rules-summary .grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .right-of-way .layout {
      grid-template-columns: 5fr 7fr;
    }
  }
</style>
