---
import Layout from "@layouts/Layout.astro";
import LeaveNoTraceSmall from "@components/LeaveNoTraceSmall.astro";

const faqs = [
  {
    id: "01",
    tag: "Getting Around",
    question: "How do I find my way around UVP? I am always getting lost.",
    answer:
      'Please download the <a class="text-link" href="/visit/">map</a> or take a picture of our trail map before you head out. Always note your specific parking lot location.',
  },
  {
    id: "02",
    tag: "Planning",
    question: "What are the official park hours?",
    answer:
      "WINTER (Nov 1 — Apr 30): 5 a.m. to 9 p.m. SUMMER (May 1 — Oct 31): 5 a.m. to 10 p.m.",
  },
  {
    id: "03",
    tag: "Planning",
    question: "Where can I park my car?",
    answer:
      'Consult the <a class="text-link" href="/visit/">visit</a> page for verified trailhead coordinates and parking capacity.',
  },
  {
    id: "04",
    tag: "Amenities",
    question: "Are there bathroom facilities available?",
    answer:
      "Portable restrooms are available at Vindicator and South Rockrimmon parking lots.",
  },
  {
    id: "05",
    tag: "Wildlife",
    question: "What wildlife will I encounter?",
    answer:
      "Deer, bobcat, bear, mountain lions, and rattlesnakes are active within the wildland. Never engage with wildlife. Respect their habitat by staying on trails and giving abundant space.",
  },
  {
    id: "06",
    tag: "Safety",
    question: "What should I do if I see a rattlesnake?",
    answer:
      "Stay calm, maintain distance, and do not agitate. UVP is an active wildlife habitat; stay on designated trails to minimize encounters.",
  },
  {
    id: "07",
    tag: "Getting Involved",
    question: "How do I get involved with Ute Valley Park?",
    answer:
      'Visit our <a class="text-link" href="/volunteer/">volunteer</a> page to register for upcoming volunteer events.',
  },
];
---

<Layout
  title="FAQ"
  description="Read frequently asked questions about Ute Valley Park including hours, parking, wildlife safety, and volunteer opportunities."
>
  <main class="page">
    <!-- FAQ Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            Common Questions
          </span>
        </div>

        <h1 class="page-title">
          Frequently <br /> Asked <br />
          <span>Questions.</span>
        </h1>

        <p class="page-intro">
          Common questions about visiting and enjoying Ute Valley Park.
        </p>
      </div>
    </section>

    <!-- FAQ Grid -->
    <section class="page-section page-section--muted">
      <div class="faq-section">
        <div class="feature-grid feature-grid--two feature-grid--three">
          {
            faqs.map((faq) => (
              <div class="faq-card">
                <div class="content">
                  <div class="meta">
                    <span>
                      [{faq.id}]
                    </span>
                    <span>
                      {faq.tag}
                    </span>
                  </div>
                  <h3>
                    {faq.question}
                  </h3>
                  <div
                    class="answer"
                    set:html={faq.answer}
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div>
      <LeaveNoTraceSmall />
    </div>
  </main>
</Layout>

<style>
  .faq-section {
    width: min(100%, var(--container-wide));
    margin-inline: auto;
  }

  .faq-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: var(--color-surface);
    padding: 2rem;
    transition: background-color var(--duration-fast);
  }

  .faq-card:hover {
    background: var(--color-page);
  }

  .faq-card .content {
    display: grid;
    gap: 1rem;
  }

  .faq-card .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .faq-card .meta span:first-child {
    color: var(--color-border);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    transition: color var(--duration-fast);
  }

  .faq-card:hover .meta span:first-child {
    color: var(--color-brand-strong);
  }

  .faq-card .meta span:last-child {
    border: 1px solid var(--color-border-muted);
    color: var(--color-text-subtle);
    padding: 0.125rem 0.5rem;
    font-family: var(--font-label);
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition:
      border-color var(--duration-fast),
      color var(--duration-fast);
  }

  .faq-card:hover .meta span:last-child {
    border-color: var(--color-brand-strong);
    color: var(--color-brand-strong);
  }

  .faq-card h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
    transition: color var(--duration-fast);
  }

  .faq-card:hover h3 {
    color: var(--color-brand-strong);
  }

  .faq-card .answer {
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .faq-card .answer :global(p) {
    margin: 0;
  }

  @media (min-width: 64rem) {
    .faq-section {
      width: min(100% - (var(--space-page-x) * 2), var(--container-wide));
    }
  }
</style>
