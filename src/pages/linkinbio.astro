---
import Layout from "@layouts/Layout.astro";
import VolunteerItem from "@components/VolunteerItem.vue";
import SocialLinks from "@components/SocialLinks.astro";

import { Image } from "astro:assets";

import { getCollection } from "astro:content";
import { byPriorityDesc, getUpcomingVolunteerEvents } from "@/utils/content";
const upcomingVolunteerEvents = await getUpcomingVolunteerEvents();
const meetingLocations = await getCollection("trailheads");
const links = await getCollection("links");
const wishlist = await getCollection("wishlist", ({ data }) => {
  return data.quantityNeeded > 0;
});
const sortedLinks = [...links].sort(byPriorityDesc);

import Logo from "@/assets/images/logos/logo-medium.jpg";
---

<Layout
  title="Link in Bio"
  description="Quick links from Friends of Ute Valley Park including volunteer events, resources, and current wishlist needs."
>
  <main class="link-page">
    <div class="link-card">
      <!-- Header -->
      <div class="link-card__header">
        <div class="link-card__identity">
          <div class="link-card__logo-frame">
            <Image src={Logo} alt="FUVP Seal" width="80" height="80" />
          </div>
          <div class="link-card__title-block">
            <h1>
              Friends of <br />
              <span>Ute Valley Park.</span>
            </h1>
            <p>
              Ute Valley Park — Quick Links
            </p>
          </div>
          <div class="link-card__social">
            <SocialLinks />
          </div>
        </div>
      </div>

      <!-- Active Operations -->
      {
        upcomingVolunteerEvents.length > 0 && (
          <div class="link-section">
            <div class="link-section__heading link-section__heading--accent">
              <span />
              <h2>
                Volunteer Opportunities
              </h2>
            </div>
            <div class="link-section__stack">
              {upcomingVolunteerEvents.map((volunteerEvent) => (
                <div class="link-section__inset">
                  <VolunteerItem
                    meetingLocations={meetingLocations}
                    volunteerEvent={volunteerEvent}
                    client:idle
                  />
                </div>
              ))}
            </div>
          </div>
        )
      }

      <!-- Quick Links -->
      <div class="link-section link-section--muted">
        <div class="link-section__heading">
          <span></span>
          <h2>
            Useful Links
          </h2>
        </div>
        <div class="quick-links">
          {
            sortedLinks.map((link) => (
              <a
                href={link.data.link}
                target="_blank"
                rel="noopener noreferrer nofollow"
                class="quick-link"
              >
                <span>
                  {link.data.title}
                </span>
                <span>
                  →
                </span>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Technical Wishlist -->
      <div class="link-section">
        <div class="link-section__heading link-section__heading--neutral">
          <span></span>
          <h2>
            Our Wishlist
          </h2>
        </div>
        <p class="wishlist-intro">
          The following items are needed for our work in the park. Please <a
            href="/contact/"
            >contact us</a
          > to coordinate delivery.
        </p>

        <div class="wishlist-grid">
          {
            wishlist.map((item) => (
              <div class="wishlist-item">
                <div class="wishlist-item__media">
                  <Image
                    src={item.data.image}
                    alt={item.data.imageAlt}
                    width="200"
                    height="200"
                    class="wishlist-item__image"
                  />
                  <div class="wishlist-item__quantity">
                    {item.data.quantityNeeded} REQUIRED
                  </div>
                </div>
                <div>
                  <h3>
                    <a
                      href={item.data.link}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                    >
                      {item.data.title}
                    </a>
                  </h3>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Footer -->
      <div class="link-card__footer">
        <p>
          Friends of Ute Valley Park — 2026 Active Wildland
        </p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .link-page {
    min-height: 100vh;
    background: var(--color-page);
    padding-block: 2rem;
  }

  .link-card {
    width: min(100% - 2rem, 36rem);
    margin-inline: auto;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    box-shadow: 0 1px 2px rgb(0 0 0 / 5%);
  }

  .link-card__header,
  .link-section {
    border-bottom: 1px solid var(--color-border);
    padding: 2rem;
  }

  .link-card__header,
  .link-section--muted {
    background: color-mix(in oklab, var(--color-page) 50%, transparent);
  }

  .link-card__identity {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .link-card__logo-frame {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 0.25rem;
    box-shadow: 0 1px 2px rgb(0 0 0 / 5%);
  }

  .link-card__title-block {
    display: grid;
    gap: 0.5rem;
  }

  .link-card__title-block h1 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .link-card__title-block h1 span {
    color: var(--color-brand-strong);
  }

  .link-card__title-block p,
  .link-card__footer p {
    margin: 0;
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .link-card__title-block p {
    color: var(--color-text-subtle);
  }

  .link-card__social {
    display: flex;
    width: 100%;
    justify-content: center;
    border-top: 1px solid var(--color-border-muted);
    padding-top: 1rem;
  }

  .link-section__heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .link-section__heading span {
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: var(--color-brand-strong);
  }

  .link-section__heading--accent span {
    background: var(--color-accent-strong);
  }

  .link-section__heading--neutral span {
    background: var(--color-text-subtle);
  }

  .link-section__heading h2 {
    margin: 0;
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .link-section__heading--accent h2 {
    color: var(--color-accent-strong);
  }

  .link-section__heading--neutral h2 {
    color: var(--color-text-subtle);
  }

  .link-section__stack {
    display: grid;
    gap: 2rem;
  }

  .link-section__inset {
    border-left: 2px solid var(--color-border-muted);
    padding-left: 1rem;
  }

  .quick-links {
    display: grid;
    gap: 1rem;
  }

  .quick-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: inherit;
    padding: 1.25rem;
    text-decoration: none;
    transition:
      border-color 200ms,
      transform 200ms;
  }

  .quick-link:hover {
    border-color: var(--color-brand-strong);
  }

  .quick-link:active {
    transform: scale(0.96);
  }

  .quick-link span:first-child,
  .wishlist-item h3 {
    color: var(--color-text-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 200ms;
  }

  .quick-link span:last-child {
    color: var(--color-border);
    transition: color 200ms;
  }

  .quick-link:hover span {
    color: var(--color-brand-strong);
  }

  .wishlist-intro {
    margin: 0 0 2rem;
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: var(--text-label);
    line-height: var(--leading-body);
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .wishlist-intro a {
    color: var(--color-brand-strong);
    font-weight: 900;
    text-decoration: underline;
  }

  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--color-border-muted);
    background: var(--color-border-muted);
  }

  .wishlist-item {
    display: grid;
    gap: 1rem;
    background: var(--color-surface);
    padding: 1rem;
    transition: background-color 200ms;
  }

  .wishlist-item:hover {
    background: var(--color-page);
  }

  .wishlist-item__media {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--color-border-muted);
    background: var(--color-surface-muted);
  }

  :global(.wishlist-item__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms;
  }

  .wishlist-item__quantity {
    position: absolute;
    bottom: 0.5rem;
    left: 0.5rem;
    background: var(--color-surface-inverse);
    color: var(--color-text-inverse);
    padding: 0.125rem 0.5rem;
    font-family: var(--font-label);
    font-size: 0.5rem;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .wishlist-item h3 {
    margin: 0;
    letter-spacing: 0;
  }

  .wishlist-item h3 a {
    color: inherit;
    text-decoration: none;
  }

  .wishlist-item:hover h3 {
    color: var(--color-brand-strong);
  }

  .link-card__footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface-inverse);
    padding: 2rem;
    text-align: center;
  }

  .link-card__footer p {
    color: var(--color-text-subtle);
    font-size: 0.5rem;
    letter-spacing: 0.4em;
  }
</style>
