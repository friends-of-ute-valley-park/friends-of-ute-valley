---
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="Privacy Policy"
  description="Read the Friends of Ute Valley Park privacy policy and how we collect, use, and protect website and contact data."
>
  <main class="page">
    <!-- Privacy Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            Our Privacy Policy
          </span>
        </div>

        <h1 class="page-title">
          Your <br />
          <span>Privacy.</span>
        </h1>

        <p class="page-intro">
          How we collect, use, and protect your information.
        </p>
      </div>
    </section>

    <!-- Policy Content -->
    <section class="page-section">
      <div class="page-section__inner page-section__inner--narrow">
        <div class="privacy-sections">
          <div class="privacy-section">
            <div class="number">
              Section 1
            </div>
            <div class="content">
              <h2>
                Information Collection
              </h2>
              <div class="privacy-prose">
                <p>
                  Friends of Ute Valley Park ("we", "us", "our") is committed to
                  protecting the privacy of our website visitors. We collect
                  limited personal data strictly for communication and improving
                  our services.
                </p>
                <ul>
                  <li>
                    <span>Analytics Data</span>
                    We collect anonymized analytics data to optimize site performance.
                    No personally identifiable information (PII) is captured during
                    this process. We do not employ third-party tracking cookies.
                  </li>
                  <li>
                    <span>Communication Forms</span>
                    Name and email addresses are collected via contact and volunteer
                    forms. This data is utilized exclusively for addressing specific
                    inquiries.
                  </li>
                  <li>
                    <span>Subscriptions</span>
                    Newsletter enrollment requires name and email data. Subscribers
                    may opt-out at any time via the provided technical links.
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <div class="privacy-section">
            <div class="number">
              Section 2
            </div>
            <div class="content">
              <h2>
                Data Disclosure
              </h2>
              <div class="privacy-prose">
                <p>
                  We maintain a strict zero-distribution policy regarding
                  personal data.
                </p>
                <ul>
                  <li>
                    <span>We Don't Sell Your Data</span>
                    We will never sell or lease personal information to third-party
                    entities for any reason.
                  </li>
                  <li>
                    <span>Service Facilitation</span>
                    Third-party providers (e.g., Turnstile) may process data
                    only to fulfill specific functional requests such as spam
                    prevention and are contractually bound to privacy standards.
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <div class="privacy-section">
            <div class="number">
              Section 3
            </div>
            <div class="content">
              <h2>
                Security & Integrity
              </h2>
              <div class="privacy-prose">
                <p>
                  We implement technical measures to protect data from
                  unauthorized access. However, absolute security of internet
                  transmissions cannot be guaranteed. We periodically review our
                  protocols to maintain high-integrity standards.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="privacy-update">
          <div class="content">
            <div>
              <p>
                Last Update
              </p>
              <p>
                March 31, 2023
              </p>
            </div>
            <a
              href="mailto:contact@fuvp.org"
              >Contact Us →</a
            >
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .privacy-sections {
    display: grid;
    gap: 4rem;
  }

  .privacy-section {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
  }

  .privacy-section .number {
    flex-shrink: 0;
    color: var(--color-border);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
  }

  .privacy-section .content {
    display: grid;
    gap: 1rem;
  }

  .privacy-section .content h2 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .privacy-prose {
    color: var(--color-text-muted);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .privacy-prose p {
    margin: 0 0 1rem;
  }

  .privacy-prose ul {
    display: grid;
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .privacy-prose li {
    border-left: 2px solid var(--color-border-muted);
    padding: 0.25rem 0 0.25rem 1rem;
  }

  .privacy-prose li span {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--color-text-strong);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .privacy-update {
    margin-top: 6rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 2rem;
  }

  .privacy-update .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .privacy-update p {
    margin: 0;
    font-family: var(--font-label);
    text-transform: uppercase;
  }

  .privacy-update p:first-child {
    color: var(--color-text-subtle);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
  }

  .privacy-update p:last-child {
    color: var(--color-text-strong);
    font-size: var(--text-body-small);
    font-weight: 900;
  }

  .privacy-update a {
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (min-width: 48rem) {
    .privacy-section {
      flex-direction: row;
    }

    .privacy-update .content {
      flex-direction: row;
    }
  }
</style>
