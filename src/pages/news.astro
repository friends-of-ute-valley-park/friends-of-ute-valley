---
import Layout from '@layouts/Layout.astro';
import Card from '@components/Card.astro';

import { getPublishedNewsEntries } from '@/utils/content';
const publishedNewsEntries = await getPublishedNewsEntries();
---

<Layout
  title="News"
  description="Latest Friends of Ute Valley Park news, announcements, and stewardship updates from Ute Valley Park in Colorado Springs."
>
  <main class="page">
    <!-- News Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <h1 class="page-title">
          Latest <br /> <span>News.</span>
        </h1>

        <p class="page-intro">
          News and updates from Ute Valley Park.
        </p>
      </div>
    </section>

    <!-- News Grid -->
    <section class="page-section page-section--muted">
      <div class="page-section__inner">
        <div class="news-list">
          {
            publishedNewsEntries
              .map((post) => (
                <Card 
                  title={post.data.title} 
                  previewText={post.data.previewText} 
                  image={post.data.coverImage} 
                  href={post.id} 
                  publishedOn={post.data.publishedOn} 
                />
              ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .news-list {
    display: grid;
    gap: 4rem;
  }

  @media (min-width: 48rem) {
    .news-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .news-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
