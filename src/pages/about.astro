---
import LeaveNoTraceSmall from "@components/LeaveNoTraceSmall.astro";
import TeamList from "@components/TeamList.astro";
import Layout from "@layouts/Layout.astro";
import OldPhotos from "@components/OldPhotos.astro";
import StatsCard from "@components/StatsCard.astro";
---

<Layout
  title="About"
  description="Learn about Friends of Ute Valley Park, our mission, history, and volunteer-led work to protect and maintain Ute Valley Park in Colorado Springs."
>
  <main class="page about-page">
    <!-- Archival Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            About Us
          </span>
        </div>

        <h1 class="page-title title">
          Our Story <br /> & <span>Mission.</span>
        </h1>

        <div class="layout">
          <div class="prose-content copy">
            <p>
              Friends of Ute Valley Park (FUVP) is an officially recognized
              "Friends" organization dedicated to maintaining, preserving, and
              providing education for Ute Valley Park in Colorado Springs.
            </p>
            <p>
              We work in partnership with the city's Parks, Recreation, and
              Cultural Services Department to care for this treasured community
              resource, ensuring its wildland character remains intact for
              future generations.
            </p>
          </div>
          <div class="logo-card">
            <img
              src="/images/logo-medium.jpg"
              alt="Friends of Ute Valley logo"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Impact Data -->
    <section class="about-impact">
      <StatsCard />
    </section>

    <!-- Structural Records -->
    <section class="about-records">
      <div class="page-section__inner">
        <div class="layout">
          <div class="about-toc">
            <div class="sticky">
              <h3>
                About Our Work
              </h3>
              <nav class="links" data-about-toc>
                <a
                  href="#history"
                  class="link"
                  >01. Our History</a
                >
                <a
                  href="#stewardship"
                  class="link"
                  >02. How We Care for the Park</a
                >
                <a
                  href="#awards"
                  class="link"
                  >03. Awards & Recognition</a
                >
                <a
                  href="#structure"
                  class="link"
                  >04. Our Structure</a
                >
              </nav>
            </div>
          </div>

          <div class="content">
            <!-- History -->
            <div id="history" class="about-record section-heading">
              <h2 class="section-heading__title">
                Our <span>History.</span>
              </h2>
              <div class="prose-content">
                <p>
                  FUVP was formed in 2012 when we learned the City had an
                  opportunity to purchase an additional 205 acres to expand Ute
                  Valley Park. The City hoped to fund the purchase through the
                  Trails, Open Spaces, and Parks (TOPS) program.
                </p>
                <p>
                  With the help of FUVP, the Trust for Public Land, and TOPS,
                  the city was able to acquire the land in 2014-15. FUVP raised
                  $110,000 in just 3.5 months to contribute to the purchase,
                  demonstrating unprecedented community support.
                </p>
              </div>
            </div>

            <!-- Stewardship -->
            <div id="stewardship" class="about-record section-heading">
              <h2 class="section-heading__title">
                How We <span>Care for the Park.</span>
              </h2>
              <div class="stewardship-grid">
                {
                  [
                    "Conducts trail maintenance twice a month",
                    "Leads special maintenance and cleanup projects",
                    "Raises funds to support park improvements",
                    "Provides education about the park's ecology and history",
                    "Advocates for the protection of UVP",
                  ].map((item, i) => (
                    <div class="stewardship-card">
                      <span>
                        [{String(i + 1).padStart(2, "0")}]
                      </span>
                      <p>
                        {item}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>

            <!-- Awards -->
            <div id="awards" class="about-record section-heading">
              <h2 class="section-heading__title">
                Awards & <span>Recognition.</span>
              </h2>
              <div class="award-list">
                {
                  [
                    {
                      year: "2023",
                      title:
                        "Drew Town Parks, Recreation, and Cultural Services Volunteer of the Year Nomination",
                    },
                    { year: "2022", title: "TOSC Best Friends group" },
                    {
                      year: "2020",
                      title: "Great Outdoors Colorado (GOCO) Award",
                    },
                    {
                      year: "2020",
                      title: "Parks & Recreation Volunteer of the Year",
                    },
                    {
                      year: "2019",
                      title: "David J Collas Community Service Award",
                    },
                    {
                      year: "2014",
                      title: "City Council Resolution Thanking FUVP",
                    },
                    { year: "2014", title: "Friends Group of the Year" },
                    { year: "2013", title: "TOSC Stewardship Award" },
                    {
                      year: "",
                      title: "Dan Woods SuperGroup MVP Award",
                    },
                  ].map((award) => (
                    <div class="item">
                      <span>
                        {award.year}
                      </span>
                      <span>
                        {award.title}
                      </span>
                    </div>
                  ))
                }
              </div>
            </div>

            <!-- Structure -->
            <div id="structure" class="about-record section-heading">
              <h2 class="section-heading__title">
                Our <span>Structure.</span>
              </h2>
              <div class="structure-card">
                <div class="content">
                  <p>
                    FUVP currently operates as a committee under the fiscal
                    sponsorship of the Trails and Open Spaces Coalition (TOSC)
                    through June 30, 2026.
                  </p>
                  <p>
                    We are transitioning away from that sponsorship and have
                    opened a new PO Box for direct correspondence.
                  </p>
                  <div class="facts">
                    <div>
                      <p>
                        Status
                      </p>
                      <p>
                        Transitioning
                      </p>
                    </div>
                    <div>
                      <p>
                        Mail
                      </p>
                      <p>
                        PO Box 50122
                      </p>
                    </div>
                  </div>
                </div>
                <div class="marker"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Team -->
    <section class="about-team">
      <TeamList />
    </section>

    <!-- Photographic Evidence -->
    <section class="about-gallery">
      <div class="page-section__inner">
        <div class="heading section-heading">
          <h2 class="section-heading__title">
            Park <span>Gallery.</span>
          </h2>
        </div>
        <OldPhotos />
      </div>
    </section>

    <!-- Technical Surveys -->
    <section class="survey-report">
      <div class="inner l-container">
        <div class="card">
          <div class="code"></div>
          <h2>
            Coal Mine <span>Survey Report.</span>
          </h2>
          <div class="media">
            <img
              src="/images/colorado-land-survey-preview.jpg"
              alt="Coal mine survey"
            />
          </div>
          <div class="footer">
            <div>
              <p>
                1983 Colorado Front Range Inactive Coal Mine Data (El Paso
                County). Historical geological report regarding subsurface
                conditions and previous industrial operations.
              </p>
            </div>
            <a
              href="/images/maps/colorado-springs-coal-mine-survey.pdf"
              download
              class="button button--brand"
            >
              Download Report (14.8MB)
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="about-lnt">
      <LeaveNoTraceSmall />
    </div>
  </main>
</Layout>

<script>
  const toc = document.querySelector<HTMLElement>("[data-about-toc]");
  if (toc) {
    const links = Array.from(
      toc.querySelectorAll<HTMLAnchorElement>('a[href^="#"]'),
    );
    const linkById = new Map<string, HTMLAnchorElement>();
    for (const link of links) {
      const href = link.getAttribute("href");
      const id = href ? href.slice(1) : "";
      if (id) {
        linkById.set(id, link);
      }
    }

    const setActive = (id: string) => {
      links.forEach((link) => {
        link.classList.remove("link active");
        link.removeAttribute("aria-current");
      });
      const active = linkById.get(id);
      if (active) {
        active.classList.add("link active");
        active.setAttribute("aria-current", "location");
      }
    };

    const sections = Array.from(linkById.keys())
      .map((id) => document.getElementById(id))
      .filter((section): section is HTMLElement => section !== null);

    if (sections.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
            }
          });
        },
        {
          rootMargin: "-30% 0px -70% 0px",
          threshold: 0,
        },
      );

      sections.forEach((section) => observer.observe(section));

      const initialId =
        (location.hash && location.hash.slice(1)) || sections[0].id;
      setActive(initialId);
    }
  }
</script>

<style>
  .about-hero .title {
    margin-bottom: 3rem;
  }

  .about-hero .layout {
    display: grid;
    align-items: start;
    gap: 3rem;
  }

  .about-hero .copy {
    color: var(--color-text-muted);
    font-size: var(--text-body-large);
  }

  .about-hero .logo-card {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 2rem;
  }

  .about-hero .logo-card img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform var(--duration-slow);
  }

  .about-impact,
  .about-team,
  .about-lnt {
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
  }

  .about-records,
  .about-gallery,
  .survey-report {
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-section);
  }

  .about-records .layout {
    display: grid;
    gap: 4rem;
  }

  .about-toc {
    display: none;
  }

  .about-toc .sticky {
    position: sticky;
    top: 6rem;
    display: grid;
    gap: 2rem;
  }

  .about-toc h3 {
    margin: 0;
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .about-toc .links,
  .about-records .content,
  .about-record {
    display: grid;
  }

  .about-toc .links {
    gap: 1rem;
  }

  .about-toc .link {
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color var(--duration-fast);
  }

  .about-toc .link:hover,
  .about-toc .link.active {
    color: var(--color-brand);
  }

  .about-records .content {
    gap: 6rem;
  }

  .about-record {
    gap: 2rem;
    scroll-margin-top: 6rem;
  }

  .about-record,
  .about-gallery .heading {
    --section-heading-title-size: clamp(2.25rem, 6vw, 3rem);
    --section-heading-title-leading: normal;
  }

  .survey-report h2 span {
    color: var(--color-brand-strong);
    font-style: italic;
  }

  .stewardship-grid {
    display: grid;
    gap: 1rem;
  }

  .stewardship-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 1.5rem;
    transition: border-color var(--duration-fast);
  }

  .stewardship-card:hover {
    border-color: var(--color-brand-strong);
  }

  .stewardship-card span {
    color: var(--color-accent-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
  }

  .stewardship-card p {
    margin: 0;
    color: var(--color-text-strong);
    font-size: var(--text-body-small);
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .award-list {
    border: 1px solid var(--color-border);
  }

  .award-list .item {
    display: flex;
    align-items: center;
    gap: 2rem;
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem;
    transition: background-color var(--duration-fast);
  }

  .award-list .item:last-child {
    border-bottom: 0;
  }

  .award-list .item:hover {
    background: var(--color-surface);
  }

  .award-list .item span:first-child {
    min-width: 3rem;
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: var(--text-body-large);
    font-weight: 900;
  }

  .award-list .item span:last-child {
    color: var(--color-text-muted);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .structure-card {
    position: relative;
    overflow: hidden;
    background: var(--color-surface-inverse);
    color: var(--color-text-inverse);
    padding: clamp(2rem, 4vw, 3rem);
  }

  .structure-card .content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.5rem;
  }

  .structure-card .content > p {
    margin: 0;
    color: var(--color-text-inverse-muted);
    font-size: var(--text-body-large);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .structure-card .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    border-top: 1px solid var(--color-surface-inverse-muted);
    padding-top: 2rem;
  }

  .structure-card .facts p {
    margin: 0;
    font-family: var(--font-label);
    text-transform: uppercase;
  }

  .structure-card .facts p:first-child {
    margin-bottom: 0.25rem;
    color: var(--color-text-subtle);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
  }

  .structure-card .facts p:last-child {
    color: var(--color-text-inverse);
    font-size: 0.75rem;
    font-weight: 900;
  }

  .structure-card .marker {
    position: absolute;
    top: 0;
    right: 0;
    width: 8rem;
    height: 8rem;
    background: color-mix(in oklab, var(--color-brand-strong) 20%, transparent);
    transform: translate(50%, -50%) rotate(45deg);
  }

  .about-gallery .heading {
    margin-bottom: 3rem;
  }

  .survey-report {
    background: var(--color-surface-muted);
  }

  .survey-report .inner {
    --l-container-max: 56rem;
  }

  .survey-report .card {
    position: relative;
    border: 2px solid var(--color-border-strong);
    background: var(--color-surface);
    padding: clamp(2rem, 4vw, 3rem);
  }

  .survey-report h2 {
    margin: 0 0 2rem;
    border-bottom: 1px solid var(--color-border-muted);
    padding-bottom: 1rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .survey-report .media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface-muted);
    margin-bottom: 2rem;
  }

  .survey-report .media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow);
  }

  .survey-report .footer {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .survey-report .footer > div {
    max-width: 28rem;
  }

  .survey-report .footer p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  @media (min-width: 48rem) {
    .stewardship-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .survey-report .footer {
      flex-direction: row;
      align-items: flex-end;
    }
  }

  @media (min-width: 64rem) {
    .about-hero .layout {
      grid-template-columns: 7fr 5fr;
    }

    .about-records .layout {
      grid-template-columns: 4fr 8fr;
    }

    .about-toc {
      display: block;
      border-right: 1px solid var(--color-border);
      padding-right: 3rem;
    }
  }
</style>
