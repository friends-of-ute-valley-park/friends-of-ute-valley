---
import { Image } from "astro:assets";

import Layout from "../layouts/Layout.astro";
import CheckBadgeIcon from "~icons/heroicons/check-badge";

const benefits = [
  "Expanded trails",
  "Trail maintenance",
  "Wayfinding signage and facilities",
  "New tools",
  "Educational programs",
  "Volunteer appreciation",
];
import VolunteerHeroImage from "../assets/images/volunteer-hero.jpg";
---

<Layout
  title="Donate"
  description="Support Friends of Ute Valley Park with a tax-deductible donation that funds trail maintenance, restoration, and stewardship programs."
>
  <main class="page donate-page">
    <!-- Fiscal Hero -->
    <section class="donate-hero">
      <div class="layout">
        <!-- Message Column -->
        <div class="message">
          <div class="stack">
            <div class="page-eyebrow">
              <span>
                Support Us
              </span>
            </div>

            <h1 class="page-title">
              Support <br /> The <br />
              <span>Wildland.</span>
            </h1>

            <div class="intro">
              <p>
                Your tax-deductible gift directly funds trail maintenance,
                invasive species management, educational programs, and the
                stewardship that keeps Ute Valley Park beautiful for everyone.
              </p>
            </div>

            <div class="cta">
              <a
                href="https://trailsandopenspacecoalition-bloom.kindful.com/embeds/65db98e0-d794-4712-bf37-144689d58de3"
                class="button button--brand"
              >
                Donate Now
              </a>
            </div>
          </div>
        </div>

        <!-- Visual Context -->
        <div class="media">
          <Image
            src={VolunteerHeroImage}
            alt="Park scenery"
            class="image media-cover"
            width={1200}
          />
          <div class="matte media-matte"></div>
        </div>
      </div>
    </section>

    <!-- Fiscal Sponsorship Info -->
    <section class="page-section">
      <div class="page-section__inner">
        <div class="donate-info">
          <div class="main">
            <div>
              <h2>
                How Your <span>Gift Helps.</span>
              </h2>
              <p>
                Friends of Ute Valley Park operates under the fiscal sponsorship
                of the Trails and Open Space Coalition (TOSC), a 501(c)(3)
                nonprofit. This ensures your donation is used effectively.
              </p>
            </div>

            <div class="columns">
              <div class="column">
                  <h4>
                      What We
                    <span>Need.</span>
                  </h4>
                <ul class="benefit-list">
                  {
                    benefits.map((benefit) => (
                      <li>
                        <CheckBadgeIcon class="icon" />
                        <span>
                          {benefit}
                        </span>
                      </li>
                    ))
                  }
                </ul>
              </div>
              <div class="column">
                  <h4>
                      Our
                    <span>Partner.</span>
                  </h4>
                <div class="partner-note">
                  <p>
                    All donations are processed via TOSC for regulatory
                    compliance and transparency.
                  </p>
                  <div>
                    <span>Entity Status</span>
                    <span>501(c)(3) Tax-Exempt</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="aside">
            <div class="tosc-card">
              <div class="logo">
                <svg
                  id="Layer_1"
                  class="svg"
                  version="1.1"
                  xmlns="http://www.w3.org/2000/svg"
                  x="0"
                  y="0"
                  viewBox="0 0 484.2 201.5"
                  xml:space="preserve"
                >
                  <title>Trails and Open Space Logo</title>
                  <path
                    fill="currentColor"
                    d="M234.9 43.4h-18.5v135.4h-17.2V43.4h-17.6V26.3h53.3v17.1zM269 178.9c-13 0-19.4-6.4-19.4-19.4V45.7c0-13 6.4-19.4 19.4-19.4h18.5c13 0 19.4 6.4 19.4 19.4v113.7c0 13-6.4 19.4-19.4 19.4H269zm-2.3-17.2h23.1V43.4h-23.1v118.3zM342.4 124.9v36.8h23.1v-36.4c0-3.4-.2-5.5-.7-6.4-.5-.9-1.6-1.8-3.4-2.5l-25.8-9.8c-4.1-1.6-6.9-3.9-8.2-7.1-1.4-3.2-2.1-8.7-2.1-16.5V45.7c0-13 6.4-19.4 19.4-19.4h18.5c13 0 19.4 6.4 19.4 19.4V81h-17.2V43.4h-23.1v40.3c0 3.9.2 6.2.9 7.1.5.9 1.8 1.8 4.1 2.7l23.6 8.7c4.8 1.6 7.8 3.9 9.4 6.6s2.3 7.3 2.3 13.7v36.8c0 13-6.4 19.4-19.4 19.4h-18.5c-13 0-19.4-6.4-19.4-19.4v-34.5h17.1zM458.4 159.4c0 13-6.4 19.4-19.4 19.4h-18.5c-13 0-19.4-6.4-19.4-19.4V45.7c0-13 6.4-19.4 19.4-19.4H439c13 0 19.4 6.4 19.4 19.4v38.2h-17.2V43.4h-23.1v118.3h23.1v-40.9h17.2v38.6z"
                  ></path>
                  <g>
                    <path
                      fill="currentColor"
                      d="M114.2 92.4l-9.3.5-1.8-11-12.4-18.3s-5.6 10.5-6.4 12.2c-2.9 6.5-10.8 22.6-1 36.1 2.1 3 5 5.1 10.2 5.1 1.4 0 2.8-.2 4.1-.6 3.4-.9 7-4.2 31.9-11.4l-15.3-12.6zM127.6 80.5l36.3 24.8c0-.9 0-1.7.1-2.6.1-4.3-.7-8.8-.9-10.8l-30.5-20.1-5 8.7zM68.2 78.9L48.9 111c2.1.7 7.2 2.6 9.6 3.2l17.9-29.7-8.2-5.6z"
                    ></path>
                    <path
                      fill="currentColor"
                      d="M157.6 104.9L92.2 61 106 79.9l1.9 9.2 7.3-.6 19.1 15.5c6.2-.6 19-.1 23.3.9zM85.7 118.5c-.3-.4-14.3-13.6-9.7-27.8l-13.3 24.1c6.8 2.1 22.3 3.7 23 3.7zM96.4 124.9c-6.9 5.1-18.7 31.3 19 39.3 18-4.6 44.1-19.7 48.2-55.7-31-1.6-42.9-1.6-67.2 16.4z"
                    ></path>
                    <path
                      d="M43.9 108.9c.5.3 1 .6 1.6.8l21.9-34.9 10.4 6.9 12.9-26.4L125 78.7l7-11 30.1 19.8c-6.8-27.6-31.7-48.1-61.4-48.1-34.9 0-63.1 28.2-63.3 63 0 0 2.7 4.4 6.5 6.5z"
                      fill="#e36a2a"></path>
                    <path
                      fill="currentColor"
                      d="M100.7 26.3c-42.2 0-76.3 34.2-76.3 76.3S58.6 179 100.7 179s76.3-34.2 76.3-76.3-34.1-76.4-76.3-76.4zm49.5 125.8c-6.4 6.4-13.9 11.5-22.3 15-8.6 3.7-17.8 5.5-27.3 5.5s-18.6-1.9-27.3-5.5c-8.3-3.5-15.8-8.6-22.3-15-6.4-6.4-11.5-13.9-15-22.3-3.7-8.6-5.5-17.8-5.5-27.3s1.9-18.6 5.5-27.3c3.5-8.3 8.6-15.8 15-22.3s13.9-11.5 22.3-15c8.6-3.7 17.8-5.5 27.3-5.5s18.6 1.9 27.3 5.5c8.3 3.5 15.8 8.6 22.3 15s11.5 13.9 15 22.3c3.7 8.6 5.5 17.8 5.5 27.3s-1.9 18.6-5.5 27.3c-3.5 8.4-8.5 15.9-15 22.3z"
                    ></path>
                    <path
                      fill="currentColor"
                      d="M83.2 121.6c-31.5-1.9-45-14.3-45.7-14.8 1.9 14.3 5.1 27.1 20.4 42.3 1.4-7.9 10.9-19.6 25.3-27.5z"
                    ></path>
                  </g>
                </svg>
              </div>
              <div>
                <p>
                  TOSC is our fiscal sponsor. All donations are processed
                  through their nonprofit organization.
                </p>
              </div>
            </div>
            <div class="volunteer-donation-card">
              <p>
                Want to donate your time instead?
              </p>
              <a
                href="/volunteer/"
                >Check Volunteer Opportunities →</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .donate-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .donate-hero .layout {
    display: grid;
  }

  .donate-hero .message {
    padding: clamp(3rem, 8vw, 8rem) var(--space-page-x) clamp(5rem, 10vw, 10rem);
  }

  .donate-hero .stack {
    display: grid;
    gap: 2rem;
  }

  .donate-hero .intro {
    max-width: 36rem;
  }

  .donate-hero .intro p,
  .donate-info .main > div > p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-large);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .donate-hero .cta {
    padding-top: 2rem;
  }

  .donate-hero .media {
    position: relative;
    min-height: 28rem;
    overflow: hidden;
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
  }

  .donate-hero .matte {
    --media-matte-border: 1.5rem solid color-mix(in oklab, var(--color-surface) 20%, transparent);
  }

  .donate-info {
    display: grid;
    align-items: start;
    gap: 4rem;
  }

  .donate-info .main {
    display: grid;
    gap: 3rem;
  }

  .donate-info .main h2 {
    margin: 0 0 2rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .donate-info .main h2 span,
  .donate-info .column h4 span {
    color: var(--color-brand-strong);
    font-style: italic;
  }

  .donate-info .columns {
    display: grid;
    gap: 2rem 3rem;
  }

  .donate-info .column {
    display: grid;
    gap: 1rem;
  }

  .donate-info .column h4 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: var(--text-body-small);
    font-weight: 900;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .benefit-list {
    display: grid;
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .benefit-list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  :global(.benefit-list .icon) {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    color: var(--color-accent-strong);
  }

  .benefit-list span {
    color: var(--color-text-strong);
    font-size: var(--text-body-small);
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .partner-note {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--color-border-muted);
    background: var(--color-surface-muted);
    padding: 1.5rem;
  }

  .partner-note p,
  .tosc-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .partner-note div {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .partner-note span {
    font-family: var(--font-label);
    font-size: var(--text-label);
    text-transform: uppercase;
  }

  .partner-note span:last-child {
    font-weight: 900;
  }

  .donate-info .aside {
    display: grid;
    gap: 2rem;
  }

  .tosc-card {
    display: grid;
    gap: 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 2rem;
  }

  .tosc-card .logo {
    display: flex;
    justify-content: center;
  }

  .tosc-card .svg {
    width: 100%;
    height: auto;
    opacity: 0.5;
  }

  .volunteer-donation-card {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--color-border-muted);
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
    padding: 2rem;
  }

  .volunteer-donation-card p {
    margin: 0;
    color: var(--color-text-strong);
    font-size: var(--text-body-small);
    font-weight: 500;
  }

  .volunteer-donation-card a {
    display: inline-block;
    color: var(--color-brand-strong);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (min-width: 48rem) {
    .donate-info .columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .donate-hero .layout {
      grid-template-columns: 7fr 5fr;
    }

    .donate-hero .message {
      border-right: 1px solid var(--color-border);
      padding-inline: var(--space-page-x) 3rem;
    }

    .donate-info {
      grid-template-columns: 8fr 4fr;
    }
  }
</style>
