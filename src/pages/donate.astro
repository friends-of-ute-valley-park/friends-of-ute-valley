---
import { Image } from "astro:assets";

import ContactForm from "../components/ContactForm.vue";
import ZeffyDonationEmbed from "../components/ZeffyDonationEmbed.astro";
import Layout from "../layouts/Layout.astro";
import CheckBadgeIcon from "~icons/heroicons/check-badge";
import BankTransferIcon from "~icons/mdi/bank-transfer";
import BriefcaseCheckIcon from "~icons/mdi/briefcase-check";
import MailboxUpIcon from "~icons/mdi/mailbox-up";
import { TURNSTILE_SITE_KEY } from "astro:env/client";

import VolunteerHeroImage from "../assets/images/volunteer-hero.jpg";

const giftUses = [
  "Tools, safety gear, and supplies for volunteer trail work days",
  "Habitat protection and practical visitor education",
  "Wayfinding signs, stewardship materials, and ongoing park care",
  "Community outreach with City of Colorado Springs partners",
];

const matchDetails = [
  {
    label: "$1 donated",
    value: "$3 for the park",
  },
  {
    label: "Matched through",
    value: "August 31, 2026",
  },
  {
    label: "Challenge cap",
    value: "$2,000",
  },
];

const givingOptions = [
  {
    id: "give-by-mail",
    title: "Mail a check",
    icon: MailboxUpIcon,
    description: "Best for donors who prefer paper records.",
    detail: "Friends of Ute Valley Park, PO Box 50122, Colorado Springs, CO 80919",
    nextStep: "Make checks payable to Friends of Ute Valley Park. Include your return address if you would like a receipt.",
  },
  {
    id: "give-by-bank-transfer",
    title: "Bank transfer",
    icon: BankTransferIcon,
    description: "Best for ACH, wire, or direct deposit arrangements.",
    detail: "Contact us before sending financial details.",
    nextStep: "We will coordinate the right details securely.",
  },
  {
    id: "give-through-workplace",
    title: "Workplace giving",
    icon: BriefcaseCheckIcon,
    description: "Best for matching gifts, sponsorships, Benevity, or volunteer teams.",
    detail: "A Benevity profile is in progress.",
    nextStep: "Tell us what your employer needs and we will help route it.",
  },
];
---

<Layout
  title="Donate"
  description="Support Friends of Ute Valley Park with an online gift, mailed check, direct deposit arrangement, or corporate giving program."
>
  <main class="page">
    <section class="donate-hero page-hero band">
      <div class="hero-shell l-container">
        <div class="hero-copy">
          <p class="hero-kicker">
            Friends of Ute Valley Park
          </p>

          <h1 class="hero-title">
            Triple your impact for Ute Valley Park.
          </h1>

          <p class="hero-intro">
            Friends of Ute Valley Park is launching as an independent nonprofit.
            During this kickoff challenge, every dollar you give is matched
            two-to-one to help local stewardship start strong.
          </p>

          <div class="hero-actions" aria-label="Donation page shortcuts">
            <a href="#donation-form" class="button button--brand">
              Give While Gifts Are Matched
            </a>
            <a href="#gift-impact" class="text-link">
              See what gifts support
            </a>
          </div>

          <section class="match-panel" aria-labelledby="match-panel-title">
            <div class="match-panel__copy">
              <p class="match-panel__label">
                Independence Kickoff Fund
              </p>
              <h2 id="match-panel-title">
                $1 becomes $3 for the park.
              </h2>
              <p>
                Gifts are matched two dollars for every dollar donated, up to
                $2,000, through August 31, 2026.
              </p>
            </div>

            <dl class="match-panel__details" aria-label="Kickoff matching gift details">
              {
                matchDetails.map((item) => (
                  <div>
                    <dt>{item.label}</dt>
                    <dd>{item.value}</dd>
                  </div>
                ))
              }
            </dl>
          </section>

          <p class="donation-meta">
            Friends of Ute Valley Park is an independent 501(c)(3) public charity.
            EIN: 42-2107142. Donations support local stewardship of Ute Valley
            Park and may be tax-deductible as allowed by law.
          </p>
        </div>

        <aside id="donation-form" class="donation-card panel-card" aria-label="Online donation form">
          <div class="donation-card__header">
            <div>
              <h2>
                Secure online donation
              </h2>
              <p>
                Make a one-time or monthly gift through Zeffy. Choose any
                amount that works for you. Eligible kickoff gifts are matched
                two-to-one through August 31, 2026.
              </p>
            </div>

            <div class="tip-note">
              <CheckBadgeIcon aria-hidden="true" />
              <p>
                Zeffy may ask for an optional tip at checkout. That tip supports
                Zeffy, not the park, and you can set it to any amount, including
                zero.
              </p>
            </div>
          </div>

          <ZeffyDonationEmbed height="620px" mobileHeight="700px" />
        </aside>
      </div>
    </section>

    <section id="gift-impact" class="impact-section l-section content-defer">
      <div class="impact-layout l-container">
        <div class="impact-media media-frame">
          <Image
            src={VolunteerHeroImage}
            alt="Volunteers gather on a Ute Valley Park trail"
            class="image media-cover"
            width={1200}
          />
        </div>

        <div class="impact-copy">
          <h2>
            What matched gifts make possible
          </h2>
          <ul class="gift-list" aria-label="What donations support">
            {
              giftUses.map((item) => (
                <li>
                  <CheckBadgeIcon class="icon" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <section id="other-ways-to-give" class="giving-options-section l-section band content-defer">
      <div class="l-container">
        <div class="section-heading donate-section-heading">
          <h2 class="section-heading__title">
            Other ways to give
          </h2>
          <p class="section-heading__copy">
            Prefer a different route? Start here. For bank transfers, workplace
            giving, or larger partnership questions, contact us before sending
            financial details.
          </p>
        </div>

        <div class="giving-grid">
          {
            givingOptions.map((option) => {
              const Icon = option.icon;

              return (
                <article id={option.id} class="giving-card card">
                  <div class="card-icon">
                    <Icon aria-hidden="true" />
                  </div>
                  <div class="giving-card__body">
                    <h3>{option.title}</h3>
                    <p>{option.description}</p>
                    <p class="giving-detail">{option.detail}</p>
                    <p class="giving-next">{option.nextStep}</p>
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
    </section>

    <section class="donor-contact-section content-defer">
      <ContactForm
        client:idle
        turnstileSiteKey={TURNSTILE_SITE_KEY}
        defaultOption="Other"
      >
        <Fragment slot="title">
          <h2 class="donor-contact-title section-heading__title">
            Set up a giving arrangement.
          </h2>
        </Fragment>
        <Fragment slot="subtitle">
          Tell us about bank transfers, matching gifts, Benevity, sponsorships,
          corporate volunteer teams, or documentation your employer needs.
        </Fragment>
      </ContactForm>
    </section>

    <section class="volunteer-bridge band band--muted">
      <div class="l-container bridge-inner">
        <p>Want to give time instead?</p>
        <a href="/volunteer/" class="button button--outline">
          View Volunteer Events
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .donate-hero {
    padding-block: clamp(2rem, 5vw, 4rem);
  }

  .hero-shell {
    --l-container-max: 88rem;

    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .hero-copy {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
    min-width: 0;
  }

  .hero-kicker {
    margin: 0;
    color: var(--color-brand-strong);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: var(--leading-tight);
  }

  .hero-title {
    max-width: 12ch;
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 4.75rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.9;
    text-transform: uppercase;
    text-wrap: balance;
    word-spacing: 0.08em;
  }

  .hero-intro,
  .donation-card__header p,
  .giving-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-large);
    font-weight: 500;
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  .hero-intro {
    max-width: 42rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.25rem;
  }

  .hero-actions .button {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-transform: none;
  }

  .match-panel {
    display: grid;
    gap: 1rem;
    min-width: 0;
    border-block: 1px solid var(--color-border);
    padding-block: clamp(1.25rem, 3vw, 1.75rem);
  }

  .match-panel__copy {
    display: grid;
    gap: 0.55rem;
  }

  .match-panel__label {
    width: fit-content;
    margin: 0;
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
  }

  .match-panel h2 {
    max-width: 18ch;
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: var(--leading-tight);
    text-transform: uppercase;
    text-wrap: balance;
  }

  .match-panel p {
    max-width: 38rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1rem;
    font-weight: 500;
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  .match-panel__details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0;
  }

  .match-panel__details div {
    flex: 1 1 8.5rem;
    display: grid;
    gap: 0.35rem;
    min-width: 0;
    border-top: 2px solid var(--color-accent);
    padding-top: 0.65rem;
  }

  .match-panel__details dt {
    color: var(--color-text-muted);
    font-size: 0.76rem;
    font-weight: 750;
    line-height: var(--leading-tight);
  }

  .match-panel__details dd {
    margin: 0;
    color: var(--color-brand-strong);
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    font-weight: 900;
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  .donation-meta {
    margin: 0;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  .donation-card {
    --panel-card-border-color: var(--color-border-strong);
    --panel-card-padding: clamp(1rem, 2.5vw, 1.5rem);

    display: grid;
    gap: 1.25rem;
    scroll-margin-top: 1.5rem;
  }

  .donation-card:target {
    animation: donation-target 1.4s ease-out;
    outline: 3px solid color-mix(in srgb, var(--color-brand-strong) 55%, transparent);
    outline-offset: 0.35rem;
  }

  .donation-card__header {
    display: grid;
    gap: 1rem;
  }

  .donation-card__header h2,
  .impact-copy h2 {
    margin: 0 0 0.75rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 2.4vw, 2.1rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  .tip-note {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    border-top: 1px solid var(--color-border-muted);
    padding-top: 1rem;
  }

  .tip-note svg {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    color: var(--color-brand-strong);
    margin-top: 0.2rem;
  }

  .tip-note p {
    color: var(--color-text-strong);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .donation-card :global(.zeffy-donation-embed__note) {
    display: none;
  }

  @keyframes donation-target {
    0% {
      outline-color: color-mix(in srgb, var(--color-brand-strong) 80%, transparent);
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-brand-strong) 24%, transparent);
    }

    45% {
      box-shadow: 0 0 0 0.75rem color-mix(in srgb, var(--color-brand-strong) 10%, transparent);
    }

    100% {
      outline-color: color-mix(in srgb, var(--color-brand-strong) 0%, transparent);
      box-shadow: 0 0 0 1rem transparent;
    }
  }

  .impact-section {
    background: var(--color-page);
  }

  .impact-layout {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: stretch;
  }

  .impact-media {
    min-height: 18rem;
  }

  .impact-copy {
    display: grid;
    align-content: center;
    gap: 1.5rem;
    border-block: 1px solid var(--color-border);
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }

  .gift-list {
    display: grid;
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .gift-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  :global(.gift-list .icon) {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    color: var(--color-accent-strong);
    margin-top: 0.2rem;
  }

  .gift-list span {
    color: var(--color-text-strong);
    font-size: 1rem;
    font-weight: 750;
    line-height: 1.45;
  }

  .donate-section-heading {
    --section-heading-title-size: clamp(2rem, 5vw, 3.25rem);
    --section-heading-title-leading: var(--leading-tight);
    --section-heading-copy-width: 48rem;
    --section-heading-copy-margin: 0;

    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .donate-section-heading .section-heading__title {
    font-size: clamp(2rem, 4vw, 2.85rem);
    font-weight: 800;
    text-transform: none;
  }

  .giving-grid {
    display: grid;
    gap: 1rem;
  }

  .giving-card {
    display: flex;
    min-width: 0;
    align-items: flex-start;
    gap: 1rem;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .card-icon {
    display: inline-flex;
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    background: var(--color-brand-subtle);
    color: var(--color-brand-strong);
  }

  .card-icon svg {
    display: block;
    width: 1.35rem;
    height: 1.35rem;
  }

  .giving-card__body {
    display: grid;
    gap: 0.65rem;
    min-width: 0;
  }

  .giving-card h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-size: 1.05rem;
    font-weight: 800;
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  .giving-card p {
    font-size: 0.95rem;
  }

  .giving-card .giving-detail {
    color: var(--color-text-strong);
    font-weight: 800;
  }

  .giving-card .giving-next {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .donor-contact-title {
    --section-heading-title-size: clamp(2rem, 5vw, 3.25rem);
    --section-heading-title-leading: var(--leading-tight);
    --section-heading-accent-style: normal;

    font-size: clamp(2rem, 4vw, 2.85rem);
    font-weight: 800;
    text-transform: none;
  }

  .volunteer-bridge {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(2rem, 5vw, 3rem);
  }

  .bridge-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .bridge-inner p {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 3vw, 2.25rem);
    font-weight: 800;
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  .bridge-inner .button {
    min-height: 2.75rem;
  }

  @media (min-width: 54rem) {
    .giving-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .giving-card {
      flex-direction: column;
    }
  }

  @media (min-width: 64rem) {
    .hero-shell {
      grid-template-columns: minmax(0, 0.9fr) minmax(28rem, 1.1fr);
    }

    .donation-card {
      grid-column: 2;
    }

    .impact-layout {
      grid-template-columns: minmax(0, 0.8fr) minmax(22rem, 0.7fr);
    }
  }

  @media (max-width: 36rem) {
    .hero-actions .button,
    .bridge-inner .button {
      width: 100%;
    }

    .hero-actions .text-link {
      width: 100%;
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .donation-card:target {
      animation: none;
    }
  }
</style>
