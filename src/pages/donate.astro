---
import { Image } from "astro:assets";

import Layout from "../layouts/Layout.astro";
import CheckBadgeIcon from "~icons/heroicons/check-badge";

const benefits = [
  "Trail stewardship",
  "Trail maintenance",
  "Wayfinding and facilities",
  "Educational programs",
  "Volunteer coordination",
  "Community care",
];
import VolunteerHeroImage from "../assets/images/volunteer-hero.jpg";
---

<Layout
  title="Page Paused"
  description="Friends of Ute Valley Park has paused this page while we complete an organizational transition."
>
  <main class="page donate-page">
    <!-- Fiscal Hero -->
    <section class="donate-hero">
      <div class="layout">
        <!-- Message Column -->
        <div class="message">
          <div class="stack">
            <div class="page-eyebrow">
              <span>
                Paused
              </span>
            </div>

            <h1 class="page-title">
              We Are <br /> Paused <br />
              <span>As We Transition.</span>
            </h1>

            <div class="intro">
              <p>
                This page is paused while Friends of Ute Valley Park completes
                an organizational transition. Please check back for updates.
              </p>
            </div>
          </div>
        </div>

        <!-- Visual Context -->
        <div class="media">
          <Image
            src={VolunteerHeroImage}
            alt="Park scenery"
            class="image media-cover"
            width={1200}
          />
          <div class="matte media-matte"></div>
        </div>
      </div>
    </section>

    <!-- Fiscal Sponsorship Info -->
    <section class="page-section">
      <div class="page-section__inner">
        <div class="donate-info">
          <div class="main">
            <div>
              <h2>
                While We <span>Transition.</span>
              </h2>
              <p>
                Our volunteer stewardship work continues in Ute Valley Park as
                we update our organizational structure and public support
                channels.
              </p>
            </div>

            <div class="columns">
              <div class="column">
                  <h4>
                      What We
                    <span>Continue.</span>
                  </h4>
                <ul class="benefit-list">
                  {
                    benefits.map((benefit) => (
                      <li>
                        <CheckBadgeIcon class="icon" />
                        <span>
                          {benefit}
                        </span>
                      </li>
                    ))
                  }
                </ul>
              </div>
              <div class="column">
                  <h4>
                      Current
                    <span>Status.</span>
                  </h4>
                <div class="partner-note">
                  <p>
                    This channel is paused while we complete our organizational
                    transition.
                  </p>
                  <div>
                    <span>Status</span>
                    <span>Paused</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="aside">
            <div class="mail-card">
              <p class="label">
                Correspondence Address
              </p>
              <address class="mail-card-address">
                <span>Friends of Ute Valley Park</span>
                <span>PO Box 50122</span>
                <span>Colorado Springs, CO 80919</span>
              </address>
              <p>
                Use this address for correspondence, partnership notes, and
                other official mail.
              </p>
            </div>
            <div class="volunteer-donation-card">
              <p>
                Want to volunteer your time instead?
              </p>
              <a
                href="/volunteer/"
                >Check Volunteer Opportunities →</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .donate-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .donate-hero .layout {
    display: grid;
  }

  .donate-hero .message {
    padding: clamp(3rem, 8vw, 8rem) var(--space-page-x) clamp(5rem, 10vw, 10rem);
  }

  .donate-hero .stack {
    display: grid;
    gap: 2rem;
  }

  .donate-hero .intro {
    max-width: 36rem;
  }

  .donate-hero .intro p,
  .donate-info .main > div > p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-large);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .donate-hero .mail-address {
    display: grid;
    gap: 0.35rem;
    max-width: 28rem;
    border: 1px solid color-mix(in oklab, var(--color-brand-strong) 40%, var(--color-border));
    background: var(--color-surface);
    padding: 1.25rem;
    color: var(--color-brand-strong);
    font-style: normal;
    font-size: var(--text-body-large);
    font-weight: 800;
    line-height: var(--leading-tight);
  }

  .donate-hero .media {
    position: relative;
    min-height: 28rem;
    overflow: hidden;
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
  }

  .donate-hero .matte {
    --media-matte-border: 1.5rem solid color-mix(in oklab, var(--color-surface) 20%, transparent);
  }

  .donate-info {
    display: grid;
    align-items: start;
    gap: 4rem;
  }

  .donate-info .main {
    display: grid;
    gap: 3rem;
  }

  .donate-info .main h2 {
    margin: 0 0 2rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .donate-info .main h2 span,
  .donate-info .column h4 span {
    color: var(--color-brand-strong);
    font-style: italic;
  }

  .donate-info .columns {
    display: grid;
    gap: 2rem 3rem;
  }

  .donate-info .column {
    display: grid;
    gap: 1rem;
  }

  .donate-info .column h4 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: var(--text-body-small);
    font-weight: 900;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .benefit-list {
    display: grid;
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .benefit-list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  :global(.benefit-list .icon) {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    color: var(--color-accent-strong);
  }

  .benefit-list span {
    color: var(--color-text-strong);
    font-size: var(--text-body-small);
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .partner-note {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--color-border-muted);
    background: var(--color-surface-muted);
    padding: 1.5rem;
  }

  .partner-note p,
  .mail-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .partner-note div {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .partner-note span {
    font-family: var(--font-label);
    font-size: var(--text-label);
    text-transform: uppercase;
  }

  .partner-note span:last-child {
    font-weight: 900;
  }

  .donate-info .aside {
    display: grid;
    gap: 2rem;
  }

  .mail-card {
    display: grid;
    gap: 1.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 2rem;
  }

  .mail-card .label {
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .mail-card-address {
    display: grid;
    gap: 0.35rem;
    color: var(--color-text-strong);
    font-style: normal;
    font-size: var(--text-body-small);
    font-weight: 800;
    line-height: var(--leading-tight);
  }

  .volunteer-donation-card {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--color-border-muted);
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
    padding: 2rem;
  }

  .volunteer-donation-card p {
    margin: 0;
    color: var(--color-text-strong);
    font-size: var(--text-body-small);
    font-weight: 500;
  }

  .volunteer-donation-card a {
    display: inline-block;
    color: var(--color-brand-strong);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (min-width: 48rem) {
    .donate-info .columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .donate-hero .layout {
      grid-template-columns: 7fr 5fr;
    }

    .donate-hero .message {
      border-right: 1px solid var(--color-border);
      padding-inline: var(--space-page-x) 3rem;
    }

    .donate-info {
      grid-template-columns: 8fr 4fr;
    }
  }
</style>
