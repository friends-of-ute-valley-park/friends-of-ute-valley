---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Picture } from "astro:assets";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const trailheadEntries = await getCollection("trailheads");
  return trailheadEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"trailheads">;
}

const { entry } = Astro.props;
---

<Layout title={entry.data.name} description={entry.data.description}>
  <main class="page">
    <!-- Trailhead Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            Trailhead Info
          </span>
        </div>

        <h1 class="page-title">
          {entry.data.name.split(" ").slice(0, -1).join(" ")}
          <br />
          <span
            >{entry.data.name.split(" ").slice(-1)}</span
          >
        </h1>

        <p class="page-intro">
          {entry.data.description}
        </p>
      </div>
    </section>

    <!-- Logistics & Entry Grid -->
    <section class="article-layout">
      <div class="article-layout__inner">
        <div class="trailhead-layout">
          <!-- Details -->
          <div class="details">
            <div class="trailhead-stack">
              <div class="trailhead-block">
                <h3>
                  Location Info
                </h3>
                <p class="trailhead-location">
                  {entry.data.location}
                </p>
              </div>

              <div class="trailhead-block">
                <h3>
                  Available Amenities
                </h3>
                <div class="amenity-list">
                  {
                    entry.data.amenities.map((amenity, i) => (
                      <div class="amenity-card">
                        <span>
                          [{String(i + 1).padStart(2, "0")}]
                        </span>
                        <div>
                          <h5>
                            {amenity.name}
                          </h5>
                          <p>
                            {amenity.description}
                          </p>
                        </div>
                      </div>
                    ))
                  }
                </div>
              </div>

              <div>
                <a
                  href={entry.data.directionsLink}
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                  class="button button--brand trailhead-directions"
                >
                  Get Directions →
                </a>
              </div>
            </div>
          </div>

          <!-- Cartographic Context -->
          <div class="map-wrap">
            <div class="trailhead-map-card">
              <Picture
                class="trailhead-map"
                width="1000"
                src={entry.data.map}
                alt={`${entry.data.name} map section`}
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Visual Documentation -->
    <section class="page-section">
      <div class="page-section__inner">
        <div class="header section-heading">
          <h2 class="section-heading__title">
            Site <span>Documentation.</span>
          </h2>
        </div>

        <div class="trailhead-photo-grid">
          {
            entry.data.photos.map((photo) => (
              <div class="trailhead-photo">
                <div class="media media-frame media-zoom-frame">
                  <Picture
                    class="image media-cover media-zoom media-zoom--slow"
                    src={photo.photo}
                    alt={photo.caption}
                    width={800}
                  />
                  <div class="matte media-matte" />
                </div>
                <p>
                  {photo.caption}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .trailhead-layout {
    display: grid;
  }

  .trailhead-layout .details {
    padding: var(--space-section) var(--space-page-x);
  }

  .trailhead-stack {
    display: grid;
    gap: 3rem;
  }

  .trailhead-block h3 {
    margin: 0 0 1.5rem;
    border-bottom: 1px solid var(--color-border-muted);
    padding-bottom: 0.5rem;
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .trailhead-location {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-large);
    font-style: italic;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .amenity-list {
    display: grid;
    gap: 1rem;
  }

  .amenity-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    border: 1px solid var(--color-border-muted);
    background: var(--color-surface);
    padding: 1.5rem;
  }

  .amenity-card > span {
    color: var(--color-accent-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
  }

  .amenity-card h5 {
    margin: 0 0 0.25rem;
    color: var(--color-text-strong);
    font-size: var(--text-body-small);
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .amenity-card p {
    margin: 0;
    color: var(--color-text-subtle);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .trailhead-directions {
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
  }

  .trailhead-layout .map-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in oklab, var(--color-surface-muted) 50%, transparent);
    padding: clamp(2rem, 4vw, 3rem);
  }

  .trailhead-map-card {
    width: 100%;
    max-width: 42rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 1rem;
  }

  :global(.trailhead-map) {
    width: 100%;
    height: auto;
    transition: transform 700ms;
  }

  .trailhead-docs .header {
    margin-bottom: 4rem;
    --section-heading-title-size: clamp(2.25rem, 6vw, 3.75rem);
    --section-heading-title-leading: normal;
  }

  .trailhead-photo-grid {
    display: grid;
    gap: 3rem;
  }

  .trailhead-photo {
    display: grid;
    gap: 1.5rem;
  }

  .trailhead-photo .media {
    position: relative;
    aspect-ratio: 16 / 10;
  }

  .trailhead-photo .matte {
    --media-matte-border: 1rem solid color-mix(in oklab, var(--color-surface) 10%, transparent);
  }

  .trailhead-photo p {
    margin: 0;
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-align: center;
    text-transform: uppercase;
  }

  @media (min-width: 48rem) {
    .trailhead-photo-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .trailhead-layout {
      grid-template-columns: 5fr 7fr;
    }

    .trailhead-layout .details {
      border-right: 1px solid var(--color-border);
      padding-inline: var(--space-page-x) 3rem;
    }
  }
</style>
