---
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const volunteerSpotlights = await getCollection("volunteer-spotlight");
---

<Layout
  title="Volunteer Spotlight"
  description="Meet the volunteers behind Friends of Ute Valley Park and read spotlight stories from community stewards."
>
  <main class="page">
    <!-- Volunteer Spotlight Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            Volunteer Stories
          </span>
        </div>

        <h1 class="page-title">
          Volunteer <br />
          <span>Spotlight.</span>
        </h1>

        <p class="page-intro">
          Get to know the stories and contributions of our amazing volunteers.
        </p>
      </div>
    </section>

    <!-- Spotlight Grid -->
    <section class="page-section page-section--muted">
      <div class="page-section__inner">
        <div class="feature-grid feature-grid--two feature-grid--three">
          {
            volunteerSpotlights.map((spotlight) => (
              <a
                href={`/volunteerspotlight/${spotlight.id}`}
                class="spotlight-card"
              >
                <div class="spotlight-card__media">
                  <Image
                    class="spotlight-card__image"
                    src={spotlight.data.images[0].image}
                    alt={spotlight.data.name}
                    quality={70}
                  />
                  <div class="spotlight-card__matte" />
                </div>

                <div class="spotlight-card__body">
                  <div class="spotlight-card__copy">
                    <div class="spotlight-card__tag">
                      <span>
                        Volunteer
                      </span>
                    </div>
                    <h3>
                      {spotlight.data.name}
                    </h3>
                    <p>
                      {spotlight.data.intro}
                    </p>
                  </div>

                  <div class="spotlight-card__footer">
                    <span>
                      Read More →
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .spotlight-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    color: inherit;
    text-decoration: none;
    transition: background-color 200ms;
  }

  .spotlight-card:hover {
    background: var(--color-page);
  }

  .spotlight-card__media {
    position: relative;
    aspect-ratio: 1;
    width: 100%;
    overflow: hidden;
  }

  :global(.spotlight-card__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transform: scale(1.05);
    transform-origin: top;
    transition: transform 700ms;
  }

  .spotlight-card:hover :global(.spotlight-card__image) {
    transform: scale(1);
  }

  .spotlight-card__matte {
    position: absolute;
    inset: 0;
    border: 0.75rem solid color-mix(in oklab, var(--color-surface) 20%, transparent);
    pointer-events: none;
  }

  .spotlight-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
  }

  .spotlight-card__copy {
    display: grid;
    gap: 0.75rem;
  }

  .spotlight-card__tag {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .spotlight-card__tag span {
    border: 1px solid color-mix(in oklab, var(--color-brand-strong) 20%, transparent);
    color: var(--color-brand-strong);
    padding: 0.125rem 0.5rem;
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .spotlight-card h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    transition: color 200ms;
  }

  .spotlight-card:hover h3 {
    color: var(--color-brand-strong);
  }

  .spotlight-card__copy p {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .spotlight-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    border-top: 1px solid var(--color-border-muted);
    padding-top: 1.5rem;
  }

  .spotlight-card__footer span {
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>
