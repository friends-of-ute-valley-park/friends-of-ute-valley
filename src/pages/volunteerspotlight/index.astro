---
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const volunteerSpotlights = await getCollection("volunteer-spotlight");
---

<Layout
  title="Volunteer Spotlight"
  description="Meet the volunteers behind Friends of Ute Valley Park and read spotlight stories from community stewards."
>
  <main class="page">
    <!-- Volunteer Spotlight Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            Volunteer Stories
          </span>
        </div>

        <h1 class="page-title">
          Volunteer <br />
          <span>Spotlight.</span>
        </h1>

        <p class="page-intro">
          Get to know the stories and contributions of our amazing volunteers.
        </p>
      </div>
    </section>

    <!-- Spotlight Grid -->
    <section class="page-section page-section--muted">
      <div class="page-section__inner">
        <div class="feature-grid feature-grid--two feature-grid--three">
          {
            volunteerSpotlights.map((spotlight) => (
              <a
                href={`/volunteerspotlight/${spotlight.id}`}
                class="spotlight-card media-zoom-parent"
              >
                <div class="media">
                  <Image
                    class="image media-cover media-zoom"
                    src={spotlight.data.images[0].image}
                    alt={spotlight.data.name}
                    quality={70}
                  />
                  <div class="matte media-matte" />
                </div>

                <div class="body">
                  <div class="copy">
                    <div class="tag">
                      <span class="meta-label">
                        Volunteer
                      </span>
                    </div>
                    <h3 class="title card-title">
                      {spotlight.data.name}
                    </h3>
                    <p>
                      {spotlight.data.intro}
                    </p>
                  </div>

                  <div class="footer">
                    <span class="meta-label">
                      Read More →
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .spotlight-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    color: inherit;
    text-decoration: none;
    transition: background-color 200ms;
  }

  .spotlight-card:hover {
    background: var(--color-page);
  }

  .spotlight-card .media {
    position: relative;
    aspect-ratio: 1;
    width: 100%;
    overflow: hidden;
  }

  :global(.spotlight-card .image) {
    object-position: top;
    transform-origin: top;
  }

  .spotlight-card .body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
  }

  .spotlight-card .copy {
    display: grid;
    gap: 0.75rem;
  }

  .spotlight-card .tag {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .spotlight-card .tag span {
    border: 1px solid color-mix(in oklab, var(--color-brand-strong) 20%, transparent);
    color: var(--color-brand-strong);
    padding: 0.125rem 0.5rem;
  }

  .spotlight-card .title {
    --card-title-size: 1.875rem;
    line-height: 1;
  }

  .spotlight-card:hover h3 {
    color: var(--color-brand-strong);
  }

  .spotlight-card .copy p {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .spotlight-card .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    border-top: 1px solid var(--color-border-muted);
    padding-top: 1.5rem;
  }

  .spotlight-card .footer span {
    color: var(--color-brand-strong);
  }
</style>
