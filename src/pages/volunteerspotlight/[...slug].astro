---
import { getCollection, render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

import InstagramIcon from "~icons/mdi/instagram";
import WebsiteIcon from "~icons/mdi/computer";

export async function getStaticPaths() {
  const volunteerSpotlights = await getCollection("volunteer-spotlight");
  return volunteerSpotlights.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"volunteer-spotlight">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout
  title={`Volunteer Spotlight: ${entry.data.name}`}
  description={entry.data.intro}
>
  <main class="page">
    <!-- Volunteer Spotlight Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="hero">
          <div class="intro">
            <div class="page-eyebrow">
              <span>
                Volunteer Spotlight — {entry.data.name}
              </span>
            </div>

            <h1 class="page-title">
              {entry.data.name.split(" ")[0]}
              <br />
              <span
                >{entry.data.name.split(" ").slice(1).join(" ")}</span
              >
            </h1>

            <p class="page-intro">
              {entry.data.intro}
            </p>
          </div>

          <div class="actions">
            <a
              href="/volunteerspotlight/"
              class="back"
            >
              <span>← Back to Spotlights</span>
            </a>
            {
              (entry.data.instagram || entry.data.website) && (
                <div class="socials">
                  {entry.data.instagram && (
                    <a
                      href={"https://instagram.com/" + entry.data.instagram}
                    >
                      <InstagramIcon class="icon" aria-hidden="true" />
                    </a>
                  )}
                  {entry.data.website && (
                    <a
                      href={entry.data.website}
                    >
                      <WebsiteIcon class="icon" aria-hidden="true" />
                    </a>
                  )}
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Story & Photos -->
    <section class="article-layout">
      <div class="article-layout__inner">
        <div class="article-layout__grid">
          <!-- Their Story -->
          <div class="article-layout__main">
            <div class="prose-content">
              <Content />
            </div>
          </div>

          <!-- Photographic Records -->
          <div class="article-layout__aside photos">
            {
              entry.data.images.map((image, i) => (
                <div class="article-photo-card photo">
                  <Image
                    src={image.image}
                    alt={`${entry.data.name} action photo ${i + 1}`}
                    width={800}
                    height={800}
                    class="photo-image"
                  />
                  <div class="article-photo-card__meta">
                    <span>
                      Photo {i + 1}
                    </span>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .spotlight-detail .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .spotlight-detail .intro {
    display: grid;
    gap: 2rem;
  }

  .spotlight-detail .actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .spotlight-detail .back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 200ms;
  }

  .spotlight-detail .back:hover,
  .spotlight-detail .socials a:hover {
    color: var(--color-brand-strong);
  }

  .spotlight-detail .socials {
    display: flex;
    gap: 1rem;
    border: 1px solid var(--color-border-muted);
    background: var(--color-surface);
    padding: 1rem;
  }

  .spotlight-detail .socials a {
    color: var(--color-text-subtle);
    transition: color 200ms;
  }

  :global(.spotlight-detail .icon) {
    width: 1.25rem;
    height: 1.25rem;
  }

  .spotlight-detail .photos {
    display: grid;
    align-content: start;
    gap: 3rem;
  }

  .spotlight-detail .photo {
    align-self: start;
  }

  :global(.spotlight-detail .photo-image) {
    display: block;
    width: 100%;
    height: clamp(14rem, 26vw, 20rem);
    object-fit: cover;
    object-position: top;
    transform-origin: top center;
    transform: scale(1.05);
    transition: transform 1000ms;
  }

  .spotlight-detail .photo:hover :global(.photo-image) {
    transform: scale(1);
  }

  @media (min-width: 48rem) {
    .spotlight-detail .hero {
      flex-direction: row;
    }
  }
</style>
