---
import { Image } from "astro:assets";

import Layout from "@layouts/Layout.astro";
import VolunteerItem from "@components/VolunteerItem.vue";
import LeaveNoTraceSmall from "@components/LeaveNoTraceSmall.astro";
import ContactForm from "@components/ContactForm.vue";
import EmailForm from "@components/EmailForm.vue";
import StaticCalendar from "../components/StaticCalendar.astro";
import SocialLinks from "@components/SocialLinks.astro";

import { getCollection } from "astro:content";
import { getUpcomingVolunteerEvents } from "@/utils/content";
import { formatShortMonthDayYear } from "@/utils/date";
const upcomingVolunteerEvents = await getUpcomingVolunteerEvents();

import VolunteerHeroImage from "../assets/images/volunteer-hero-mask.jpg";
import VolunteerInfoImage2 from "../assets/images/volunteer-4.jpg";
import { TURNSTILE_SITE_KEY } from "astro:env/client";

const meetingLocations = await getCollection("trailheads");
---

<Layout
  title="Volunteer"
  description="Volunteer with Friends of Ute Valley Park and join trail maintenance and stewardship events in Colorado Springs."
>
  <main class="page volunteer-page">
    <!-- Hero Section -->
    <section class="volunteer-hero">
      <Image
        src={VolunteerHeroImage}
        alt="Volunteers in the field"
        class="image"
        width={1800}
      />
      <div class="scrim"></div>

      <div class="inner l-container">
        <div class="content">
          <h1>
            Volunteer <br />
            <span>With Us.</span>
          </h1>

          <p>
            Join our community of dedicated park stewards. We provide the
            expertise and tools; your hands-on help is what makes the continued
            preservation of this urban wildland possible.
          </p>
        </div>
      </div>

      <div class="volunteer-status">
        <div class="panel">
          <div>
            <span>Current Status</span>
            <span>Recruiting</span>
          </div>
          <div>
            <span>Next Event</span>
            <span>
              {
                upcomingVolunteerEvents.length > 0
                  ? formatShortMonthDayYear(upcomingVolunteerEvents[0].data.date)
                  : "TBD"
              }
            </span>
          </div>
        </div>
      </div>
    </section>

    <section class="page-section volunteer-events-section">
      <div class="page-section__inner">
        {
          upcomingVolunteerEvents.length > 0 ? (
            <div class="volunteer-events">
              {upcomingVolunteerEvents.map((volunteerEvent) => (
                <div class="item">
                  <VolunteerItem
                    meetingLocations={meetingLocations}
                    volunteerEvent={volunteerEvent}
                    client:idle
                  />
                </div>
              ))}
            </div>
          ) : (
            <div class="empty">
              <p>
                No scheduled events at this time. Check back for seasonal updates.
              </p>
            </div>
          )
        }
      </div>
    </section>

    <!-- Volunteer Opportunities -->
    <section class="page-section volunteer-opps">
      <div class="page-section__inner">
        <div class="header">
          <div>
            <h2>
              Volunteer{" "}
              <span>Opportunities.</span>
            </h2>
            <p>
              Preserving the 550-acre Ute Valley urban wildland is a collective
              effort. From April through September, we host scheduled trail
              maintenance and stewardship events on select Wednesdays and
              weekends. As our schedule varies each month, we encourage you to
              join our update list and follow us
              <SocialLinks variant="inline" /> for the latest news. Whether you join us for one
              session or the full season, your contribution is vital to the health
              of our local trails.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Seasonal Calendar -->
    <section class="page-section page-section--muted">
      <StaticCalendar />
    </section>

    <!-- Field Manual / Info -->
    <section class="page-section">
      <div class="page-section__inner">
        <div class="volunteer-field">
          <div class="copy">
            <div>
              <h2>
                What to <span>Expect.</span>
              </h2>
              <p>
                Our team welcomes individuals of all abilities. We offer tasks
                ranging from trail restoration and drainage construction to
                native seeding and path maintenance.
              </p>
            </div>

            <div class="field-notes">
              {
                [
                  {
                    title: "Technical Training",
                    desc: "No prior experience required. Crew leaders provide on-site instruction for all specialized tools.",
                  },
                  {
                    title: "Logistics",
                    desc: "FUVP provides all necessary heavy tools and infrastructure support.",
                  },
                  {
                    title: "Field Gear",
                    desc: "Volunteers must wear pants and closed-toe footwear. Gloves and eye protection are mandatory.",
                  },
                ].map((item, i) => (
                  <div class="field-note">
                    <h3>
                      0{i + 1}. {item.title}
                    </h3>
                    <p>
                      {item.desc}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="photo">
            <Image
              src={VolunteerInfoImage2}
              alt="Volunteers in action"
              class="image"
              width={1000}
            />
            <div class="article-photo-card__meta">
              <span>Volunteers working on trail maintenance</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Recruitment (Engagement) -->
    <section class="volunteer-recruitment">
      <div class="marker"></div>

      <div class="inner l-container">
        <div class="panel">
          <div class="layout">
            <div class="copy">
              <h2>
                Stay <br />
                <span>Updated.</span>
              </h2>
              <p>
                Our crew leaders often schedule additional volunteer sessions.
                Stay connected through our newsletter or social media for the
                latest on volunteer opportunities, meeting locations, and park
                updates.
              </p>
            </div>
            <div class="form">
              <h3>
                Stay Updated
              </h3>
              <EmailForm client:idle />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Communication Link -->
    <section class="volunteer-contact">
      <div class="inner l-container">
        <ContactForm
          default-option="Volunteer"
          client:visible
          turnstileSiteKey={TURNSTILE_SITE_KEY}
        >
          <Fragment slot="title">
            <h2 class="title">
              Get in <span>Touch.</span>
            </h2>
          </Fragment>
          <Fragment slot="subtitle">
            For specific inquiries regarding group volunteer events or technical
            project coordination, please submit an official request below.
          </Fragment>
        </ContactForm>
      </div>
    </section>

    <div class="volunteer-lnt">
      <LeaveNoTraceSmall />
    </div>
  </main>
</Layout>

<style>
  .volunteer-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-inverse);
  }

  :global(.volunteer-hero .image) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
  }

  .volunteer-hero .scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--color-surface-inverse), transparent);
  }

  .volunteer-hero .inner {
    position: relative;
    padding-block: clamp(6rem, 12vw, 10rem);
  }

  .volunteer-hero .content {
    max-width: 48rem;
  }

  .volunteer-hero .eyebrow {
    margin-bottom: 2rem;
  }

  .volunteer-status span,
  .volunteer-events .empty p {
    font-family: var(--font-label);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .volunteer-hero h1 {
    margin: 0;
    color: var(--color-text-inverse);
    font-family: var(--font-display);
    font-size: clamp(3rem, 11vw, 8rem);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .volunteer-hero h1 span,
  .volunteer-recruitment .copy h2 span {
    color: var(--color-accent);
  }

  .volunteer-hero p {
    max-width: 36rem;
    margin: 2rem 0 0;
    color: var(--color-text-inverse-muted);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .volunteer-status {
    position: absolute;
    right: 0;
    bottom: 0;
    display: none;
    padding: 2rem;
  }

  .volunteer-status .panel {
    display: grid;
    gap: 1rem;
    border: 1px solid color-mix(in oklab, var(--color-text-inverse) 20%, transparent);
    background: color-mix(in oklab, var(--color-text-inverse) 10%, transparent);
    padding: 1.5rem;
    backdrop-filter: blur(12px);
  }

  .volunteer-status .panel div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 3rem;
  }

  .volunteer-status span:first-child {
    color: var(--color-text-subtle);
  }

  .volunteer-status span:last-child {
    color: var(--color-text-inverse);
    font-size: var(--text-body-small);
    font-weight: 700;
    letter-spacing: normal;
    text-transform: none;
  }

  .volunteer-status div:first-child span:last-child {
    color: var(--color-accent);
  }

  .volunteer-events {
    border: 1px solid var(--color-border);
  }

  .volunteer-events .item {
    padding: 2rem;
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--duration-fast);
  }

  .volunteer-events .item:hover {
    background: var(--color-page);
  }

  .volunteer-events .item:last-child {
    border-bottom: 0;
  }

  .volunteer-events .empty {
    border: 1px solid var(--color-border-muted);
    background: var(--color-page);
    padding: 3rem;
    text-align: center;
  }

  .volunteer-events .empty p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .volunteer-opps {
    background: var(--color-surface);
  }

  .volunteer-opps .header {
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .volunteer-opps .header > div {
    width: min(100%, 56rem);
    max-width: 56rem;
  }

  .volunteer-opps h2,
  .volunteer-field h2,
  .volunteer-contact .title {
    margin: 0 0 1.5rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .volunteer-opps h2 span,
  .volunteer-field h2 span,
  .volunteer-contact .title span {
    color: var(--color-brand-strong);
    font-style: italic;
  }

  .volunteer-opps p,
  .volunteer-field .copy > div > p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-large);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .volunteer-field {
    display: grid;
    gap: 4rem;
  }

  .volunteer-field .copy {
    display: grid;
    gap: 3rem;
  }

  .field-notes {
    display: grid;
    gap: 1.5rem;
  }

  .field-note {
    border-left: 4px solid var(--color-brand-strong);
    padding: 0.5rem 0 0.5rem 1.5rem;
  }

  .field-note h3 {
    margin: 0 0 0.5rem;
    color: var(--color-text-strong);
    font-family: var(--font-label);
    font-size: var(--text-body-small);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .field-note p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .volunteer-field .photo {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 1rem;
  }

  :global(.volunteer-field .image) {
    width: 100%;
    height: auto;
    transition: transform var(--duration-slower);
  }

  .volunteer-recruitment {
    position: relative;
    overflow: clip;
    background: var(--color-surface-inverse);
    padding-block: var(--space-section);
  }

  .volunteer-recruitment .marker {
    position: absolute;
    top: 0;
    right: 0;
    width: 16rem;
    height: 16rem;
    border: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);
    background: color-mix(in oklab, var(--color-accent) 5%, transparent);
    transform: translate(50%, -50%) rotate(45deg);
  }

  .volunteer-recruitment .inner {
    --l-container-max: 72rem;
  }

  .volunteer-recruitment .panel {
    border: 2px solid var(--color-accent);
    background: var(--color-surface-inverse);
    padding: clamp(2rem, 5vw, 4rem);
    box-shadow: var(--shadow-accent-xl);
  }

  .volunteer-recruitment .layout {
    display: grid;
    align-items: center;
    gap: 4rem;
  }

  .volunteer-recruitment .copy {
    display: grid;
    gap: 2rem;
  }

  .volunteer-recruitment .copy h2 {
    margin: 0;
    color: var(--color-text-inverse);
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 3rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .volunteer-recruitment .copy h2 span {
    font-style: italic;
  }

  .volunteer-recruitment .copy p {
    margin: 0;
    color: var(--color-text-inverse-muted);
    font-size: var(--text-body-large);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .volunteer-recruitment .form {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: clamp(1.25rem, 5vw, 2rem);
  }

  .volunteer-recruitment .form :global(.email-signup) {
    width: 100%;
  }

  .volunteer-recruitment .form h3 {
    margin: 0 0 1.5rem;
    border-bottom: 1px solid var(--color-border-muted);
    padding-bottom: 0.5rem;
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .volunteer-contact {
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-section);
  }

  .volunteer-contact .inner {
    --l-container-max: 80rem;
  }

  .volunteer-lnt {
    border-top: 1px solid var(--color-border);
    background: var(--color-page);
  }

  @media (width <= 24rem) {
    .volunteer-hero h1 {
      font-size: clamp(2.5rem, 13vw, 3rem);
    }

    .volunteer-opps h2,
    .volunteer-field h2,
    .volunteer-contact .title {
      font-size: clamp(1.5rem, 9vw, 1.875rem);
    }
  }

  @media (min-width: 64rem) {
    .volunteer-status {
      display: block;
    }

    .volunteer-field,
    .volunteer-recruitment .layout {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
