---
import Layout from "@layouts/Layout.astro";

const logos = [
  {
    src: "/images/logo-small.jpg",
    alt: "Small Logo",
    ref: "LOG_SML_01",
    desc: "Small utility logo",
  },
  {
    src: "/images/logo-medium.jpg",
    alt: "Medium Logo",
    desc: "Medium report logo",
  },
  {
    src: "/images/logo-full.jpg",
    alt: "Full Size Logo",
    desc: "Standard full size logo",
  },
  {
    src: "/images/logo-full-uncompressed.jpg",
    alt: "Uncompressed Logo",
    desc: "High-resolution RAW asset",
  },
  {
    src: "/images/logo-stickers.png",
    alt: "Sticker Logo",
    desc: "Sticker-optimized layout",
  },
];
---

<Layout
  title="Assets"
  description="Download official Friends of Ute Valley Park brand assets and logos for approved community, partner, and media use."
>
  <main class="page">
    <!-- Assets Header -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            Park Media
          </span>
        </div>

        <h1 class="page-title">
          Brand <br />
          <span>Assets.</span>
        </h1>

        <p class="page-intro">
          Official visual markers and logos for use in authorized
          communications, field signage, and technical reports.
        </p>
      </div>
    </section>

    <!-- Assets Grid -->
    <section class="page-section page-section--muted">
      <div class="page-section__inner">
        <div class="assets-grid">
          {
            logos.map((logo) => (
              <div class="asset-card">
                <div class="asset-card__media">
                  <img
                    src={logo.src}
                    alt={logo.alt}
                  />
                </div>
                <div class="asset-card__body">
                  <div>
                    <h3>
                      {logo.alt}
                    </h3>
                    <p>
                      {logo.desc}
                    </p>
                  </div>
                  <div>
                    <a
                      href={logo.src}
                      download
                    >
                      Download Asset
                    </a>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .assets-grid {
    display: grid;
    gap: 3rem;
  }

  .asset-card {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: border-color 200ms;
  }

  .asset-card:hover {
    border-color: var(--color-brand-strong);
  }

  .asset-card__media {
    display: flex;
    aspect-ratio: 1;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--color-border-muted);
    background: color-mix(in oklab, var(--color-page) 50%, transparent);
    padding: 3rem;
  }

  .asset-card__media img {
    width: auto;
    max-height: 100%;
    transition: transform 700ms;
  }

  .asset-card__body {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
  }

  .asset-card__body h3 {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .asset-card__body p {
    margin: 0.25rem 0 0;
    color: var(--color-text-subtle);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .asset-card__body a {
    display: inline-block;
    border: 1px solid var(--color-border);
    color: var(--color-text-subtle);
    padding: 0.75rem 1.5rem;
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 200ms,
      color 200ms,
      transform 200ms;
  }

  .asset-card__body a:hover {
    background: var(--color-text-strong);
    color: var(--color-text-inverse);
  }

  .asset-card__body a:active {
    transform: scale(0.96);
  }

  @media (min-width: 48rem) {
    .assets-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .assets-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
