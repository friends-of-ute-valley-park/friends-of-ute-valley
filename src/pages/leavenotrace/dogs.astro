---
import { Picture } from "astro:assets";

import Layout from "@layouts/Layout.astro";

import DogImage from "../../assets/images/dog.jpg";
import FreyjaPup from "../../assets/images/dogs/freyja_pup.jpg";
import SweetLife from "../../assets/images/dogs/the.sweet.life.of.five.jpg";
import LoganRescue from "../../assets/images/dogs/logan.and.the.rescue.crew.jpg";
import Marisslh from "../../assets/images/dogs/marisslh.jpg";
import QueenPadme from "../../assets/images/dogs/queen_padme_21.jpg";

const dogs = [
  { src: FreyjaPup, handle: "freyja_pup" },
  { src: SweetLife, handle: "the.sweet.life.of.five" },
  { src: LoganRescue, handle: "logan.and.the.rescue.crew" },
  { src: Marisslh, handle: "marisslh" },
  { src: QueenPadme, handle: "queen_padme_21" },
];

const otherParks = [
  {
    name: "Red Rock Canyon Open Space",
    image: "/images/other-parks/red-rock-canyon-open-space.jpg",
    type: "Unfenced",
    distance: "7.5 miles",
    time: "15 minutes",
    mapLink: "https://goo.gl/maps/qAKchVJRqyTYUc8v9",
    cityLink:
      "https://coloradosprings.gov/parks/page/red-rock-canyon-open-space",
  },
  {
    name: "Palmer Park",
    image: "/images/other-parks/palmer-park.jpg",
    type: "Fenced",
    distance: "9.8 miles",
    time: "20 minutes",
    mapLink: "https://goo.gl/maps/sgxAgR8Mnjr86Qt98",
    cityLink: "https://coloradosprings.gov/parks/page/palmer-park",
  },
  {
    name: "Garden of the Gods",
    image: "/images/other-parks/garden-of-the-gods.jpg",
    type: "Unfenced",
    distance: "6.9 miles",
    time: "14 minutes",
    mapLink: "https://goo.gl/maps/Vj2851x6X2JSNeX76",
    cityLink: "https://coloradosprings.gov/parks/page/garden-gods",
  },
  {
    name: "Rampart Dog Park",
    image: "/images/other-parks/rampart-dog-park.jpg",
    type: "Fenced",
    distance: "6.6 miles",
    time: "15 minutes",
    mapLink: "https://goo.gl/maps/UEAzoaFGxCTFi7Qo9",
    cityLink: "https://coloradosprings.gov/parks/page/rampart-park",
  },
];
const reasons = [
  "City Ordinance: Colorado Springs Ordinance 6.7.107 requires dogs to be on a leash. Fines range from $50 to $150.",
  "Courtesy to Others: Not all visitors are comfortable around dogs. Keeping your pup on a leash helps everyone enjoy the trails.",
  "Wildlife Safety: A leash keeps your dog from chasing or disturbing other pets and the wildlife that call the park home.",
  "Rattlesnake Risk: Ute Valley Park is home to rattlesnakes. A leash helps keep your dog safe from a dangerous encounter.",
];
const rules = [
  "Leash Required: There are no off-leash areas in Ute Valley Park. Dogs must be on a leash at all times.",
  "Pick Up After Your Dog: Please bag and dispose of pet waste to keep the trails clean for everyone.",
  "Stay on the Trail: Dogs should stay on designated trails at all times to protect the natural landscape.",
  "Know the Rules: Check out the full park regulations so you and your dog can have a great visit.",
];
---

<Layout
  title="Dogs at Ute Valley Park"
  description="Dog rules for Ute Valley Park: leash requirements, safety guidance, and nearby off-leash dog parks in Colorado Springs."
>
  <main class="page dogs-page">
    <!-- Dogs Hero -->
    <section class="dogs-hero">
      <div class="dogs-hero__layout">
        <!-- Identity Column -->
        <div class="dogs-hero__identity">
          <div class="dogs-hero__stack">
            <div class="page-eyebrow">
              <span>
                Visiting With Dogs
              </span>
            </div>

            <h1 class="page-title">
              Visiting <br /> With <br />
              <span>Dogs.</span>
            </h1>

            <p>
              We love dogs at Ute Valley Park! For the safety of your furry
              friend, other visitors, and local wildlife, dogs must be on a
              leash at all times.
            </p>

            <div class="dogs-hero__actions">
              <a href="#rules" class="button button--brand"> Leash Rules </a>
              <a
                href="#off-leash"
                class="dogs-hero__secondary-link"
              >
                Off-Leash Dog Parks
              </a>
            </div>
          </div>
        </div>

        <!-- Visual Context -->
        <div class="dogs-hero__gallery">
          <div class="dogs-hero__gallery-grid">
            <div class="dogs-hero__gallery-column">
              {
                dogs.slice(0, 2).map((dog) => (
                  <div class="dog-tile">
                    <a
                      href={`https://instagram.com/${dog.handle}`}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                    >
                      <Picture
                        src={dog.src}
                        formats={["avif", "webp"]}
                        alt="Dog at Ute Valley Park"
                        width={400}
                        class="dog-tile__image"
                      />
                      <p>
                        @{dog.handle}
                      </p>
                    </a>
                  </div>
                ))
              }
            </div>
            <div class="dogs-hero__gallery-column">
              {
                dogs.slice(2, 5).map((dog) => (
                  <div class="dog-tile">
                    <a
                      href={`https://instagram.com/${dog.handle}`}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                    >
                      <Picture
                        src={dog.src}
                        formats={["avif", "webp"]}
                        alt="Dog at Ute Valley Park"
                        width={400}
                        class="dog-tile__image"
                      />
                      <p>
                        @{dog.handle}
                      </p>
                    </a>
                  </div>
                ))
              }
            </div>
          </div>
          <div class="dogs-hero__badge">
            Dogs of Ute Valley
          </div>
        </div>
      </div>
    </section>

    <!-- Leash Rules -->
    <section class="page-section dogs-rules">
      <div class="page-section__inner">
        <div class="dogs-rules__layout">
          <div>
            <h2>
              Leash <br />
              <span>Rules.</span>
            </h2>
            <div class="dogs-rules__photo">
              <Picture
                src={DogImage}
                formats={["avif", "webp"]}
                alt="Dog in park"
                width="800"
                class="dogs-rules__image"
              />
              <div>
                Good dog!
              </div>
            </div>
          </div>

          <div class="dogs-rules__content">
            <div>
              <p class="dogs-rules__kicker">
                Why Leash Rules Matter
              </p>
              <div class="dogs-reason-list">
                {
                  reasons.map((reason, i) => (
                    <div class="dogs-reason-card">
                      <span>
                        [0{i + 1}]
                      </span>
                      <p>
                        {reason}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>

            <div id="rules">
              <p class="dogs-rules__kicker">
                Here's Why
              </p>
              <div class="dog-rule-list">
                {
                  rules.map((rule) => (
                    <div class="dog-rule-list__item">
                      <div />
                      <p>
                        {rule}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Off-Leash Dog Parks Nearby -->
    <section id="off-leash" class="off-leash-parks">
      <div class="page-section__inner">
        <div class="off-leash-parks__header">
          <div>
            <h2>
              Off-Leash Dog <span>Parks Nearby.</span>
            </h2>
            <p>
              Nearby off-leash dog parks where your pup can run free.
            </p>
          </div>
          <a
            href="https://coloradosprings.gov/parks/page/dog-parks?mlid=4736"
            >All CS Off-Leash Parks</a
          >
        </div>

        <div class="dog-park-grid">
          {
            otherParks.map((park) => (
              <div class="dog-park-card">
                <div class="dog-park-card__media">
                  <img
                    src={park.image}
                    alt={park.name}
                  />
                </div>
                <div class="dog-park-card__body">
                  <div>
                    <p>
                      {park.type} Park
                    </p>
                    <h3>
                      {park.name}
                    </h3>
                  </div>

                  <div class="dog-park-card__stats">
                    <div>
                      <p>
                        Dist
                      </p>
                      <p>
                        {park.distance}
                      </p>
                    </div>
                    <div>
                      <p>
                        Time
                      </p>
                      <p>
                        {park.time}
                      </p>
                    </div>
                  </div>

                  <div class="dog-park-card__links">
                    <a
                      href={park.mapLink}
                    >
                      Visit Site <span>→</span>
                    </a>
                    <a
                      href={park.cityLink}
                    >
                      Information <span>→</span>
                    </a>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .dogs-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .dogs-hero__layout {
    display: grid;
  }

  .dogs-hero__identity {
    padding: clamp(3rem, 8vw, 8rem) var(--space-page-x) clamp(5rem, 10vw, 10rem);
  }

  .dogs-hero__stack {
    display: grid;
    gap: 2rem;
  }

  .dogs-hero__stack > p {
    max-width: 36rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .dogs-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1rem;
  }

  .dogs-hero__secondary-link {
    border: 2px solid var(--color-text-strong);
    color: var(--color-text-strong);
    padding: 1rem 2rem;
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 200ms,
      transform 200ms;
  }

  .dogs-hero__secondary-link:hover {
    background: var(--color-page);
  }

  .dogs-hero__secondary-link:active {
    transform: scale(0.96);
  }

  .dogs-hero__gallery {
    position: relative;
    min-height: 25rem;
    overflow: hidden;
    background: var(--color-page);
  }

  .dogs-hero__gallery-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    padding: 0.75rem;
  }

  .dogs-hero__gallery-column {
    display: grid;
    align-content: center;
    gap: 0.75rem;
  }

  .dog-tile {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  :global(.dog-tile__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .dog-tile p {
    position: absolute;
    bottom: 0;
    left: 0;
    margin: 0;
    border-top: 1px solid var(--color-border-muted);
    border-right: 1px solid var(--color-border-muted);
    background: color-mix(in oklab, var(--color-surface) 90%, transparent);
    color: var(--color-text-strong);
    padding: 0.25rem 0.5rem;
    font-family: var(--font-label);
    font-size: 0.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .dogs-hero__badge {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    z-index: 1;
    border: 1px solid var(--color-brand-strong);
    background: var(--color-brand-strong);
    color: var(--color-text-inverse);
    padding: 0.5rem 1rem;
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    box-shadow: var(--shadow-accent-sm);
  }

  .dogs-rules {
    background: var(--color-surface);
  }

  .dogs-rules__layout {
    display: grid;
    align-items: start;
    gap: 4rem;
  }

  .dogs-rules h2,
  .off-leash-parks__header h2 {
    margin: 0 0 2rem;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .dogs-rules h2 span,
  .off-leash-parks__header h2 span {
    color: var(--color-brand-strong);
    font-style: italic;
  }

  .dogs-rules__photo {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface-muted);
  }

  :global(.dogs-rules__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1000ms;
  }

  .dogs-rules__photo > div {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    background: var(--color-surface-inverse);
    color: var(--color-text-inverse);
    padding: 0.125rem 0.5rem;
    font-family: var(--font-label);
    font-size: 0.5rem;
    text-transform: uppercase;
  }

  .dogs-rules__content {
    display: grid;
    gap: 3rem;
  }

  .dogs-rules__kicker {
    margin: 0 0 1rem;
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .dogs-reason-list {
    display: grid;
    gap: 1rem;
  }

  .dogs-reason-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    border: 1px solid var(--color-border-muted);
    background: var(--color-page);
    padding: 1.5rem;
  }

  .dogs-reason-card span {
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
  }

  .dogs-reason-card p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-body-small);
    font-weight: 500;
    line-height: var(--leading-body);
  }

  .dog-rule-list {
    border: 1px solid var(--color-border);
  }

  .dog-rule-list__item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem;
    transition: background-color 200ms;
  }

  .dog-rule-list__item:last-child {
    border-bottom: 0;
  }

  .dog-rule-list__item:hover {
    background: var(--color-page);
  }

  .dog-rule-list__item div {
    width: 0.5rem;
    height: 0.5rem;
    flex-shrink: 0;
    background: var(--color-accent);
  }

  .dog-rule-list__item p {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .off-leash-parks {
    background: var(--color-surface-muted);
    padding-block: var(--space-section);
  }

  .off-leash-parks__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .off-leash-parks__header h2 {
    margin-bottom: 1rem;
  }

  .off-leash-parks__header p {
    margin: 0;
    color: var(--color-text-subtle);
    font-weight: 500;
  }

  .off-leash-parks__header > a {
    color: var(--color-brand-strong);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration-line: underline;
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 2px;
    text-underline-offset: 0.5rem;
  }

  .dog-park-grid {
    display: grid;
    gap: 1px;
    border: 1px solid var(--color-border);
    background: var(--color-border);
  }

  .dog-park-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
  }

  .dog-park-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border-muted);
    background: var(--color-surface-muted);
  }

  .dog-park-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms;
  }

  .dog-park-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
  }

  .dog-park-card__body > div:first-child p,
  .dog-park-card__stats p:first-child {
    margin: 0;
    color: var(--color-text-subtle);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .dog-park-card h3 {
    margin: 0.25rem 0 0;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    line-height: var(--leading-tight);
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .dog-park-card__stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    border-block: 1px solid var(--color-border-muted);
    padding-block: 1rem;
  }

  .dog-park-card__stats div {
    display: grid;
    gap: 0.25rem;
  }

  .dog-park-card__stats p:last-child {
    margin: 0;
    color: var(--color-text-strong);
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    text-transform: uppercase;
  }

  .dog-park-card__links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
  }

  .dog-park-card__links a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid var(--color-border-muted);
    background: var(--color-page);
    color: var(--color-text-strong);
    padding: 0.75rem 1rem;
    font-family: var(--font-label);
    font-size: var(--text-label);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 200ms,
      color 200ms,
      transform 200ms;
  }

  .dog-park-card__links a:hover {
    background: var(--color-surface-inverse);
    color: var(--color-text-inverse);
  }

  .dog-park-card__links a:active {
    transform: scale(0.96);
  }

  @media (min-width: 40rem) {
    .dog-park-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 48rem) {
    .off-leash-parks__header {
      flex-direction: row;
      align-items: flex-end;
    }
  }

  @media (min-width: 64rem) {
    .dogs-hero__layout {
      grid-template-columns: 7fr 5fr;
    }

    .dogs-hero__identity {
      border-right: 1px solid var(--color-border);
      padding-inline: var(--space-page-x) 3rem;
    }

    .dogs-rules__layout {
      grid-template-columns: 5fr 7fr;
    }

    .dog-park-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
