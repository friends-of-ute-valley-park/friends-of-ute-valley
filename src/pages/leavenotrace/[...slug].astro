---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Picture } from "astro:assets";

export async function getStaticPaths() {
  const leavenotraceEntries = await getCollection("leavenotrace");
  return leavenotraceEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.topText}>
  <main class="page">
    <!-- Leave No Trace Guide -->
    <section class="page-hero">
      <div class="page-hero__inner">
        <div class="page-eyebrow">
          <span>
            Leave No Trace Guide
          </span>
        </div>

        <h1 class="page-title">
          {entry.data.title.split(" ").slice(0, -1).join(" ")}
          <br />
          <span
            >{entry.data.title.split(" ").slice(-1)}</span
          >
        </h1>

        <p class="page-intro">
          {entry.data.topText}
        </p>
      </div>
    </section>

    <!-- Content -->
    <section class="article-layout">
      <div class="article-layout__inner">
        <div class="article-layout__grid">
          <!-- Content -->
          <div class="article-layout__main">
            <div class="prose-content">
              <Content />
            </div>
          </div>

          <!-- Photos -->
          <div class="article-layout__aside">
            <div class="aside-stack">
              <div class="article-photo-card photo">
                <Picture
                  class="image"
                  formats={["avif", "webp"]}
                  width="1000"
                  height="1000"
                  src={entry.data.image}
                  alt={entry.data.imageAlt}
                />
                <div class="article-photo-card__meta">
                  <span>Photos</span>
                </div>
              </div>

              <div class="callout">
                <h3>
                  Why It Matters
                </h3>
                <p>
                  "Following the Seven Principles of Leave No Trace is the best
                  way we can all help in protecting the park for future
                  generations."
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .lnt-guide .aside-stack {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 64rem) {
    .lnt-guide .aside-stack {
      position: sticky;
      top: 6rem;
    }
  }

  :global(.lnt-guide .image) {
    width: 100%;
    height: auto;
    transform: scale(1.05);
    transition: transform var(--duration-slower);
  }

  .lnt-guide .photo:hover :global(.image) {
    transform: scale(1);
  }

  .lnt-guide .callout {
    border: 1px solid var(--color-border);
    background: var(--color-surface-inverse);
    color: var(--color-text-inverse);
    padding: 2rem;
  }

  .lnt-guide .callout h3 {
    margin: 0 0 1rem;
    color: var(--color-accent);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .lnt-guide .callout p {
    margin: 0;
    color: var(--color-text-inverse-muted);
    font-size: var(--text-body-small);
    font-style: italic;
    font-weight: 500;
    line-height: var(--leading-body);
  }
</style>
