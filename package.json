{
  "name": "friends-of-ute-valley-park",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "node ./scripts/ensure-pnpm.mjs",
    "dev": "pnpm run trails:update && astro dev",
    "start": "pnpm run dev",
    "build": "pnpm run trails:update && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint --type-aware && node ./scripts/check-design-tokens.mjs",
    "lint:design": "node ./scripts/check-design-tokens.mjs",
    "lint:fix": "oxlint --fix --type-aware",
    "format": "oxfmt",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "trails:update": "node --experimental-strip-types ./scripts/update-trailforks-data.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@cloudflare/pages-plugin-turnstile": "^1.0.2",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@vueuse/core": "^14.3.0",
    "astro": "^7.0.7",
    "dotenv": "^17.4.2",
    "maplibre-gl": "^5.24.0",
    "resend": "^6.17.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/vue": "^7.0.1",
    "@iconify/json": "^2.2.498",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.23.0",
    "sharp": "^0.35.3",
    "unplugin-icons": "^23.0.1",
    "vue": "^3.5.39"
  },
  "packageManager": "pnpm@11.9.0"
}
