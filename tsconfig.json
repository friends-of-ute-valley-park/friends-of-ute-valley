{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@assets/*": ["./src/assets/*"],
      "@/typings": ["./typings/index.ts"],
      "@/*": ["./src/*"]
    },
    "types": ["unplugin-icons/types/astro"]
  }
}
